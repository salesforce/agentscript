{
  "watch": [
    "generate-sidebar.ts",
    "sidebars.ts",
    "../../dialects/*/package.json",
    "../../packages/*/package.json",
    "../../dialects/*/pyproject.toml",
    "../../packages/*/pyproject.toml"
  ],
  "ext": "ts,json,toml",
  "ignore": [
    "node_modules/**",
    "build/**",
    ".docusaurus/**",
    "**/*.test.ts",
    "**/*.spec.ts"
  ],
  "exec": "docusaurus start --port 27000 --host 0.0.0.0 --no-open",
  "delay": 1000,
  "verbose": true
}
