{
  "name": "@agentscript/docs",
  "version": "2.0.0",
  "private": true,
  "description": "AgentScript documentation site",
  "scripts": {
    "docusaurus": "docusaurus",
    "extract-types": "tsx extract-types.ts",
    "validate-code-blocks": "tsx validate-code-blocks.ts",
    "validate-code-blocks:strict": "STRICT=1 tsx validate-code-blocks.ts",
    "prebuild": "pnpm run extract-types",
    "start": "docusaurus start --port 27000 --host 0.0.0.0",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve --port 27000 --host 0.0.0.0",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc",
    "dev": "nodemon",
    "dev:simple": "docusaurus start --port 27000 --host 0.0.0.0 --no-open",
    "clean": "rm -rf build .docusaurus"
  },
  "dependencies": {
    "@docusaurus/core": "^3.6.3",
    "@docusaurus/preset-classic": "^3.6.3",
    "@mdx-js/react": "^3.1.0",
    "clsx": "^2.1.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.6.3",
    "@docusaurus/tsconfig": "^3.6.3",
    "@docusaurus/types": "^3.6.3",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "docusaurus-plugin-typedoc": "1.0.5",
    "glob": "^12.0.0",
    "nodemon": "^3.0.0",
    "typedoc": "0.26.11",
    "typedoc-plugin-markdown": "4.2.10",
    "typescript": "^5.8.3",
    "unist-util-visit": "^5.1.0"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "volta": {
    "node": "22.22.1"
  }
}
