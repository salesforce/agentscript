{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build: vscode extension",
      "type": "shell",
      "command": "node",
      "args": ["packages/vscode/scripts/build-all.mjs"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$tsc"],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
