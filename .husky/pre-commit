# Run lint-staged for code quality
npx lint-staged

# Extract diagnostics and update documentation
pnpm extract-diagnostics

# Format the generated docs (the extractor emits non-prettier table separators)
# and stage the result so the committed file always passes `format:check` in CI.
npx prettier --write apps/docs/docs/architecture/diagnostic-reference.md 2>/dev/null || true
git add apps/docs/docs/architecture/diagnostic-reference.md 2>/dev/null || true
