                "description": "Items",
                "data_type": "String",
                "is_list": false,
                "is_used_by_planner": true,
                "is_displayable": false
              }
            ]
          }
        ],
        "instructions": "You are a support coordinator that routes customers to specialized agents.",
        "focus_prompt": "{{state.AgentScriptInternal_agent_instructions}}",
        "before_reasoning_iteration": [
          {
            "type": "action",
            "target": "__state_update_action__",
            "enabled": "True",
            "state_updates": [
              {
                "AgentScriptInternal_agent_instructions": "''"
              }
            ]
          },
          {
            "type": "action",
            "target": "__state_update_action__",
            "state_updates": [
              {
                "AgentScriptInternal_agent_instructions": "template::{{state.AgentScriptInternal_agent_instructions}}\nHelp the customer with their order inquiry.\nLook up order details and provide status updates."
              }
            ]
          }
        ]
      },
      {
        "type": "subagent",
        "reasoning_type": "salesforce.default",
        "description": "Handle billing and payment questions",
