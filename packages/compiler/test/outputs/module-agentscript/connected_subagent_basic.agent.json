      {
        "type": "subagent",
        "reasoning_type": "salesforce.default",
        "description": "Assess customer needs and route to the right agent",
        "tools": [
          {
            "type": "action",
            "target": "lookup_customer",
            "bound_inputs": {
              "customer_id": "variables.Customer_Id"
            },
            "llm_inputs": [],
            "state_updates": [],
            "name": "lookup_customer",
            "description": "Lookup Customer"
          },
          {
            "type": "action",
            "target": "__state_update_action__",
            "state_updates": [
              {
                "AgentScriptInternal_next_topic": "\"Order_Support\""
              }
            ],
            "name": "go_to_orders",
            "description": "Route to order support agent"
          },
          {
            "type": "action",
            "target": "__state_update_action__",
            "state_updates": [
              {
                "AgentScriptInternal_next_topic": "\"Billing_Support\""
              }
            ],
            "name": "go_to_billing",
            "description": "Route to billing agent"
          }
        ],
        "developer_name": "Triage",
        "label": "Triage",
        "action_definitions": [
          {
            "developer_name": "lookup_customer",
            "label": "Lookup Customer",
            "description": "Look up customer details",
            "require_user_confirmation": false,
            "include_in_progress_indicator": false,
            "invocation_target_type": "apex",
            "invocation_target_name": "lookup_customer",
            "input_type": [
              {
                "developer_name": "customer_id",
                "label": "Customer Id",
                "description": "Customer Id",
                "data_type": "String",
                "is_list": false,
                "required": false,
                "is_user_input": false
              }
            ],
            "output_type": [
              {
                "developer_name": "name",
                "label": "Name",
                "description": "Name",
                "data_type": "String",
                "is_list": false,
                "is_used_by_planner": true,
                "is_displayable": false
              },
              {
                "developer_name": "tier",
                "label": "Tier",
                "description": "Tier",
                "data_type": "String",
                "is_list": false,
                "is_used_by_planner": true,
                "is_displayable": false
              }
            ]
          }
        ],
        "instructions": "You are a support coordinator that routes customers to specialized agents.",
        "focus_prompt": "{{state.AgentScriptInternal_agent_instructions}}",
        "before_reasoning_iteration": [
          {
            "type": "action",
            "target": "__state_update_action__",
            "enabled": "True",
            "state_updates": [
              {
                "AgentScriptInternal_agent_instructions": "''"
              }
            ]
          },
          {
            "type": "action",
            "target": "__state_update_action__",
            "state_updates": [
              {
                "AgentScriptInternal_agent_instructions": "template::{{state.AgentScriptInternal_agent_instructions}}\nYou are a triage agent. Assess what the customer needs\nand route them to the appropriate specialized agent.\nUse the lookup_customer action to get customer details first."
              }
            ]
          }
        ],
        "after_all_tool_calls": [
          {
            "type": "handoff",
            "target": "Order_Support",
            "enabled": "state.AgentScriptInternal_next_topic==\"Order_Support\"",
            "state_updates": [
              {
                "AgentScriptInternal_next_topic": "\"__EMPTY__\""
              }
            ]
          },
          {
            "type": "handoff",
            "target": "Billing_Support",
            "enabled": "state.AgentScriptInternal_next_topic==\"Billing_Support\"",
            "state_updates": [
              {
                "AgentScriptInternal_next_topic": "\"__EMPTY__\""
              }
            ]
          }
        ]
      },
