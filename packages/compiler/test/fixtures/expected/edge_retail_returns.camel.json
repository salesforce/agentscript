            "type": "action",
            "target": "__state_update_action__",
            "stateUpdates": [
              {
                "AgentScriptInternal_agent_instructions": "template::{{state.AgentScriptInternal_agent_instructions}}\nThis case needs human review. Escalate to a returns specialist."
              }
            ]
          }
        ],
        "afterAllToolCalls": [
          {
            "type": "handoff",
            "target": "__human__",
            "enabled": "state.AgentScriptInternal_next_topic == '__human__'",
            "stateUpdates": [
              {
                "AgentScriptInternal_next_topic": "\"__EMPTY__\""
              }
            ]
          }
        ]
      }
