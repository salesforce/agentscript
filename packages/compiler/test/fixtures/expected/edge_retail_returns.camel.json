        "dataType": "string",
        "isList": false,
        "visibility": "Internal",
        "default": "''"
      },
      {
        "developerName": "order_number",
        "label": "Order Number",
        "description": "Order number for the return",
        "dataType": "string",
        "isList": false,
        "visibility": "Internal",
        "default": "''"
      },
      {
        "developerName": "return_eligible",
        "label": "Return Eligible",
