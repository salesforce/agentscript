        "dataType": "boolean",
        "isList": false,
        "visibility": "Internal",
        "default": false
      },
      {
        "developerName": "refund_amount",
        "label": "Refund Amount",
        "description": "Calculated refund amount",
        "dataType": "number",
        "isList": false,
        "visibility": "Internal",
        "default": 0
