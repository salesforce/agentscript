      {
        "developerName": "return_reason",
        "label": "Return Reason",
        "description": "Reason for the return",
        "dataType": "string",
        "isList": false,
        "visibility": "Internal",
        "default": "''"
      },
      {
        "developerName": "case_id",
        "label": "Case Id",
        "description": "Support case ID",
        "dataType": "string",
        "isList": false,
        "visibility": "Internal",
        "default": "''"
      },
      {
        "developerName": "AgentScriptInternal_condition_1",
        "label": "Runtime Condition 1",
        "description": "Runtime condition evaluation for if statements",
        "dataType": "boolean",
        "isList": false,
        "visibility": "Internal"
      }
