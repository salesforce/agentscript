        "dataType": "string",
        "isList": false,
        "visibility": "Internal",
        "default": "''"
      },
      {
        "developerName": "Support_Plan_c",
        "label": "Support Plan C",
        "description": "Support plan custom field",
        "dataType": "string",
        "isList": false,
        "visibility": "Internal",
        "default": "'Basic'"
