          {
            "type": "action",
            "target": "__state_update_action__",
            "enabled": "True",
            "stateUpdates": [
              {
                "AgentScriptInternal_agent_instructions": "''"
              }
            ]
          },
          {
            "type": "action",
            "target": "__state_update_action__",
            "stateUpdates": [
              {
                "AgentScriptInternal_agent_instructions": "template::{{state.AgentScriptInternal_agent_instructions}}\nCheck the customer tier and loyalty points"
              }
            ]
          }
        ]
      }
    ],
    "surfaces": [],
    "modalityParameters": {},
    "additionalParameters": {
      "reset_to_initial_node": true
