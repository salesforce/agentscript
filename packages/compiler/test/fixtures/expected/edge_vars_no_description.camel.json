      {
        "developerName": "session_ref",
        "label": "Session Ref",
        "description": "Session_Ref",
        "dataType": "string",
        "fieldMapping": "MessagingSession.Id"
      }
    ]
  },
  "agentVersion": {
    "plannerType": "Atlas__ConcurrentMultiAgentOrchestration",
    "systemMessages": [],
