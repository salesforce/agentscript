    "initialNode": "main",
    "nodes": [
      {
        "type": "subagent",
        "reasoningType": "salesforce.default",
        "description": "Process without described variables",
        "tools": [],
        "developerName": "main",
        "label": "Main",
        "actionDefinitions": [],
