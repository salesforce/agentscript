        "focusPrompt": "{{state.AgentScriptInternal_agent_instructions}}",
        "beforeReasoningIteration": [
          {
            "type": "action",
            "target": "__state_update_action__",
            "enabled": "True",
            "stateUpdates": [
              {
                "AgentScriptInternal_agent_instructions": "''"
              }
            ]
          },
          {
            "type": "action",
            "target": "__state_update_action__",
            "stateUpdates": [
              {
                "AgentScriptInternal_agent_instructions": "template::{{state.AgentScriptInternal_agent_instructions}}\nProcess the request using available variables"
              }
            ]
          }
        ]
      }
    ],
    "surfaces": [],
    "modalityParameters": {},
