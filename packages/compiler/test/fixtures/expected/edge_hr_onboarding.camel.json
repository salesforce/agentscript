        "beforeReasoningIteration": [
          {
            "type": "action",
            "target": "__state_update_action__",
            "enabled": "True",
            "stateUpdates": [
              {
                "AgentScriptInternal_agent_instructions": "''"
              }
            ]
          },
          {
            "type": "action",
            "target": "__state_update_action__",
            "stateUpdates": [
              {
                "AgentScriptInternal_agent_instructions": "template::{{state.AgentScriptInternal_agent_instructions}}\nSet up the employee's IT accounts and order equipment.\nThis includes email, VPN access, and laptop provisioning."
              }
            ]
          }
        ],
        "afterAllToolCalls": [
          {
            "type": "handoff",
            "target": "benefits_enrollment",
            "enabled": "state.AgentScriptInternal_next_topic==\"benefits_enrollment\"",
            "stateUpdates": [
              {
                "AgentScriptInternal_next_topic": "\"__EMPTY__\""
              }
            ]
          }
        ]
