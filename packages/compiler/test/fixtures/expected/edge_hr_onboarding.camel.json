                "description": "Employee Id",
                "dataType": "String",
                "isList": false,
                "required": false,
                "isUserInput": false
              }
            ],
            "outputType": [
              {
                "developerName": "enrolled",
                "label": "Enrolled",
                "description": "Enrolled",
                "dataType": "Boolean",
                "isList": false,
                "isUsedByPlanner": true,
