        "instructions": "You are an HR onboarding assistant that helps new employees complete their onboarding tasks.",
        "focusPrompt": "{{state.AgentScriptInternal_agent_instructions}}",
        "beforeReasoningIteration": [
          {
            "type": "action",
            "target": "__state_update_action__",
            "enabled": "True",
            "stateUpdates": [
              {
                "AgentScriptInternal_agent_instructions": "''"
              }
            ]
          },
          {
            "type": "action",
            "target": "__state_update_action__",
            "stateUpdates": [
              {
                "AgentScriptInternal_agent_instructions": "template::{{state.AgentScriptInternal_agent_instructions}}\nGuide the employee through benefits selection.\nAvailable plans: health insurance, dental, vision, 401k, life insurance."
