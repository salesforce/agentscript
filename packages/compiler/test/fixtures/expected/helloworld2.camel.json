    "initialNode": "poet",
    "nodes": [
      {
        "type": "subagent",
        "reasoningType": "salesforce.default",
        "description": "you do things",
        "tools": [],
        "developerName": "poet",
        "label": "Poet",
        "actionDefinitions": [],
