            "stateUpdates": [
              {
                "AgentScriptInternal_next_topic": "\"__EMPTY__\""
              }
            ]
          }
        ]
      },
      {
        "type": "subagent",
        "reasoningType": "salesforce.default",
        "description": "Performs regulatory compliance screening",
