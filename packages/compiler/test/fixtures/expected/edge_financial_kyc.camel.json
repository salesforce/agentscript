                "AgentScriptInternal_next_topic": "\"__EMPTY__\""
              }
            ]
          },
          {
            "type": "action",
            "target": "__state_update_action__",
            "enabled": "state.AgentScriptInternal_next_topic==\"__EMPTY__\"",
            "stateUpdates": [
              {
                "AgentScriptInternal_condition_1": "state.compliance_passed == True"
              }
            ]
          },
          {
            "type": "action",
            "target": "__state_update_action__",
            "enabled": "(state.AgentScriptInternal_next_topic==\"__EMPTY__\") and (state.AgentScriptInternal_condition_1)",
            "stateUpdates": [
              {
                "verification_status": "\"approved\""
              }
            ]
          },
          {
            "type": "action",
            "target": "__state_update_action__",
            "enabled": "state.AgentScriptInternal_next_topic==\"__EMPTY__\"",
            "stateUpdates": [
              {
                "AgentScriptInternal_condition_1": "state.compliance_passed == False"
              }
            ]
          },
          {
            "type": "action",
            "target": "__state_update_action__",
            "enabled": "(state.AgentScriptInternal_next_topic==\"__EMPTY__\") and (state.AgentScriptInternal_condition_1)",
            "stateUpdates": [
              {
                "verification_status": "\"review_required\""
              }
            ]
          }
        ],
        "afterAllToolCalls": [
          {
            "type": "handoff",
            "target": "__human__",
            "enabled": "state.AgentScriptInternal_next_topic == '__human__'",
            "stateUpdates": [
              {
                "AgentScriptInternal_next_topic": "\"__EMPTY__\""
              }
            ]
          }
        ]
