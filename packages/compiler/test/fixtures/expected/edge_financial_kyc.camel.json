            "name": "check"
          },
          {
            "type": "action",
            "target": "__state_update_action__",
            "stateUpdates": [
              {
                "AgentScriptInternal_next_topic": "\"compliance_review\""
              }
            ],
            "name": "go_compliance",
            "description": "Proceed to compliance check"
          }
        ],
        "developerName": "document_verification",
        "label": "Document Verification",
        "actionDefinitions": [
          {
            "developerName": "check_documents",
