        "description": "Performs initial identity verification",
        "tools": [
          {
            "type": "action",
            "target": "verify_identity",
            "bound_inputs": {
              "customer_id": "state.customer_id"
            },
            "llm_inputs": [
              "full_name",
              "date_of_birth"
            ],
            "state_updates": [
