                "isUsedByPlanner": true,
                "isDisplayable": false
              },
              {
                "developerName": "total_credits",
                "label": "Total Credits",
                "description": "Total Credits",
                "dataType": "Double",
                "isList": false,
                "isUsedByPlanner": true,
                "isDisplayable": false
              }
            ]
          }
        ],
        "instructions": "You are a student enrollment assistant. Help students search for courses, check financial aid eligibility, and complete registration.",
        "focusPrompt": "{{state.AgentScriptInternal_agent_instructions}}",
        "beforeReasoningIteration": [
          {
            "type": "action",
            "target": "__state_update_action__",
