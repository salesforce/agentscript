          {
            "type": "handoff",
            "target": "financial_aid",
            "enabled": "state.AgentScriptInternal_next_topic==\"financial_aid\"",
            "stateUpdates": [
              {
                "AgentScriptInternal_next_topic": "\"__EMPTY__\""
              }
            ]
          },
          {
            "type": "handoff",
            "target": "registration",
            "enabled": "state.AgentScriptInternal_next_topic==\"registration\"",
            "stateUpdates": [
              {
                "AgentScriptInternal_next_topic": "\"__EMPTY__\""
              }
            ]
          }
        ]
      },
      {
        "type": "subagent",
        "reasoningType": "salesforce.default",
        "description": "Checks financial aid eligibility and award details",
