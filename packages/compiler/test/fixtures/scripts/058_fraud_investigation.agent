system:
    instructions: |
        You are a professional fraud investigation agent assistant.
        Help users manage their fraud_case requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: alert_review -> evidence_collection -> pattern_analysis -> determination.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Fraud Investigation Agent Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "fraud_investigation_agent_v58"
    default_agent_user: "fraud_investigation@example.com"
    agent_description: "Assists users with fraud_case management through the fraud investigation agent workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    fraud_case_record_id: mutable string
        description: "Record ID of the fraud_case"
    fraud_case_status: mutable string = ""
        description: "Current status of the fraud_case"
    fraud_case_tier: mutable string = "standard"
        description: "Tier classification for the fraud_case"
    fraud_case_category: mutable string = ""
        description: "Category of the fraud_case"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    alert_review_complete: mutable boolean = False
        description: "Whether the alert_review stage is complete"
    alert_review_result: mutable string = ""
        description: "Result from the alert_review stage"
    evidence_collection_complete: mutable boolean = False
        description: "Whether the evidence_collection stage is complete"
    evidence_collection_result: mutable string = ""
        description: "Result from the evidence_collection stage"
    pattern_analysis_complete: mutable boolean = False
        description: "Whether the pattern_analysis stage is complete"
    pattern_analysis_result: mutable string = ""
        description: "Result from the pattern_analysis stage"
    determination_complete: mutable boolean = False
        description: "Whether the determination stage is complete"
    determination_result: mutable string = ""
        description: "Result from the determination stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate fraud_case management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a fraud investigation agent assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current fraud_case status: {! @variables.fraud_case_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_alert_review} for alert review requests.
              Use {!@actions.go_to_evidence_collection} for evidence collection requests.
              Use {!@actions.go_to_pattern_analysis} for pattern analysis requests.
              Use {!@actions.go_to_determination} for determination requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_alert_review: @utils.transition to @topic.alert_review
                description: "Transition to alert review topic."
            go_to_evidence_collection: @utils.transition to @topic.evidence_collection
                description: "Transition to evidence collection topic."
                available when @variables.is_verified == True
            go_to_pattern_analysis: @utils.transition to @topic.pattern_analysis
                description: "Transition to pattern analysis topic."
                available when @variables.is_verified == True
            go_to_determination: @utils.transition to @topic.determination
                description: "Transition to determination topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic alert_review:
    description: "Handles the alert review stage of the fraud_case process"

    actions:
        process_alert_review_data:
            description: "Process alert review stage data for the fraud_case"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_AlertReview_Data"

        validate_alert_review_info:
            description: "Validate alert review information for the fraud_case"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_AlertReview_Info"

        fetch_alert_review_details:
            description: "Fetch alert review details for the fraud_case"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_AlertReview_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_alert_review_info
                with record_ref=@variables.fraud_case_record_id
                with contact_ref=@variables.contact_email
                set @variables.fraud_case_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the alert review stage for the fraud_case.
              Current fraud_case status: {! @variables.fraud_case_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Alert Review result: {! @variables.alert_review_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.fraud_case_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_alert_review} to begin processing.
        actions:
            run_alert_review: @actions.process_alert_review_data
                with record_ref=@variables.fraud_case_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.fraud_case_category
                set @variables.alert_review_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.alert_review_complete = @outputs.is_passed
            fetch_alert_review_info: @actions.fetch_alert_review_details
                with record_ref=@variables.fraud_case_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.fraud_case_tier = @outputs.tier_value
            go_to_evidence_collection: @utils.transition to @topic.evidence_collection
                description: "Move to evidence collection stage."
                available when @variables.alert_review_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.fraud_case_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.fraud_case_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.fraud_case_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.alert_review_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic evidence_collection:
    description: "Handles the evidence collection stage of the fraud_case process"

    actions:
        process_evidence_collection_data:
            description: "Process evidence collection stage data for the fraud_case"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_EvidenceCollection"

        validate_evidence_collection_info:
            description: "Validate evidence collection information for the fraud_case"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_EvidenceCollection_Info"

        fetch_evidence_collection_details:
            description: "Fetch evidence collection details for the fraud_case"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_EvidenceCollection_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.alert_review_complete == False:
            transition to @topic.alert_review

    reasoning:
        instructions: ->
            | Handle the evidence collection stage for the fraud_case.
              Current fraud_case status: {! @variables.fraud_case_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Evidence Collection result: {! @variables.evidence_collection_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.fraud_case_tier }
              Review the evidence collection results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_evidence_collection: @actions.process_evidence_collection_data
                with record_ref=@variables.fraud_case_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.fraud_case_category
                set @variables.evidence_collection_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.evidence_collection_complete = @outputs.is_passed
            fetch_evidence_collection_info: @actions.fetch_evidence_collection_details
                with record_ref=@variables.fraud_case_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.fraud_case_tier = @outputs.tier_value
                available when @variables.fraud_case_record_id is not None
            go_to_pattern_analysis: @utils.transition to @topic.pattern_analysis
                description: "Move to pattern analysis stage."
                available when @variables.evidence_collection_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.evidence_collection_complete == True:
            set @variables.fraud_case_status = "evidence_collection_done"
        if @variables.evidence_collection_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.pattern_analysis
        if @variables.attempt_count >= 3 and @variables.evidence_collection_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic pattern_analysis:
    description: "Handles the pattern analysis stage of the fraud_case process"

    actions:
        process_pattern_analysis_data:
            description: "Process pattern analysis stage data for the fraud_case"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_PatternAnalysis"

        validate_pattern_analysis_info:
            description: "Validate pattern analysis information for the fraud_case"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_PatternAnalysis_Info"

        fetch_pattern_analysis_details:
            description: "Fetch pattern analysis details for the fraud_case"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_PatternAnalysis_Details"

    before_reasoning:
        if @variables.pattern_analysis_complete == False:
            run @actions.fetch_pattern_analysis_details
                with record_ref=@variables.fraud_case_record_id
                with include_history=True
                set @variables.pattern_analysis_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.fraud_case_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.fraud_case_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.fraud_case_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the pattern analysis stage for the fraud_case.
              Current fraud_case status: {! @variables.fraud_case_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Pattern Analysis result: {! @variables.pattern_analysis_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.fraud_case_tier }
              Review the pattern analysis results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_pattern_analysis: @actions.process_pattern_analysis_data
                with record_ref=@variables.fraud_case_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.fraud_case_category
                set @variables.pattern_analysis_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.pattern_analysis_complete = @outputs.is_passed
            fetch_pattern_analysis_info: @actions.fetch_pattern_analysis_details
                with record_ref=@variables.fraud_case_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.fraud_case_tier = @outputs.tier_value
                available when @variables.fraud_case_record_id is not None
            go_to_determination: @utils.transition to @topic.determination
                description: "Move to determination stage."
                available when @variables.pattern_analysis_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.fraud_case_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.fraud_case_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.fraud_case_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.pattern_analysis_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic determination:
    description: "Handles the determination stage of the fraud_case process"

    actions:
        process_determination_data:
            description: "Process determination stage data for the fraud_case"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_Determination_Data"

        validate_determination_info:
            description: "Validate determination information for the fraud_case"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Determination_Info"

        fetch_determination_details:
            description: "Fetch determination details for the fraud_case"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Determination_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.pattern_analysis_complete == False:
            transition to @topic.pattern_analysis
        if @variables.eligibility_score >= 80:
            set @variables.fraud_case_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.fraud_case_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the determination stage for the fraud_case.
              Current fraud_case status: {! @variables.fraud_case_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Determination result: {! @variables.determination_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.fraud_case_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_determination: @actions.process_determination_data
                with record_ref=@variables.fraud_case_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.fraud_case_category
                set @variables.determination_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.determination_complete = @outputs.is_passed
            fetch_determination_info: @actions.fetch_determination_details
                with record_ref=@variables.fraud_case_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.fraud_case_tier = @outputs.tier_value
                available when @variables.fraud_case_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.determination_complete == True:
            set @variables.fraud_case_status = "determination_done"
        if @variables.attempt_count >= 3 and @variables.determination_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for fraud_case issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the fraud_case issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the fraud_case interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the fraud_case request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Fraud Case status: {! @variables.fraud_case_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.fraud_case_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.fraud_case_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.fraud_case_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.fraud_case_status = "escalated"
        set @variables.escalation_requested = False

