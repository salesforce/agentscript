system:
    instructions: |
        You are a professional compliance enforcement agent assistant.
        Help users manage their violation requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: detection -> investigation -> citation -> follow_up.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Compliance Enforcement Agent Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "compliance_enforcement_agent_v94"
    default_agent_user: "compliance_enforcement@example.com"
    agent_description: "Assists users with violation management through the compliance enforcement agent workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    violation_record_id: mutable string
        description: "Record ID of the violation"
    violation_status: mutable string = ""
        description: "Current status of the violation"
    violation_tier: mutable string = "standard"
        description: "Tier classification for the violation"
    violation_category: mutable string = ""
        description: "Category of the violation"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    detection_complete: mutable boolean = False
        description: "Whether the detection stage is complete"
    detection_result: mutable string = ""
        description: "Result from the detection stage"
    investigation_complete: mutable boolean = False
        description: "Whether the investigation stage is complete"
    investigation_result: mutable string = ""
        description: "Result from the investigation stage"
    citation_complete: mutable boolean = False
        description: "Whether the citation stage is complete"
    citation_result: mutable string = ""
        description: "Result from the citation stage"
    follow_up_complete: mutable boolean = False
        description: "Whether the follow_up stage is complete"
    follow_up_result: mutable string = ""
        description: "Result from the follow_up stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate violation management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a compliance enforcement agent assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current violation status: {! @variables.violation_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_detection} for detection requests.
              Use {!@actions.go_to_investigation} for investigation requests.
              Use {!@actions.go_to_citation} for citation requests.
              Use {!@actions.go_to_follow_up} for follow up requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_detection: @utils.transition to @topic.detection
                description: "Transition to detection topic."
            go_to_investigation: @utils.transition to @topic.investigation
                description: "Transition to investigation topic."
                available when @variables.is_verified == True
            go_to_citation: @utils.transition to @topic.citation
                description: "Transition to citation topic."
                available when @variables.is_verified == True
            go_to_follow_up: @utils.transition to @topic.follow_up
                description: "Transition to follow up topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic detection:
    description: "Handles the detection stage of the violation process"

    actions:
        process_detection_data:
            description: "Process detection stage data for the violation"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_Detection_Data"

        validate_detection_info:
            description: "Validate detection information for the violation"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Detection_Info"

        fetch_detection_details:
            description: "Fetch detection details for the violation"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Detection_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_detection_info
                with record_ref=@variables.violation_record_id
                with contact_ref=@variables.contact_email
                set @variables.violation_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the detection stage for the violation.
              Current violation status: {! @variables.violation_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Detection result: {! @variables.detection_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.violation_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_detection} to begin processing.
        actions:
            run_detection: @actions.process_detection_data
                with record_ref=@variables.violation_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.violation_category
                set @variables.detection_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.detection_complete = @outputs.is_passed
            fetch_detection_info: @actions.fetch_detection_details
                with record_ref=@variables.violation_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.violation_tier = @outputs.tier_value
            go_to_investigation: @utils.transition to @topic.investigation
                description: "Move to investigation stage."
                available when @variables.detection_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.violation_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.violation_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.violation_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.detection_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic investigation:
    description: "Handles the investigation stage of the violation process"

    actions:
        process_investigation_data:
            description: "Process investigation stage data for the violation"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_Investigation"

        validate_investigation_info:
            description: "Validate investigation information for the violation"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Investigation_Info"

        fetch_investigation_details:
            description: "Fetch investigation details for the violation"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Investigation_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.detection_complete == False:
            transition to @topic.detection

    reasoning:
        instructions: ->
            | Handle the investigation stage for the violation.
              Current violation status: {! @variables.violation_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Investigation result: {! @variables.investigation_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.violation_tier }
              Review the investigation results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_investigation: @actions.process_investigation_data
                with record_ref=@variables.violation_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.violation_category
                set @variables.investigation_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.investigation_complete = @outputs.is_passed
            fetch_investigation_info: @actions.fetch_investigation_details
                with record_ref=@variables.violation_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.violation_tier = @outputs.tier_value
                available when @variables.violation_record_id is not None
            go_to_citation: @utils.transition to @topic.citation
                description: "Move to citation stage."
                available when @variables.investigation_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.investigation_complete == True:
            set @variables.violation_status = "investigation_done"
        if @variables.investigation_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.citation
        if @variables.attempt_count >= 3 and @variables.investigation_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic citation:
    description: "Handles the citation stage of the violation process"

    actions:
        process_citation_data:
            description: "Process citation stage data for the violation"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_Citation"

        validate_citation_info:
            description: "Validate citation information for the violation"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Citation_Info"

        fetch_citation_details:
            description: "Fetch citation details for the violation"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Citation_Details"

    before_reasoning:
        if @variables.citation_complete == False:
            run @actions.fetch_citation_details
                with record_ref=@variables.violation_record_id
                with include_history=True
                set @variables.citation_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.violation_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.violation_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.violation_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the citation stage for the violation.
              Current violation status: {! @variables.violation_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Citation result: {! @variables.citation_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.violation_tier }
              Review the citation results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_citation: @actions.process_citation_data
                with record_ref=@variables.violation_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.violation_category
                set @variables.citation_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.citation_complete = @outputs.is_passed
            fetch_citation_info: @actions.fetch_citation_details
                with record_ref=@variables.violation_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.violation_tier = @outputs.tier_value
                available when @variables.violation_record_id is not None
            go_to_follow_up: @utils.transition to @topic.follow_up
                description: "Move to follow up stage."
                available when @variables.citation_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.violation_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.violation_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.violation_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.citation_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic follow_up:
    description: "Handles the follow up stage of the violation process"

    actions:
        process_follow_up_data:
            description: "Process follow up stage data for the violation"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_FollowUp_Data"

        validate_follow_up_info:
            description: "Validate follow up information for the violation"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_FollowUp_Info"

        fetch_follow_up_details:
            description: "Fetch follow up details for the violation"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_FollowUp_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.citation_complete == False:
            transition to @topic.citation
        if @variables.eligibility_score >= 80:
            set @variables.violation_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.violation_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the follow up stage for the violation.
              Current violation status: {! @variables.violation_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Follow Up result: {! @variables.follow_up_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.violation_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_follow_up: @actions.process_follow_up_data
                with record_ref=@variables.violation_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.violation_category
                set @variables.follow_up_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.follow_up_complete = @outputs.is_passed
            fetch_follow_up_info: @actions.fetch_follow_up_details
                with record_ref=@variables.violation_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.violation_tier = @outputs.tier_value
                available when @variables.violation_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.follow_up_complete == True:
            set @variables.violation_status = "follow_up_done"
        if @variables.attempt_count >= 3 and @variables.follow_up_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for violation issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the violation issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the violation interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the violation request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Violation status: {! @variables.violation_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.violation_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.violation_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.violation_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.violation_status = "escalated"
        set @variables.escalation_requested = False

