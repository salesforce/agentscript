config:
    agent_name: "ConstantValuesEdgeCases"

knowledge:
    citations_url: ""
    citations_enabled: False
    rag_feature_config_id: "https://example.com"

start_agent main:
    description: "Test edge cases for constant value resolution"

    actions:
        test_action:
            description: "Action with edge case constant values"
            inputs:
                query: string
                empty_url: string = @knowledge.citations_url
                cite_disabled: boolean = @knowledge.citations_enabled
                rag_id: string = @knowledge.rag_feature_config_id
            outputs:
                result: string
            target: "flow://TestAction"

    reasoning:
        instructions: ->
            | Test edge cases for constant_value
        actions:
            run_test: @actions.test_action
