system:
    instructions: |
        You are a professional energy management specialist assistant.
        Help users manage their energy requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: consumption_analysis -> optimization -> reporting -> target_setting.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Energy Management Specialist Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "energy_management_agent_v88"
    default_agent_user: "energy_management@example.com"
    agent_description: "Assists users with energy management through the energy management specialist workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    energy_record_id: mutable string
        description: "Record ID of the energy"
    energy_status: mutable string = ""
        description: "Current status of the energy"
    energy_tier: mutable string = "standard"
        description: "Tier classification for the energy"
    energy_category: mutable string = ""
        description: "Category of the energy"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    consumption_analysis_complete: mutable boolean = False
        description: "Whether the consumption_analysis stage is complete"
    consumption_analysis_result: mutable string = ""
        description: "Result from the consumption_analysis stage"
    optimization_complete: mutable boolean = False
        description: "Whether the optimization stage is complete"
    optimization_result: mutable string = ""
        description: "Result from the optimization stage"
    reporting_complete: mutable boolean = False
        description: "Whether the reporting stage is complete"
    reporting_result: mutable string = ""
        description: "Result from the reporting stage"
    target_setting_complete: mutable boolean = False
        description: "Whether the target_setting stage is complete"
    target_setting_result: mutable string = ""
        description: "Result from the target_setting stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate energy management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a energy management specialist assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current energy status: {! @variables.energy_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_consumption_analysis} for consumption analysis requests.
              Use {!@actions.go_to_optimization} for optimization requests.
              Use {!@actions.go_to_reporting} for reporting requests.
              Use {!@actions.go_to_target_setting} for target setting requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_consumption_analysis: @utils.transition to @topic.consumption_analysis
                description: "Transition to consumption analysis topic."
            go_to_optimization: @utils.transition to @topic.optimization
                description: "Transition to optimization topic."
                available when @variables.is_verified == True
            go_to_reporting: @utils.transition to @topic.reporting
                description: "Transition to reporting topic."
                available when @variables.is_verified == True
            go_to_target_setting: @utils.transition to @topic.target_setting
                description: "Transition to target setting topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic consumption_analysis:
    description: "Handles the consumption analysis stage of the energy process"

    actions:
        process_consumption_analysis_data:
            description: "Process consumption analysis stage data for the energy"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_ConsumptionAnalysis_Data"

        validate_consumption_analysis_info:
            description: "Validate consumption analysis information for the energy"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_ConsumptionAnalysis_Info"

        fetch_consumption_analysis_details:
            description: "Fetch consumption analysis details for the energy"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_ConsumptionAnalysis_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_consumption_analysis_info
                with record_ref=@variables.energy_record_id
                with contact_ref=@variables.contact_email
                set @variables.energy_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the consumption analysis stage for the energy.
              Current energy status: {! @variables.energy_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Consumption Analysis result: {! @variables.consumption_analysis_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.energy_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_consumption_analysis} to begin processing.
        actions:
            run_consumption_analysis: @actions.process_consumption_analysis_data
                with record_ref=@variables.energy_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.energy_category
                set @variables.consumption_analysis_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.consumption_analysis_complete = @outputs.is_passed
            fetch_consumption_analysis_info: @actions.fetch_consumption_analysis_details
                with record_ref=@variables.energy_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.energy_tier = @outputs.tier_value
            go_to_optimization: @utils.transition to @topic.optimization
                description: "Move to optimization stage."
                available when @variables.consumption_analysis_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.energy_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.energy_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.energy_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.consumption_analysis_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic optimization:
    description: "Handles the optimization stage of the energy process"

    actions:
        process_optimization_data:
            description: "Process optimization stage data for the energy"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_Optimization"

        validate_optimization_info:
            description: "Validate optimization information for the energy"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Optimization_Info"

        fetch_optimization_details:
            description: "Fetch optimization details for the energy"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Optimization_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.consumption_analysis_complete == False:
            transition to @topic.consumption_analysis

    reasoning:
        instructions: ->
            | Handle the optimization stage for the energy.
              Current energy status: {! @variables.energy_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Optimization result: {! @variables.optimization_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.energy_tier }
              Review the optimization results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_optimization: @actions.process_optimization_data
                with record_ref=@variables.energy_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.energy_category
                set @variables.optimization_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.optimization_complete = @outputs.is_passed
            fetch_optimization_info: @actions.fetch_optimization_details
                with record_ref=@variables.energy_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.energy_tier = @outputs.tier_value
                available when @variables.energy_record_id is not None
            go_to_reporting: @utils.transition to @topic.reporting
                description: "Move to reporting stage."
                available when @variables.optimization_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.optimization_complete == True:
            set @variables.energy_status = "optimization_done"
        if @variables.optimization_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.reporting
        if @variables.attempt_count >= 3 and @variables.optimization_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic reporting:
    description: "Handles the reporting stage of the energy process"

    actions:
        process_reporting_data:
            description: "Process reporting stage data for the energy"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_Reporting"

        validate_reporting_info:
            description: "Validate reporting information for the energy"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Reporting_Info"

        fetch_reporting_details:
            description: "Fetch reporting details for the energy"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Reporting_Details"

    before_reasoning:
        if @variables.reporting_complete == False:
            run @actions.fetch_reporting_details
                with record_ref=@variables.energy_record_id
                with include_history=True
                set @variables.reporting_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.energy_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.energy_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.energy_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the reporting stage for the energy.
              Current energy status: {! @variables.energy_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Reporting result: {! @variables.reporting_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.energy_tier }
              Review the reporting results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_reporting: @actions.process_reporting_data
                with record_ref=@variables.energy_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.energy_category
                set @variables.reporting_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.reporting_complete = @outputs.is_passed
            fetch_reporting_info: @actions.fetch_reporting_details
                with record_ref=@variables.energy_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.energy_tier = @outputs.tier_value
                available when @variables.energy_record_id is not None
            go_to_target_setting: @utils.transition to @topic.target_setting
                description: "Move to target setting stage."
                available when @variables.reporting_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.energy_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.energy_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.energy_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.reporting_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic target_setting:
    description: "Handles the target setting stage of the energy process"

    actions:
        process_target_setting_data:
            description: "Process target setting stage data for the energy"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_TargetSetting_Data"

        validate_target_setting_info:
            description: "Validate target setting information for the energy"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_TargetSetting_Info"

        fetch_target_setting_details:
            description: "Fetch target setting details for the energy"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_TargetSetting_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.reporting_complete == False:
            transition to @topic.reporting
        if @variables.eligibility_score >= 80:
            set @variables.energy_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.energy_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the target setting stage for the energy.
              Current energy status: {! @variables.energy_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Target Setting result: {! @variables.target_setting_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.energy_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_target_setting: @actions.process_target_setting_data
                with record_ref=@variables.energy_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.energy_category
                set @variables.target_setting_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.target_setting_complete = @outputs.is_passed
            fetch_target_setting_info: @actions.fetch_target_setting_details
                with record_ref=@variables.energy_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.energy_tier = @outputs.tier_value
                available when @variables.energy_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.target_setting_complete == True:
            set @variables.energy_status = "target_setting_done"
        if @variables.attempt_count >= 3 and @variables.target_setting_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for energy issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the energy issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the energy interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the energy request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Energy status: {! @variables.energy_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.energy_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.energy_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.energy_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.energy_status = "escalated"
        set @variables.escalation_requested = False

