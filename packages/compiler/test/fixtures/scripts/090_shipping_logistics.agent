system:
    instructions: |
        You are a professional shipping logistics coordinator assistant.
        Help users manage their shipment_order requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: carrier_selection -> label_generation -> tracking_setup -> delivery_confirm.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Shipping Logistics Coordinator Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "shipping_logistics_agent_v90"
    default_agent_user: "shipping_logistics@example.com"
    agent_description: "Assists users with shipment_order management through the shipping logistics coordinator workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    shipment_order_record_id: mutable string
        description: "Record ID of the shipment_order"
    shipment_order_status: mutable string = ""
        description: "Current status of the shipment_order"
    shipment_order_tier: mutable string = "standard"
        description: "Tier classification for the shipment_order"
    shipment_order_category: mutable string = ""
        description: "Category of the shipment_order"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    carrier_selection_complete: mutable boolean = False
        description: "Whether the carrier_selection stage is complete"
    carrier_selection_result: mutable string = ""
        description: "Result from the carrier_selection stage"
    label_generation_complete: mutable boolean = False
        description: "Whether the label_generation stage is complete"
    label_generation_result: mutable string = ""
        description: "Result from the label_generation stage"
    tracking_setup_complete: mutable boolean = False
        description: "Whether the tracking_setup stage is complete"
    tracking_setup_result: mutable string = ""
        description: "Result from the tracking_setup stage"
    delivery_confirm_complete: mutable boolean = False
        description: "Whether the delivery_confirm stage is complete"
    delivery_confirm_result: mutable string = ""
        description: "Result from the delivery_confirm stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate shipment_order management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a shipping logistics coordinator assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current shipment_order status: {! @variables.shipment_order_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_carrier_selection} for carrier selection requests.
              Use {!@actions.go_to_label_generation} for label generation requests.
              Use {!@actions.go_to_tracking_setup} for tracking setup requests.
              Use {!@actions.go_to_delivery_confirm} for delivery confirm requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_carrier_selection: @utils.transition to @topic.carrier_selection
                description: "Transition to carrier selection topic."
            go_to_label_generation: @utils.transition to @topic.label_generation
                description: "Transition to label generation topic."
                available when @variables.is_verified == True
            go_to_tracking_setup: @utils.transition to @topic.tracking_setup
                description: "Transition to tracking setup topic."
                available when @variables.is_verified == True
            go_to_delivery_confirm: @utils.transition to @topic.delivery_confirm
                description: "Transition to delivery confirm topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic carrier_selection:
    description: "Handles the carrier selection stage of the shipment_order process"

    actions:
        process_carrier_selection_data:
            description: "Process carrier selection stage data for the shipment_order"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_CarrierSelection"

        validate_carrier_selection_info:
            description: "Validate carrier selection information for the shipment_order"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_CarrierSelection_Info"

        fetch_carrier_selection_details:
            description: "Fetch carrier selection details for the shipment_order"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_CarrierSelection_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_carrier_selection_info
                with record_ref=@variables.shipment_order_record_id
                with contact_ref=@variables.contact_email
                set @variables.shipment_order_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the carrier selection stage for the shipment_order.
              Current shipment_order status: {! @variables.shipment_order_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Carrier Selection result: {! @variables.carrier_selection_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.shipment_order_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_carrier_selection} to begin processing.
        actions:
            run_carrier_selection: @actions.process_carrier_selection_data
                with record_ref=@variables.shipment_order_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.shipment_order_category
                set @variables.carrier_selection_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.carrier_selection_complete = @outputs.is_passed
            fetch_carrier_selection_info: @actions.fetch_carrier_selection_details
                with record_ref=@variables.shipment_order_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.shipment_order_tier = @outputs.tier_value
            go_to_label_generation: @utils.transition to @topic.label_generation
                description: "Move to label generation stage."
                available when @variables.carrier_selection_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.shipment_order_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.shipment_order_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.shipment_order_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.carrier_selection_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic label_generation:
    description: "Handles the label generation stage of the shipment_order process"

    actions:
        process_label_generation_data:
            description: "Process label generation stage data for the shipment_order"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_LabelGeneration_Data"

        validate_label_generation_info:
            description: "Validate label generation information for the shipment_order"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_LabelGeneration_Info"

        fetch_label_generation_details:
            description: "Fetch label generation details for the shipment_order"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_LabelGeneration_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.carrier_selection_complete == False:
            transition to @topic.carrier_selection

    reasoning:
        instructions: ->
            | Handle the label generation stage for the shipment_order.
              Current shipment_order status: {! @variables.shipment_order_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Label Generation result: {! @variables.label_generation_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.shipment_order_tier }
              Review the label generation results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_label_generation: @actions.process_label_generation_data
                with record_ref=@variables.shipment_order_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.shipment_order_category
                set @variables.label_generation_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.label_generation_complete = @outputs.is_passed
            fetch_label_generation_info: @actions.fetch_label_generation_details
                with record_ref=@variables.shipment_order_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.shipment_order_tier = @outputs.tier_value
                available when @variables.shipment_order_record_id is not None
            go_to_tracking_setup: @utils.transition to @topic.tracking_setup
                description: "Move to tracking setup stage."
                available when @variables.label_generation_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.label_generation_complete == True:
            set @variables.shipment_order_status = "label_generation_done"
        if @variables.label_generation_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.tracking_setup
        if @variables.attempt_count >= 3 and @variables.label_generation_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic tracking_setup:
    description: "Handles the tracking setup stage of the shipment_order process"

    actions:
        process_tracking_setup_data:
            description: "Process tracking setup stage data for the shipment_order"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_TrackingSetup"

        validate_tracking_setup_info:
            description: "Validate tracking setup information for the shipment_order"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_TrackingSetup_Info"

        fetch_tracking_setup_details:
            description: "Fetch tracking setup details for the shipment_order"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_TrackingSetup_Details"

    before_reasoning:
        if @variables.tracking_setup_complete == False:
            run @actions.fetch_tracking_setup_details
                with record_ref=@variables.shipment_order_record_id
                with include_history=True
                set @variables.tracking_setup_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.shipment_order_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.shipment_order_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.shipment_order_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the tracking setup stage for the shipment_order.
              Current shipment_order status: {! @variables.shipment_order_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Tracking Setup result: {! @variables.tracking_setup_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.shipment_order_tier }
              Review the tracking setup results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_tracking_setup: @actions.process_tracking_setup_data
                with record_ref=@variables.shipment_order_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.shipment_order_category
                set @variables.tracking_setup_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.tracking_setup_complete = @outputs.is_passed
            fetch_tracking_setup_info: @actions.fetch_tracking_setup_details
                with record_ref=@variables.shipment_order_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.shipment_order_tier = @outputs.tier_value
                available when @variables.shipment_order_record_id is not None
            go_to_delivery_confirm: @utils.transition to @topic.delivery_confirm
                description: "Move to delivery confirm stage."
                available when @variables.tracking_setup_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.shipment_order_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.shipment_order_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.shipment_order_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.tracking_setup_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic delivery_confirm:
    description: "Handles the delivery confirm stage of the shipment_order process"

    actions:
        process_delivery_confirm_data:
            description: "Process delivery confirm stage data for the shipment_order"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_DeliveryConfirm"

        validate_delivery_confirm_info:
            description: "Validate delivery confirm information for the shipment_order"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_DeliveryConfirm_Info"

        fetch_delivery_confirm_details:
            description: "Fetch delivery confirm details for the shipment_order"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_DeliveryConfirm_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.tracking_setup_complete == False:
            transition to @topic.tracking_setup
        if @variables.eligibility_score >= 80:
            set @variables.shipment_order_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.shipment_order_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the delivery confirm stage for the shipment_order.
              Current shipment_order status: {! @variables.shipment_order_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Delivery Confirm result: {! @variables.delivery_confirm_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.shipment_order_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_delivery_confirm: @actions.process_delivery_confirm_data
                with record_ref=@variables.shipment_order_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.shipment_order_category
                set @variables.delivery_confirm_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.delivery_confirm_complete = @outputs.is_passed
            fetch_delivery_confirm_info: @actions.fetch_delivery_confirm_details
                with record_ref=@variables.shipment_order_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.shipment_order_tier = @outputs.tier_value
                available when @variables.shipment_order_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.delivery_confirm_complete == True:
            set @variables.shipment_order_status = "delivery_confirm_done"
        if @variables.attempt_count >= 3 and @variables.delivery_confirm_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for shipment_order issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the shipment_order issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the shipment_order interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the shipment_order request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Shipment Order status: {! @variables.shipment_order_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.shipment_order_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.shipment_order_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.shipment_order_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.shipment_order_status = "escalated"
        set @variables.escalation_requested = False

