system:
    instructions: "You are an agent connected via messaging."
    messages:
        welcome: "Welcome to our messaging channel."
        error: "Something went wrong."

config:
    developer_name: "EdgeConnCustom"
    default_agent_user: "custom_bot@example.com"
    agent_label: "Messaging Channel Agent"
    description: "Agent with messaging connection"

connection messaging:
    adaptive_response_allowed: False

start_agent main:
    description: "Handle requests from messaging channel"

    reasoning:
        instructions: ->
            | Help the user via the messaging channel.

        actions:
            escalate_to_human: @utils.escalate
                description: "Escalate to human agent"
