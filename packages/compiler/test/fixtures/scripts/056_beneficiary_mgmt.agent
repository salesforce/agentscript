system:
    instructions: |
        You are a professional beneficiary management agent assistant.
        Help users manage their beneficiary requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: registration -> verification -> update_processing -> notification.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Beneficiary Management Agent Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "beneficiary_mgmt_agent_v56"
    default_agent_user: "beneficiary_mgmt@example.com"
    agent_description: "Assists users with beneficiary management through the beneficiary management agent workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    beneficiary_record_id: mutable string
        description: "Record ID of the beneficiary"
    beneficiary_status: mutable string = ""
        description: "Current status of the beneficiary"
    beneficiary_tier: mutable string = "standard"
        description: "Tier classification for the beneficiary"
    beneficiary_category: mutable string = ""
        description: "Category of the beneficiary"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    registration_complete: mutable boolean = False
        description: "Whether the registration stage is complete"
    registration_result: mutable string = ""
        description: "Result from the registration stage"
    verification_complete: mutable boolean = False
        description: "Whether the verification stage is complete"
    verification_result: mutable string = ""
        description: "Result from the verification stage"
    update_processing_complete: mutable boolean = False
        description: "Whether the update_processing stage is complete"
    update_processing_result: mutable string = ""
        description: "Result from the update_processing stage"
    notification_complete: mutable boolean = False
        description: "Whether the notification stage is complete"
    notification_result: mutable string = ""
        description: "Result from the notification stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate beneficiary management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a beneficiary management agent assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current beneficiary status: {! @variables.beneficiary_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_registration} for registration requests.
              Use {!@actions.go_to_verification} for verification requests.
              Use {!@actions.go_to_update_processing} for update processing requests.
              Use {!@actions.go_to_notification} for notification requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_registration: @utils.transition to @topic.registration
                description: "Transition to registration topic."
            go_to_verification: @utils.transition to @topic.verification
                description: "Transition to verification topic."
                available when @variables.is_verified == True
            go_to_update_processing: @utils.transition to @topic.update_processing
                description: "Transition to update processing topic."
                available when @variables.is_verified == True
            go_to_notification: @utils.transition to @topic.notification
                description: "Transition to notification topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic registration:
    description: "Handles the registration stage of the beneficiary process"

    actions:
        process_registration_data:
            description: "Process registration stage data for the beneficiary"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_Registration"

        validate_registration_info:
            description: "Validate registration information for the beneficiary"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Registration_Info"

        fetch_registration_details:
            description: "Fetch registration details for the beneficiary"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Registration_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_registration_info
                with record_ref=@variables.beneficiary_record_id
                with contact_ref=@variables.contact_email
                set @variables.beneficiary_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the registration stage for the beneficiary.
              Current beneficiary status: {! @variables.beneficiary_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Registration result: {! @variables.registration_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.beneficiary_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_registration} to begin processing.
        actions:
            run_registration: @actions.process_registration_data
                with record_ref=@variables.beneficiary_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.beneficiary_category
                set @variables.registration_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.registration_complete = @outputs.is_passed
            fetch_registration_info: @actions.fetch_registration_details
                with record_ref=@variables.beneficiary_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.beneficiary_tier = @outputs.tier_value
            go_to_verification: @utils.transition to @topic.verification
                description: "Move to verification stage."
                available when @variables.registration_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.beneficiary_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.beneficiary_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.beneficiary_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.registration_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic verification:
    description: "Handles the verification stage of the beneficiary process"

    actions:
        process_verification_data:
            description: "Process verification stage data for the beneficiary"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_Verification"

        validate_verification_info:
            description: "Validate verification information for the beneficiary"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Verification_Info"

        fetch_verification_details:
            description: "Fetch verification details for the beneficiary"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Verification_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.registration_complete == False:
            transition to @topic.registration

    reasoning:
        instructions: ->
            | Handle the verification stage for the beneficiary.
              Current beneficiary status: {! @variables.beneficiary_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Verification result: {! @variables.verification_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.beneficiary_tier }
              Review the verification results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_verification: @actions.process_verification_data
                with record_ref=@variables.beneficiary_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.beneficiary_category
                set @variables.verification_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.verification_complete = @outputs.is_passed
            fetch_verification_info: @actions.fetch_verification_details
                with record_ref=@variables.beneficiary_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.beneficiary_tier = @outputs.tier_value
                available when @variables.beneficiary_record_id is not None
            go_to_update_processing: @utils.transition to @topic.update_processing
                description: "Move to update processing stage."
                available when @variables.verification_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.verification_complete == True:
            set @variables.beneficiary_status = "verification_done"
        if @variables.verification_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.update_processing
        if @variables.attempt_count >= 3 and @variables.verification_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic update_processing:
    description: "Handles the update processing stage of the beneficiary process"

    actions:
        process_update_processing_data:
            description: "Process update processing stage data for the beneficiary"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_UpdateProcessing_Data"

        validate_update_processing_info:
            description: "Validate update processing information for the beneficiary"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_UpdateProcessing_Info"

        fetch_update_processing_details:
            description: "Fetch update processing details for the beneficiary"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_UpdateProcessing_Details"

    before_reasoning:
        if @variables.update_processing_complete == False:
            run @actions.fetch_update_processing_details
                with record_ref=@variables.beneficiary_record_id
                with include_history=True
                set @variables.update_processing_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.beneficiary_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.beneficiary_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.beneficiary_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the update processing stage for the beneficiary.
              Current beneficiary status: {! @variables.beneficiary_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Update Processing result: {! @variables.update_processing_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.beneficiary_tier }
              Review the update processing results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_update_processing: @actions.process_update_processing_data
                with record_ref=@variables.beneficiary_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.beneficiary_category
                set @variables.update_processing_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.update_processing_complete = @outputs.is_passed
            fetch_update_processing_info: @actions.fetch_update_processing_details
                with record_ref=@variables.beneficiary_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.beneficiary_tier = @outputs.tier_value
                available when @variables.beneficiary_record_id is not None
            go_to_notification: @utils.transition to @topic.notification
                description: "Move to notification stage."
                available when @variables.update_processing_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.beneficiary_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.beneficiary_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.beneficiary_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.update_processing_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic notification:
    description: "Handles the notification stage of the beneficiary process"

    actions:
        process_notification_data:
            description: "Process notification stage data for the beneficiary"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_Notification"

        validate_notification_info:
            description: "Validate notification information for the beneficiary"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Notification_Info"

        fetch_notification_details:
            description: "Fetch notification details for the beneficiary"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Notification_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.update_processing_complete == False:
            transition to @topic.update_processing
        if @variables.eligibility_score >= 80:
            set @variables.beneficiary_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.beneficiary_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the notification stage for the beneficiary.
              Current beneficiary status: {! @variables.beneficiary_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Notification result: {! @variables.notification_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.beneficiary_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_notification: @actions.process_notification_data
                with record_ref=@variables.beneficiary_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.beneficiary_category
                set @variables.notification_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.notification_complete = @outputs.is_passed
            fetch_notification_info: @actions.fetch_notification_details
                with record_ref=@variables.beneficiary_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.beneficiary_tier = @outputs.tier_value
                available when @variables.beneficiary_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.notification_complete == True:
            set @variables.beneficiary_status = "notification_done"
        if @variables.attempt_count >= 3 and @variables.notification_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for beneficiary issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the beneficiary issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the beneficiary interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the beneficiary request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Beneficiary status: {! @variables.beneficiary_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.beneficiary_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.beneficiary_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.beneficiary_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.beneficiary_status = "escalated"
        set @variables.escalation_requested = False

