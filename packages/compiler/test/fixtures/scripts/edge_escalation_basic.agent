system:
    instructions: "You are a support assistant that can escalate to human agents."
    messages:
        welcome: "Hello! How can I help?"
        error: "An error occurred."

config:
    developer_name: "Edge_Escalation_Basic"
    default_agent_user: "test_user"
    description: "Tests basic @utils.escalate in reasoning actions"

start_agent main:
    description: "Main topic with escalation option"

    reasoning:
        instructions: ->
            | I'm here to help. If you need a human agent, I can transfer you.

        actions:
            escalate_to_human: @utils.escalate
                description: "Escalate to a human agent"

            go_to_faq: @utils.transition to @topic.faq

topic faq:
    description: "Frequently asked questions"

    reasoning:
        instructions: ->
            | Here are some common questions I can help with.
