# Agent with 20+ state variables
system:
    instructions: "You are a customer service agent with many state variables."

config:
    agent_name: "Many_Vars_Agent"
    agent_type: "AgentforceServiceAgent"
    developer_name: "Many_Vars_Agent"
    description: "Agent with many state variables"

variables:
    first_name: mutable string = ""
        description: "Customer first name"
    last_name: mutable string = ""
        description: "Customer last name"
    email: mutable string = ""
        description: "Customer email"
    phone: mutable string = ""
        description: "Customer phone number"
    account_id: mutable string = ""
        description: "Account identifier"
    case_id: mutable string = ""
        description: "Case identifier"
    order_id: mutable string = ""
        description: "Order identifier"
    product_name: mutable string = ""
        description: "Product name"
    category: mutable string = ""
        description: "Issue category"
    priority: mutable string = "Medium"
        description: "Issue priority"
    status: mutable string = "Open"
        description: "Case status"
    amount: mutable number = 0
        description: "Transaction amount"
    quantity: mutable number = 1
        description: "Item quantity"
    discount: mutable number = 0
        description: "Applied discount"
    is_vip: mutable boolean = False
        description: "VIP customer flag"
    is_resolved: mutable boolean = False
        description: "Resolution flag"
    is_escalated: mutable boolean = False
        description: "Escalation flag"
    notes: mutable string = ""
        description: "Agent notes"
    resolution: mutable string = ""
        description: "Resolution description"
    tags: mutable list[string] = None
        description: "Issue tags"
    history: mutable list[object] = None
        description: "Interaction history"
    metadata: mutable object = None
        description: "Additional metadata"

start_agent main:
    description: "Handle customer with many variables"
    reasoning:
        instructions: ->
            | Identify the customer and help them with their request
