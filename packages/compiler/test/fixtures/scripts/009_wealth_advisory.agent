system:
    instructions: |
        You are a professional wealth advisory agent assistant.
        Help users manage their wealth requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: goal_setting -> risk_profiling -> strategy_design -> monitoring.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Wealth Advisory Agent Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "wealth_advisory_agent_v9"
    default_agent_user: "wealth_advisory@example.com"
    agent_description: "Assists users with wealth management through the wealth advisory agent workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    wealth_record_id: mutable string
        description: "Record ID of the wealth"
    wealth_status: mutable string = ""
        description: "Current status of the wealth"
    wealth_tier: mutable string = "standard"
        description: "Tier classification for the wealth"
    wealth_category: mutable string = ""
        description: "Category of the wealth"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    goal_setting_complete: mutable boolean = False
        description: "Whether the goal_setting stage is complete"
    goal_setting_result: mutable string = ""
        description: "Result from the goal_setting stage"
    risk_profiling_complete: mutable boolean = False
        description: "Whether the risk_profiling stage is complete"
    risk_profiling_result: mutable string = ""
        description: "Result from the risk_profiling stage"
    strategy_design_complete: mutable boolean = False
        description: "Whether the strategy_design stage is complete"
    strategy_design_result: mutable string = ""
        description: "Result from the strategy_design stage"
    monitoring_complete: mutable boolean = False
        description: "Whether the monitoring stage is complete"
    monitoring_result: mutable string = ""
        description: "Result from the monitoring stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate wealth management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a wealth advisory agent assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current wealth status: {! @variables.wealth_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_goal_setting} for goal setting requests.
              Use {!@actions.go_to_risk_profiling} for risk profiling requests.
              Use {!@actions.go_to_strategy_design} for strategy design requests.
              Use {!@actions.go_to_monitoring} for monitoring requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_goal_setting: @utils.transition to @topic.goal_setting
                description: "Transition to goal setting topic."
            go_to_risk_profiling: @utils.transition to @topic.risk_profiling
                description: "Transition to risk profiling topic."
                available when @variables.is_verified == True
            go_to_strategy_design: @utils.transition to @topic.strategy_design
                description: "Transition to strategy design topic."
                available when @variables.is_verified == True
            go_to_monitoring: @utils.transition to @topic.monitoring
                description: "Transition to monitoring topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic goal_setting:
    description: "Handles the goal setting stage of the wealth process"

    actions:
        process_goal_setting_data:
            description: "Process goal setting stage data for the wealth"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_GoalSetting"

        validate_goal_setting_info:
            description: "Validate goal setting information for the wealth"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_GoalSetting_Info"

        fetch_goal_setting_details:
            description: "Fetch goal setting details for the wealth"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_GoalSetting_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_goal_setting_info
                with record_ref=@variables.wealth_record_id
                with contact_ref=@variables.contact_email
                set @variables.wealth_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the goal setting stage for the wealth.
              Current wealth status: {! @variables.wealth_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Goal Setting result: {! @variables.goal_setting_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.wealth_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_goal_setting} to begin processing.
        actions:
            run_goal_setting: @actions.process_goal_setting_data
                with record_ref=@variables.wealth_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.wealth_category
                set @variables.goal_setting_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.goal_setting_complete = @outputs.is_passed
            fetch_goal_setting_info: @actions.fetch_goal_setting_details
                with record_ref=@variables.wealth_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.wealth_tier = @outputs.tier_value
            go_to_risk_profiling: @utils.transition to @topic.risk_profiling
                description: "Move to risk profiling stage."
                available when @variables.goal_setting_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.wealth_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.wealth_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.wealth_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.goal_setting_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic risk_profiling:
    description: "Handles the risk profiling stage of the wealth process"

    actions:
        process_risk_profiling_data:
            description: "Process risk profiling stage data for the wealth"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_RiskProfiling_Data"

        validate_risk_profiling_info:
            description: "Validate risk profiling information for the wealth"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_RiskProfiling_Info"

        fetch_risk_profiling_details:
            description: "Fetch risk profiling details for the wealth"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_RiskProfiling_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.goal_setting_complete == False:
            transition to @topic.goal_setting

    reasoning:
        instructions: ->
            | Handle the risk profiling stage for the wealth.
              Current wealth status: {! @variables.wealth_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Risk Profiling result: {! @variables.risk_profiling_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.wealth_tier }
              Review the risk profiling results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_risk_profiling: @actions.process_risk_profiling_data
                with record_ref=@variables.wealth_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.wealth_category
                set @variables.risk_profiling_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.risk_profiling_complete = @outputs.is_passed
            fetch_risk_profiling_info: @actions.fetch_risk_profiling_details
                with record_ref=@variables.wealth_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.wealth_tier = @outputs.tier_value
                available when @variables.wealth_record_id is not None
            go_to_strategy_design: @utils.transition to @topic.strategy_design
                description: "Move to strategy design stage."
                available when @variables.risk_profiling_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.risk_profiling_complete == True:
            set @variables.wealth_status = "risk_profiling_done"
        if @variables.risk_profiling_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.strategy_design
        if @variables.attempt_count >= 3 and @variables.risk_profiling_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic strategy_design:
    description: "Handles the strategy design stage of the wealth process"

    actions:
        process_strategy_design_data:
            description: "Process strategy design stage data for the wealth"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_StrategyDesign"

        validate_strategy_design_info:
            description: "Validate strategy design information for the wealth"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_StrategyDesign_Info"

        fetch_strategy_design_details:
            description: "Fetch strategy design details for the wealth"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_StrategyDesign_Details"

    before_reasoning:
        if @variables.strategy_design_complete == False:
            run @actions.fetch_strategy_design_details
                with record_ref=@variables.wealth_record_id
                with include_history=True
                set @variables.strategy_design_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.wealth_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.wealth_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.wealth_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the strategy design stage for the wealth.
              Current wealth status: {! @variables.wealth_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Strategy Design result: {! @variables.strategy_design_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.wealth_tier }
              Review the strategy design results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_strategy_design: @actions.process_strategy_design_data
                with record_ref=@variables.wealth_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.wealth_category
                set @variables.strategy_design_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.strategy_design_complete = @outputs.is_passed
            fetch_strategy_design_info: @actions.fetch_strategy_design_details
                with record_ref=@variables.wealth_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.wealth_tier = @outputs.tier_value
                available when @variables.wealth_record_id is not None
            go_to_monitoring: @utils.transition to @topic.monitoring
                description: "Move to monitoring stage."
                available when @variables.strategy_design_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.wealth_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.wealth_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.wealth_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.strategy_design_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic monitoring:
    description: "Handles the monitoring stage of the wealth process"

    actions:
        process_monitoring_data:
            description: "Process monitoring stage data for the wealth"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_Monitoring"

        validate_monitoring_info:
            description: "Validate monitoring information for the wealth"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Monitoring_Info"

        fetch_monitoring_details:
            description: "Fetch monitoring details for the wealth"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Monitoring_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.strategy_design_complete == False:
            transition to @topic.strategy_design
        if @variables.eligibility_score >= 80:
            set @variables.wealth_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.wealth_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the monitoring stage for the wealth.
              Current wealth status: {! @variables.wealth_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Monitoring result: {! @variables.monitoring_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.wealth_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_monitoring: @actions.process_monitoring_data
                with record_ref=@variables.wealth_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.wealth_category
                set @variables.monitoring_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.monitoring_complete = @outputs.is_passed
            fetch_monitoring_info: @actions.fetch_monitoring_details
                with record_ref=@variables.wealth_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.wealth_tier = @outputs.tier_value
                available when @variables.wealth_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.monitoring_complete == True:
            set @variables.wealth_status = "monitoring_done"
        if @variables.attempt_count >= 3 and @variables.monitoring_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for wealth issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the wealth issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the wealth interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the wealth request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Wealth status: {! @variables.wealth_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.wealth_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.wealth_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.wealth_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.wealth_status = "escalated"
        set @variables.escalation_requested = False

