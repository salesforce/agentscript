system:
    instructions: "You are a Slack-based support agent."
    messages:
        welcome: "Hello! I'm here to help in Slack."
        error: "Something went wrong."

config:
    developer_name: "EdgeConnSlack"
    default_agent_user: "slack_bot@example.com"
    agent_label: "Slack Agent"
    description: "Agent with Slack connection"

connection slack:
    adaptive_response_allowed: True

start_agent main:
    description: "Handle Slack-based support requests"

    reasoning:
        instructions: ->
            | Help the user with their request via Slack.

        actions:
            escalate_to_human: @utils.escalate
                description: "Escalate to human agent"
