system:
    instructions: |
        You are a professional policy underwriting specialist assistant.
        Help users manage their policy requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: application_review -> risk_scoring -> premium_calculation -> decision.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Policy Underwriting Specialist Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "policy_underwriting_agent_v51"
    default_agent_user: "policy_underwriting@example.com"
    agent_description: "Assists users with policy management through the policy underwriting specialist workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    policy_record_id: mutable string
        description: "Record ID of the policy"
    policy_status: mutable string = ""
        description: "Current status of the policy"
    policy_tier: mutable string = "standard"
        description: "Tier classification for the policy"
    policy_category: mutable string = ""
        description: "Category of the policy"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    application_review_complete: mutable boolean = False
        description: "Whether the application_review stage is complete"
    application_review_result: mutable string = ""
        description: "Result from the application_review stage"
    risk_scoring_complete: mutable boolean = False
        description: "Whether the risk_scoring stage is complete"
    risk_scoring_result: mutable string = ""
        description: "Result from the risk_scoring stage"
    premium_calculation_complete: mutable boolean = False
        description: "Whether the premium_calculation stage is complete"
    premium_calculation_result: mutable string = ""
        description: "Result from the premium_calculation stage"
    decision_complete: mutable boolean = False
        description: "Whether the decision stage is complete"
    decision_result: mutable string = ""
        description: "Result from the decision stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate policy management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a policy underwriting specialist assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current policy status: {! @variables.policy_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_application_review} for application review requests.
              Use {!@actions.go_to_risk_scoring} for risk scoring requests.
              Use {!@actions.go_to_premium_calculation} for premium calculation requests.
              Use {!@actions.go_to_decision} for decision requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_application_review: @utils.transition to @topic.application_review
                description: "Transition to application review topic."
            go_to_risk_scoring: @utils.transition to @topic.risk_scoring
                description: "Transition to risk scoring topic."
                available when @variables.is_verified == True
            go_to_premium_calculation: @utils.transition to @topic.premium_calculation
                description: "Transition to premium calculation topic."
                available when @variables.is_verified == True
            go_to_decision: @utils.transition to @topic.decision
                description: "Transition to decision topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic application_review:
    description: "Handles the application review stage of the policy process"

    actions:
        process_application_review_data:
            description: "Process application review stage data for the policy"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_ApplicationReview"

        validate_application_review_info:
            description: "Validate application review information for the policy"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_ApplicationReview_Info"

        fetch_application_review_details:
            description: "Fetch application review details for the policy"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_ApplicationReview_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_application_review_info
                with record_ref=@variables.policy_record_id
                with contact_ref=@variables.contact_email
                set @variables.policy_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the application review stage for the policy.
              Current policy status: {! @variables.policy_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Application Review result: {! @variables.application_review_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.policy_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_application_review} to begin processing.
        actions:
            run_application_review: @actions.process_application_review_data
                with record_ref=@variables.policy_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.policy_category
                set @variables.application_review_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.application_review_complete = @outputs.is_passed
            fetch_application_review_info: @actions.fetch_application_review_details
                with record_ref=@variables.policy_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.policy_tier = @outputs.tier_value
            go_to_risk_scoring: @utils.transition to @topic.risk_scoring
                description: "Move to risk scoring stage."
                available when @variables.application_review_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.policy_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.policy_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.policy_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.application_review_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic risk_scoring:
    description: "Handles the risk scoring stage of the policy process"

    actions:
        process_risk_scoring_data:
            description: "Process risk scoring stage data for the policy"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_RiskScoring_Data"

        validate_risk_scoring_info:
            description: "Validate risk scoring information for the policy"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_RiskScoring_Info"

        fetch_risk_scoring_details:
            description: "Fetch risk scoring details for the policy"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_RiskScoring_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.application_review_complete == False:
            transition to @topic.application_review

    reasoning:
        instructions: ->
            | Handle the risk scoring stage for the policy.
              Current policy status: {! @variables.policy_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Risk Scoring result: {! @variables.risk_scoring_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.policy_tier }
              Review the risk scoring results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_risk_scoring: @actions.process_risk_scoring_data
                with record_ref=@variables.policy_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.policy_category
                set @variables.risk_scoring_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.risk_scoring_complete = @outputs.is_passed
            fetch_risk_scoring_info: @actions.fetch_risk_scoring_details
                with record_ref=@variables.policy_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.policy_tier = @outputs.tier_value
                available when @variables.policy_record_id is not None
            go_to_premium_calculation: @utils.transition to @topic.premium_calculation
                description: "Move to premium calculation stage."
                available when @variables.risk_scoring_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.risk_scoring_complete == True:
            set @variables.policy_status = "risk_scoring_done"
        if @variables.risk_scoring_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.premium_calculation
        if @variables.attempt_count >= 3 and @variables.risk_scoring_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic premium_calculation:
    description: "Handles the premium calculation stage of the policy process"

    actions:
        process_premium_calculation_data:
            description: "Process premium calculation stage data for the policy"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_PremiumCalculation"

        validate_premium_calculation_info:
            description: "Validate premium calculation information for the policy"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_PremiumCalculation_Info"

        fetch_premium_calculation_details:
            description: "Fetch premium calculation details for the policy"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_PremiumCalculation_Details"

    before_reasoning:
        if @variables.premium_calculation_complete == False:
            run @actions.fetch_premium_calculation_details
                with record_ref=@variables.policy_record_id
                with include_history=True
                set @variables.premium_calculation_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.policy_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.policy_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.policy_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the premium calculation stage for the policy.
              Current policy status: {! @variables.policy_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Premium Calculation result: {! @variables.premium_calculation_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.policy_tier }
              Review the premium calculation results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_premium_calculation: @actions.process_premium_calculation_data
                with record_ref=@variables.policy_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.policy_category
                set @variables.premium_calculation_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.premium_calculation_complete = @outputs.is_passed
            fetch_premium_calculation_info: @actions.fetch_premium_calculation_details
                with record_ref=@variables.policy_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.policy_tier = @outputs.tier_value
                available when @variables.policy_record_id is not None
            go_to_decision: @utils.transition to @topic.decision
                description: "Move to decision stage."
                available when @variables.premium_calculation_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.policy_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.policy_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.policy_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.premium_calculation_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic decision:
    description: "Handles the decision stage of the policy process"

    actions:
        process_decision_data:
            description: "Process decision stage data for the policy"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_Decision"

        validate_decision_info:
            description: "Validate decision information for the policy"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Decision_Info"

        fetch_decision_details:
            description: "Fetch decision details for the policy"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Decision_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.premium_calculation_complete == False:
            transition to @topic.premium_calculation
        if @variables.eligibility_score >= 80:
            set @variables.policy_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.policy_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the decision stage for the policy.
              Current policy status: {! @variables.policy_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Decision result: {! @variables.decision_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.policy_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_decision: @actions.process_decision_data
                with record_ref=@variables.policy_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.policy_category
                set @variables.decision_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.decision_complete = @outputs.is_passed
            fetch_decision_info: @actions.fetch_decision_details
                with record_ref=@variables.policy_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.policy_tier = @outputs.tier_value
                available when @variables.policy_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.decision_complete == True:
            set @variables.policy_status = "decision_done"
        if @variables.attempt_count >= 3 and @variables.decision_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for policy issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the policy issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the policy interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the policy request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Policy status: {! @variables.policy_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.policy_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.policy_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.policy_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.policy_status = "escalated"
        set @variables.escalation_requested = False

