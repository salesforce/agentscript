config:
    agent_name: "ConstantValuesLiterals"

start_agent main:
    description: "Test literal constant values (not @knowledge references)"

    actions:
        test_action:
            description: "Action with literal constant values"
            inputs:
                str_const: string = "literal_string"
                bool_true: boolean = True
                bool_false: boolean = False
                empty_str: string = ""
                no_default: string
            outputs:
                result: string
            target: "flow://TestAction"

    reasoning:
        instructions: ->
            | Test literal constant values
        actions:
            run_test: @actions.test_action
