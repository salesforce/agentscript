# Every default value pattern
system:
    instructions: "You are an agent for testing every default value pattern."

config:
    agent_name: "Default_Vals_Agent"
    agent_type: "AgentforceServiceAgent"
    developer_name: "Default_Vals_Agent"
    description: "Agent with every default value pattern"

variables:
    empty_str: mutable string = ""
        description: "Empty string default"
    zero_num: mutable number = 0
        description: "Zero default"
    false_bool: mutable boolean = False
        description: "False default"
    none_obj: mutable object = None
        description: "None default"
    text_str: mutable string = "some text value"
        description: "Text string default"
    positive_num: mutable number = 42
        description: "Positive number default"
    true_bool: mutable boolean = True
        description: "True default"
    negative_num: mutable number = -1
        description: "Negative number default"
    decimal_num: mutable number = 3.14
        description: "Decimal number default"

start_agent main:
    description: "Test default values"
    reasoning:
        instructions: ->
            | Check default values for all variable types
