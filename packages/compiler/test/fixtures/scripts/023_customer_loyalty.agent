system:
    instructions: |
        You are a professional customer loyalty manager assistant.
        Help users manage their loyalty requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: enrollment -> point_tracking -> reward_redemption -> tier_evaluation.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Customer Loyalty Manager Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "customer_loyalty_agent_v23"
    default_agent_user: "customer_loyalty@example.com"
    agent_description: "Assists users with loyalty management through the customer loyalty manager workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    loyalty_record_id: mutable string
        description: "Record ID of the loyalty"
    loyalty_status: mutable string = ""
        description: "Current status of the loyalty"
    loyalty_tier: mutable string = "standard"
        description: "Tier classification for the loyalty"
    loyalty_category: mutable string = ""
        description: "Category of the loyalty"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    enrollment_complete: mutable boolean = False
        description: "Whether the enrollment stage is complete"
    enrollment_result: mutable string = ""
        description: "Result from the enrollment stage"
    point_tracking_complete: mutable boolean = False
        description: "Whether the point_tracking stage is complete"
    point_tracking_result: mutable string = ""
        description: "Result from the point_tracking stage"
    reward_redemption_complete: mutable boolean = False
        description: "Whether the reward_redemption stage is complete"
    reward_redemption_result: mutable string = ""
        description: "Result from the reward_redemption stage"
    tier_evaluation_complete: mutable boolean = False
        description: "Whether the tier_evaluation stage is complete"
    tier_evaluation_result: mutable string = ""
        description: "Result from the tier_evaluation stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate loyalty management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a customer loyalty manager assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current loyalty status: {! @variables.loyalty_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_enrollment} for enrollment requests.
              Use {!@actions.go_to_point_tracking} for point tracking requests.
              Use {!@actions.go_to_reward_redemption} for reward redemption requests.
              Use {!@actions.go_to_tier_evaluation} for tier evaluation requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_enrollment: @utils.transition to @topic.enrollment
                description: "Transition to enrollment topic."
            go_to_point_tracking: @utils.transition to @topic.point_tracking
                description: "Transition to point tracking topic."
                available when @variables.is_verified == True
            go_to_reward_redemption: @utils.transition to @topic.reward_redemption
                description: "Transition to reward redemption topic."
                available when @variables.is_verified == True
            go_to_tier_evaluation: @utils.transition to @topic.tier_evaluation
                description: "Transition to tier evaluation topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic enrollment:
    description: "Handles the enrollment stage of the loyalty process"

    actions:
        process_enrollment_data:
            description: "Process enrollment stage data for the loyalty"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_Enrollment"

        validate_enrollment_info:
            description: "Validate enrollment information for the loyalty"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Enrollment_Info"

        fetch_enrollment_details:
            description: "Fetch enrollment details for the loyalty"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Enrollment_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_enrollment_info
                with record_ref=@variables.loyalty_record_id
                with contact_ref=@variables.contact_email
                set @variables.loyalty_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the enrollment stage for the loyalty.
              Current loyalty status: {! @variables.loyalty_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Enrollment result: {! @variables.enrollment_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.loyalty_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_enrollment} to begin processing.
        actions:
            run_enrollment: @actions.process_enrollment_data
                with record_ref=@variables.loyalty_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.loyalty_category
                set @variables.enrollment_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.enrollment_complete = @outputs.is_passed
            fetch_enrollment_info: @actions.fetch_enrollment_details
                with record_ref=@variables.loyalty_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.loyalty_tier = @outputs.tier_value
            go_to_point_tracking: @utils.transition to @topic.point_tracking
                description: "Move to point tracking stage."
                available when @variables.enrollment_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.loyalty_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.loyalty_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.loyalty_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.enrollment_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic point_tracking:
    description: "Handles the point tracking stage of the loyalty process"

    actions:
        process_point_tracking_data:
            description: "Process point tracking stage data for the loyalty"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_PointTracking"

        validate_point_tracking_info:
            description: "Validate point tracking information for the loyalty"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_PointTracking_Info"

        fetch_point_tracking_details:
            description: "Fetch point tracking details for the loyalty"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_PointTracking_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.enrollment_complete == False:
            transition to @topic.enrollment

    reasoning:
        instructions: ->
            | Handle the point tracking stage for the loyalty.
              Current loyalty status: {! @variables.loyalty_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Point Tracking result: {! @variables.point_tracking_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.loyalty_tier }
              Review the point tracking results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_point_tracking: @actions.process_point_tracking_data
                with record_ref=@variables.loyalty_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.loyalty_category
                set @variables.point_tracking_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.point_tracking_complete = @outputs.is_passed
            fetch_point_tracking_info: @actions.fetch_point_tracking_details
                with record_ref=@variables.loyalty_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.loyalty_tier = @outputs.tier_value
                available when @variables.loyalty_record_id is not None
            go_to_reward_redemption: @utils.transition to @topic.reward_redemption
                description: "Move to reward redemption stage."
                available when @variables.point_tracking_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.point_tracking_complete == True:
            set @variables.loyalty_status = "point_tracking_done"
        if @variables.point_tracking_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.reward_redemption
        if @variables.attempt_count >= 3 and @variables.point_tracking_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic reward_redemption:
    description: "Handles the reward redemption stage of the loyalty process"

    actions:
        process_reward_redemption_data:
            description: "Process reward redemption stage data for the loyalty"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_RewardRedemption_Data"

        validate_reward_redemption_info:
            description: "Validate reward redemption information for the loyalty"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_RewardRedemption_Info"

        fetch_reward_redemption_details:
            description: "Fetch reward redemption details for the loyalty"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_RewardRedemption_Details"

    before_reasoning:
        if @variables.reward_redemption_complete == False:
            run @actions.fetch_reward_redemption_details
                with record_ref=@variables.loyalty_record_id
                with include_history=True
                set @variables.reward_redemption_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.loyalty_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.loyalty_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.loyalty_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the reward redemption stage for the loyalty.
              Current loyalty status: {! @variables.loyalty_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Reward Redemption result: {! @variables.reward_redemption_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.loyalty_tier }
              Review the reward redemption results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_reward_redemption: @actions.process_reward_redemption_data
                with record_ref=@variables.loyalty_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.loyalty_category
                set @variables.reward_redemption_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.reward_redemption_complete = @outputs.is_passed
            fetch_reward_redemption_info: @actions.fetch_reward_redemption_details
                with record_ref=@variables.loyalty_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.loyalty_tier = @outputs.tier_value
                available when @variables.loyalty_record_id is not None
            go_to_tier_evaluation: @utils.transition to @topic.tier_evaluation
                description: "Move to tier evaluation stage."
                available when @variables.reward_redemption_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.loyalty_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.loyalty_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.loyalty_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.reward_redemption_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic tier_evaluation:
    description: "Handles the tier evaluation stage of the loyalty process"

    actions:
        process_tier_evaluation_data:
            description: "Process tier evaluation stage data for the loyalty"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_TierEvaluation"

        validate_tier_evaluation_info:
            description: "Validate tier evaluation information for the loyalty"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_TierEvaluation_Info"

        fetch_tier_evaluation_details:
            description: "Fetch tier evaluation details for the loyalty"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_TierEvaluation_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.reward_redemption_complete == False:
            transition to @topic.reward_redemption
        if @variables.eligibility_score >= 80:
            set @variables.loyalty_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.loyalty_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the tier evaluation stage for the loyalty.
              Current loyalty status: {! @variables.loyalty_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Tier Evaluation result: {! @variables.tier_evaluation_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.loyalty_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_tier_evaluation: @actions.process_tier_evaluation_data
                with record_ref=@variables.loyalty_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.loyalty_category
                set @variables.tier_evaluation_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.tier_evaluation_complete = @outputs.is_passed
            fetch_tier_evaluation_info: @actions.fetch_tier_evaluation_details
                with record_ref=@variables.loyalty_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.loyalty_tier = @outputs.tier_value
                available when @variables.loyalty_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.tier_evaluation_complete == True:
            set @variables.loyalty_status = "tier_evaluation_done"
        if @variables.attempt_count >= 3 and @variables.tier_evaluation_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for loyalty issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the loyalty issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the loyalty interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the loyalty request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Loyalty status: {! @variables.loyalty_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.loyalty_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.loyalty_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.loyalty_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.loyalty_status = "escalated"
        set @variables.escalation_requested = False

