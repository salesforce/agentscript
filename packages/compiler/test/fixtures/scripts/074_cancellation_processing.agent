system:
    instructions: |
        You are a professional cancellation processing agent assistant.
        Help users manage their cancellation requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: request_review -> policy_check -> refund_calculation -> confirmation.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Cancellation Processing Agent Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "cancellation_processing_agent_v74"
    default_agent_user: "cancellation_processing@example.com"
    agent_description: "Assists users with cancellation management through the cancellation processing agent workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    cancellation_record_id: mutable string
        description: "Record ID of the cancellation"
    cancellation_status: mutable string = ""
        description: "Current status of the cancellation"
    cancellation_tier: mutable string = "standard"
        description: "Tier classification for the cancellation"
    cancellation_category: mutable string = ""
        description: "Category of the cancellation"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    request_review_complete: mutable boolean = False
        description: "Whether the request_review stage is complete"
    request_review_result: mutable string = ""
        description: "Result from the request_review stage"
    policy_check_complete: mutable boolean = False
        description: "Whether the policy_check stage is complete"
    policy_check_result: mutable string = ""
        description: "Result from the policy_check stage"
    refund_calculation_complete: mutable boolean = False
        description: "Whether the refund_calculation stage is complete"
    refund_calculation_result: mutable string = ""
        description: "Result from the refund_calculation stage"
    confirmation_complete: mutable boolean = False
        description: "Whether the confirmation stage is complete"
    confirmation_result: mutable string = ""
        description: "Result from the confirmation stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate cancellation management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a cancellation processing agent assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current cancellation status: {! @variables.cancellation_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_request_review} for request review requests.
              Use {!@actions.go_to_policy_check} for policy check requests.
              Use {!@actions.go_to_refund_calculation} for refund calculation requests.
              Use {!@actions.go_to_confirmation} for confirmation requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_request_review: @utils.transition to @topic.request_review
                description: "Transition to request review topic."
            go_to_policy_check: @utils.transition to @topic.policy_check
                description: "Transition to policy check topic."
                available when @variables.is_verified == True
            go_to_refund_calculation: @utils.transition to @topic.refund_calculation
                description: "Transition to refund calculation topic."
                available when @variables.is_verified == True
            go_to_confirmation: @utils.transition to @topic.confirmation
                description: "Transition to confirmation topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic request_review:
    description: "Handles the request review stage of the cancellation process"

    actions:
        process_request_review_data:
            description: "Process request review stage data for the cancellation"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_RequestReview"

        validate_request_review_info:
            description: "Validate request review information for the cancellation"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_RequestReview_Info"

        fetch_request_review_details:
            description: "Fetch request review details for the cancellation"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_RequestReview_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_request_review_info
                with record_ref=@variables.cancellation_record_id
                with contact_ref=@variables.contact_email
                set @variables.cancellation_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the request review stage for the cancellation.
              Current cancellation status: {! @variables.cancellation_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Request Review result: {! @variables.request_review_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.cancellation_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_request_review} to begin processing.
        actions:
            run_request_review: @actions.process_request_review_data
                with record_ref=@variables.cancellation_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.cancellation_category
                set @variables.request_review_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.request_review_complete = @outputs.is_passed
            fetch_request_review_info: @actions.fetch_request_review_details
                with record_ref=@variables.cancellation_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.cancellation_tier = @outputs.tier_value
            go_to_policy_check: @utils.transition to @topic.policy_check
                description: "Move to policy check stage."
                available when @variables.request_review_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.cancellation_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.cancellation_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.cancellation_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.request_review_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic policy_check:
    description: "Handles the policy check stage of the cancellation process"

    actions:
        process_policy_check_data:
            description: "Process policy check stage data for the cancellation"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_PolicyCheck"

        validate_policy_check_info:
            description: "Validate policy check information for the cancellation"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_PolicyCheck_Info"

        fetch_policy_check_details:
            description: "Fetch policy check details for the cancellation"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_PolicyCheck_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.request_review_complete == False:
            transition to @topic.request_review

    reasoning:
        instructions: ->
            | Handle the policy check stage for the cancellation.
              Current cancellation status: {! @variables.cancellation_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Policy Check result: {! @variables.policy_check_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.cancellation_tier }
              Review the policy check results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_policy_check: @actions.process_policy_check_data
                with record_ref=@variables.cancellation_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.cancellation_category
                set @variables.policy_check_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.policy_check_complete = @outputs.is_passed
            fetch_policy_check_info: @actions.fetch_policy_check_details
                with record_ref=@variables.cancellation_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.cancellation_tier = @outputs.tier_value
                available when @variables.cancellation_record_id is not None
            go_to_refund_calculation: @utils.transition to @topic.refund_calculation
                description: "Move to refund calculation stage."
                available when @variables.policy_check_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.policy_check_complete == True:
            set @variables.cancellation_status = "policy_check_done"
        if @variables.policy_check_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.refund_calculation
        if @variables.attempt_count >= 3 and @variables.policy_check_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic refund_calculation:
    description: "Handles the refund calculation stage of the cancellation process"

    actions:
        process_refund_calculation_data:
            description: "Process refund calculation stage data for the cancellation"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_RefundCalculation_Data"

        validate_refund_calculation_info:
            description: "Validate refund calculation information for the cancellation"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_RefundCalculation_Info"

        fetch_refund_calculation_details:
            description: "Fetch refund calculation details for the cancellation"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_RefundCalculation_Details"

    before_reasoning:
        if @variables.refund_calculation_complete == False:
            run @actions.fetch_refund_calculation_details
                with record_ref=@variables.cancellation_record_id
                with include_history=True
                set @variables.refund_calculation_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.cancellation_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.cancellation_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.cancellation_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the refund calculation stage for the cancellation.
              Current cancellation status: {! @variables.cancellation_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Refund Calculation result: {! @variables.refund_calculation_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.cancellation_tier }
              Review the refund calculation results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_refund_calculation: @actions.process_refund_calculation_data
                with record_ref=@variables.cancellation_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.cancellation_category
                set @variables.refund_calculation_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.refund_calculation_complete = @outputs.is_passed
            fetch_refund_calculation_info: @actions.fetch_refund_calculation_details
                with record_ref=@variables.cancellation_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.cancellation_tier = @outputs.tier_value
                available when @variables.cancellation_record_id is not None
            go_to_confirmation: @utils.transition to @topic.confirmation
                description: "Move to confirmation stage."
                available when @variables.refund_calculation_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.cancellation_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.cancellation_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.cancellation_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.refund_calculation_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic confirmation:
    description: "Handles the confirmation stage of the cancellation process"

    actions:
        process_confirmation_data:
            description: "Process confirmation stage data for the cancellation"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_Confirmation"

        validate_confirmation_info:
            description: "Validate confirmation information for the cancellation"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Confirmation_Info"

        fetch_confirmation_details:
            description: "Fetch confirmation details for the cancellation"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Confirmation_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.refund_calculation_complete == False:
            transition to @topic.refund_calculation
        if @variables.eligibility_score >= 80:
            set @variables.cancellation_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.cancellation_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the confirmation stage for the cancellation.
              Current cancellation status: {! @variables.cancellation_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Confirmation result: {! @variables.confirmation_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.cancellation_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_confirmation: @actions.process_confirmation_data
                with record_ref=@variables.cancellation_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.cancellation_category
                set @variables.confirmation_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.confirmation_complete = @outputs.is_passed
            fetch_confirmation_info: @actions.fetch_confirmation_details
                with record_ref=@variables.cancellation_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.cancellation_tier = @outputs.tier_value
                available when @variables.cancellation_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.confirmation_complete == True:
            set @variables.cancellation_status = "confirmation_done"
        if @variables.attempt_count >= 3 and @variables.confirmation_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for cancellation issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the cancellation issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the cancellation interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the cancellation request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Cancellation status: {! @variables.cancellation_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.cancellation_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.cancellation_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.cancellation_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.cancellation_status = "escalated"
        set @variables.escalation_requested = False

