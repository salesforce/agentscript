system:
    instructions: "You are a knowledge assistant with full citation support."
    messages:
        welcome: "Hello! I can search and cite sources for you."
        error: "An error occurred."

config:
    developer_name: "Edge_Knowledge_Citations"
    default_agent_user: "test_user"
    description: "Tests knowledge block with citations_url and rag_feature_config_id"

knowledge:
    citations_enabled: True
    citations_url: "https://example.com/knowledge-base"
    rag_feature_config_id: "kb_config_001"

start_agent main:
    description: "Agent with full knowledge citation configuration"

    reasoning:
        instructions: ->
            | I can search our knowledge base and provide cited answers.
              What information are you looking for?
