system:
    instructions: |
        You are a professional discharge planning specialist assistant.
        Help users manage their discharge requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: readiness_assessment -> care_coordination -> documentation -> followup_scheduling.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Discharge Planning Specialist Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "discharge_planning_agent_v17"
    default_agent_user: "discharge_planning@example.com"
    agent_description: "Assists users with discharge management through the discharge planning specialist workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    discharge_record_id: mutable string
        description: "Record ID of the discharge"
    discharge_status: mutable string = ""
        description: "Current status of the discharge"
    discharge_tier: mutable string = "standard"
        description: "Tier classification for the discharge"
    discharge_category: mutable string = ""
        description: "Category of the discharge"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    readiness_assessment_complete: mutable boolean = False
        description: "Whether the readiness_assessment stage is complete"
    readiness_assessment_result: mutable string = ""
        description: "Result from the readiness_assessment stage"
    care_coordination_complete: mutable boolean = False
        description: "Whether the care_coordination stage is complete"
    care_coordination_result: mutable string = ""
        description: "Result from the care_coordination stage"
    documentation_complete: mutable boolean = False
        description: "Whether the documentation stage is complete"
    documentation_result: mutable string = ""
        description: "Result from the documentation stage"
    followup_scheduling_complete: mutable boolean = False
        description: "Whether the followup_scheduling stage is complete"
    followup_scheduling_result: mutable string = ""
        description: "Result from the followup_scheduling stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate discharge management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a discharge planning specialist assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current discharge status: {! @variables.discharge_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_readiness_assessment} for readiness assessment requests.
              Use {!@actions.go_to_care_coordination} for care coordination requests.
              Use {!@actions.go_to_documentation} for documentation requests.
              Use {!@actions.go_to_followup_scheduling} for followup scheduling requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_readiness_assessment: @utils.transition to @topic.readiness_assessment
                description: "Transition to readiness assessment topic."
            go_to_care_coordination: @utils.transition to @topic.care_coordination
                description: "Transition to care coordination topic."
                available when @variables.is_verified == True
            go_to_documentation: @utils.transition to @topic.documentation
                description: "Transition to documentation topic."
                available when @variables.is_verified == True
            go_to_followup_scheduling: @utils.transition to @topic.followup_scheduling
                description: "Transition to followup scheduling topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic readiness_assessment:
    description: "Handles the readiness assessment stage of the discharge process"

    actions:
        process_readiness_assessment_data:
            description: "Process readiness assessment stage data for the discharge"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_ReadinessAssessment"

        validate_readiness_assessment_info:
            description: "Validate readiness assessment information for the discharge"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_ReadinessAssessment_Info"

        fetch_readiness_assessment_details:
            description: "Fetch readiness assessment details for the discharge"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_ReadinessAssessment_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_readiness_assessment_info
                with record_ref=@variables.discharge_record_id
                with contact_ref=@variables.contact_email
                set @variables.discharge_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the readiness assessment stage for the discharge.
              Current discharge status: {! @variables.discharge_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Readiness Assessment result: {! @variables.readiness_assessment_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.discharge_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_readiness_assessment} to begin processing.
        actions:
            run_readiness_assessment: @actions.process_readiness_assessment_data
                with record_ref=@variables.discharge_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.discharge_category
                set @variables.readiness_assessment_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.readiness_assessment_complete = @outputs.is_passed
            fetch_readiness_assessment_info: @actions.fetch_readiness_assessment_details
                with record_ref=@variables.discharge_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.discharge_tier = @outputs.tier_value
            go_to_care_coordination: @utils.transition to @topic.care_coordination
                description: "Move to care coordination stage."
                available when @variables.readiness_assessment_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.discharge_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.discharge_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.discharge_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.readiness_assessment_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic care_coordination:
    description: "Handles the care coordination stage of the discharge process"

    actions:
        process_care_coordination_data:
            description: "Process care coordination stage data for the discharge"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_CareCoordination"

        validate_care_coordination_info:
            description: "Validate care coordination information for the discharge"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_CareCoordination_Info"

        fetch_care_coordination_details:
            description: "Fetch care coordination details for the discharge"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_CareCoordination_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.readiness_assessment_complete == False:
            transition to @topic.readiness_assessment

    reasoning:
        instructions: ->
            | Handle the care coordination stage for the discharge.
              Current discharge status: {! @variables.discharge_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Care Coordination result: {! @variables.care_coordination_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.discharge_tier }
              Review the care coordination results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_care_coordination: @actions.process_care_coordination_data
                with record_ref=@variables.discharge_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.discharge_category
                set @variables.care_coordination_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.care_coordination_complete = @outputs.is_passed
            fetch_care_coordination_info: @actions.fetch_care_coordination_details
                with record_ref=@variables.discharge_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.discharge_tier = @outputs.tier_value
                available when @variables.discharge_record_id is not None
            go_to_documentation: @utils.transition to @topic.documentation
                description: "Move to documentation stage."
                available when @variables.care_coordination_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.care_coordination_complete == True:
            set @variables.discharge_status = "care_coordination_done"
        if @variables.care_coordination_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.documentation
        if @variables.attempt_count >= 3 and @variables.care_coordination_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic documentation:
    description: "Handles the documentation stage of the discharge process"

    actions:
        process_documentation_data:
            description: "Process documentation stage data for the discharge"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_Documentation_Data"

        validate_documentation_info:
            description: "Validate documentation information for the discharge"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Documentation_Info"

        fetch_documentation_details:
            description: "Fetch documentation details for the discharge"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Documentation_Details"

    before_reasoning:
        if @variables.documentation_complete == False:
            run @actions.fetch_documentation_details
                with record_ref=@variables.discharge_record_id
                with include_history=True
                set @variables.documentation_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.discharge_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.discharge_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.discharge_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the documentation stage for the discharge.
              Current discharge status: {! @variables.discharge_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Documentation result: {! @variables.documentation_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.discharge_tier }
              Review the documentation results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_documentation: @actions.process_documentation_data
                with record_ref=@variables.discharge_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.discharge_category
                set @variables.documentation_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.documentation_complete = @outputs.is_passed
            fetch_documentation_info: @actions.fetch_documentation_details
                with record_ref=@variables.discharge_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.discharge_tier = @outputs.tier_value
                available when @variables.discharge_record_id is not None
            go_to_followup_scheduling: @utils.transition to @topic.followup_scheduling
                description: "Move to followup scheduling stage."
                available when @variables.documentation_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.discharge_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.discharge_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.discharge_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.documentation_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic followup_scheduling:
    description: "Handles the followup scheduling stage of the discharge process"

    actions:
        process_followup_scheduling_data:
            description: "Process followup scheduling stage data for the discharge"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_FollowupScheduling"

        validate_followup_scheduling_info:
            description: "Validate followup scheduling information for the discharge"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_FollowupScheduling_Info"

        fetch_followup_scheduling_details:
            description: "Fetch followup scheduling details for the discharge"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_FollowupScheduling_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.documentation_complete == False:
            transition to @topic.documentation
        if @variables.eligibility_score >= 80:
            set @variables.discharge_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.discharge_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the followup scheduling stage for the discharge.
              Current discharge status: {! @variables.discharge_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Followup Scheduling result: {! @variables.followup_scheduling_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.discharge_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_followup_scheduling: @actions.process_followup_scheduling_data
                with record_ref=@variables.discharge_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.discharge_category
                set @variables.followup_scheduling_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.followup_scheduling_complete = @outputs.is_passed
            fetch_followup_scheduling_info: @actions.fetch_followup_scheduling_details
                with record_ref=@variables.discharge_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.discharge_tier = @outputs.tier_value
                available when @variables.discharge_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.followup_scheduling_complete == True:
            set @variables.discharge_status = "followup_scheduling_done"
        if @variables.attempt_count >= 3 and @variables.followup_scheduling_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for discharge issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the discharge issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the discharge interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the discharge request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Discharge status: {! @variables.discharge_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.discharge_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.discharge_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.discharge_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.discharge_status = "escalated"
        set @variables.escalation_requested = False

