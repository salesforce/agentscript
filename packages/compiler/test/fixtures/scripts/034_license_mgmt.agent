system:
    instructions: |
        You are a professional software license management agent assistant.
        Help users manage their sw_license requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: audit -> allocation -> compliance_check -> renewal.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Software License Management Agent Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "license_mgmt_agent_v34"
    default_agent_user: "license_mgmt@example.com"
    agent_description: "Assists users with sw_license management through the software license management agent workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    sw_license_record_id: mutable string
        description: "Record ID of the sw_license"
    sw_license_status: mutable string = ""
        description: "Current status of the sw_license"
    sw_license_tier: mutable string = "standard"
        description: "Tier classification for the sw_license"
    sw_license_category: mutable string = ""
        description: "Category of the sw_license"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    audit_complete: mutable boolean = False
        description: "Whether the audit stage is complete"
    audit_result: mutable string = ""
        description: "Result from the audit stage"
    allocation_complete: mutable boolean = False
        description: "Whether the allocation stage is complete"
    allocation_result: mutable string = ""
        description: "Result from the allocation stage"
    compliance_check_complete: mutable boolean = False
        description: "Whether the compliance_check stage is complete"
    compliance_check_result: mutable string = ""
        description: "Result from the compliance_check stage"
    renewal_complete: mutable boolean = False
        description: "Whether the renewal stage is complete"
    renewal_result: mutable string = ""
        description: "Result from the renewal stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate sw_license management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a software license management agent assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current sw_license status: {! @variables.sw_license_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_audit} for audit requests.
              Use {!@actions.go_to_allocation} for allocation requests.
              Use {!@actions.go_to_compliance_check} for compliance check requests.
              Use {!@actions.go_to_renewal} for renewal requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_audit: @utils.transition to @topic.audit
                description: "Transition to audit topic."
            go_to_allocation: @utils.transition to @topic.allocation
                description: "Transition to allocation topic."
                available when @variables.is_verified == True
            go_to_compliance_check: @utils.transition to @topic.compliance_check
                description: "Transition to compliance check topic."
                available when @variables.is_verified == True
            go_to_renewal: @utils.transition to @topic.renewal
                description: "Transition to renewal topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic audit:
    description: "Handles the audit stage of the sw_license process"

    actions:
        process_audit_data:
            description: "Process audit stage data for the sw_license"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_Audit_Data"

        validate_audit_info:
            description: "Validate audit information for the sw_license"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Audit_Info"

        fetch_audit_details:
            description: "Fetch audit details for the sw_license"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Audit_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_audit_info
                with record_ref=@variables.sw_license_record_id
                with contact_ref=@variables.contact_email
                set @variables.sw_license_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the audit stage for the sw_license.
              Current sw_license status: {! @variables.sw_license_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Audit result: {! @variables.audit_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.sw_license_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_audit} to begin processing.
        actions:
            run_audit: @actions.process_audit_data
                with record_ref=@variables.sw_license_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.sw_license_category
                set @variables.audit_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.audit_complete = @outputs.is_passed
            fetch_audit_info: @actions.fetch_audit_details
                with record_ref=@variables.sw_license_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.sw_license_tier = @outputs.tier_value
            go_to_allocation: @utils.transition to @topic.allocation
                description: "Move to allocation stage."
                available when @variables.audit_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.sw_license_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.sw_license_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.sw_license_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.audit_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic allocation:
    description: "Handles the allocation stage of the sw_license process"

    actions:
        process_allocation_data:
            description: "Process allocation stage data for the sw_license"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_Allocation"

        validate_allocation_info:
            description: "Validate allocation information for the sw_license"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Allocation_Info"

        fetch_allocation_details:
            description: "Fetch allocation details for the sw_license"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Allocation_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.audit_complete == False:
            transition to @topic.audit

    reasoning:
        instructions: ->
            | Handle the allocation stage for the sw_license.
              Current sw_license status: {! @variables.sw_license_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Allocation result: {! @variables.allocation_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.sw_license_tier }
              Review the allocation results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_allocation: @actions.process_allocation_data
                with record_ref=@variables.sw_license_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.sw_license_category
                set @variables.allocation_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.allocation_complete = @outputs.is_passed
            fetch_allocation_info: @actions.fetch_allocation_details
                with record_ref=@variables.sw_license_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.sw_license_tier = @outputs.tier_value
                available when @variables.sw_license_record_id is not None
            go_to_compliance_check: @utils.transition to @topic.compliance_check
                description: "Move to compliance check stage."
                available when @variables.allocation_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.allocation_complete == True:
            set @variables.sw_license_status = "allocation_done"
        if @variables.allocation_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.compliance_check
        if @variables.attempt_count >= 3 and @variables.allocation_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic compliance_check:
    description: "Handles the compliance check stage of the sw_license process"

    actions:
        process_compliance_check_data:
            description: "Process compliance check stage data for the sw_license"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_ComplianceCheck"

        validate_compliance_check_info:
            description: "Validate compliance check information for the sw_license"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_ComplianceCheck_Info"

        fetch_compliance_check_details:
            description: "Fetch compliance check details for the sw_license"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_ComplianceCheck_Details"

    before_reasoning:
        if @variables.compliance_check_complete == False:
            run @actions.fetch_compliance_check_details
                with record_ref=@variables.sw_license_record_id
                with include_history=True
                set @variables.compliance_check_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.sw_license_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.sw_license_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.sw_license_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the compliance check stage for the sw_license.
              Current sw_license status: {! @variables.sw_license_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Compliance Check result: {! @variables.compliance_check_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.sw_license_tier }
              Review the compliance check results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_compliance_check: @actions.process_compliance_check_data
                with record_ref=@variables.sw_license_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.sw_license_category
                set @variables.compliance_check_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.compliance_check_complete = @outputs.is_passed
            fetch_compliance_check_info: @actions.fetch_compliance_check_details
                with record_ref=@variables.sw_license_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.sw_license_tier = @outputs.tier_value
                available when @variables.sw_license_record_id is not None
            go_to_renewal: @utils.transition to @topic.renewal
                description: "Move to renewal stage."
                available when @variables.compliance_check_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.sw_license_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.sw_license_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.sw_license_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.compliance_check_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic renewal:
    description: "Handles the renewal stage of the sw_license process"

    actions:
        process_renewal_data:
            description: "Process renewal stage data for the sw_license"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_Renewal_Data"

        validate_renewal_info:
            description: "Validate renewal information for the sw_license"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Renewal_Info"

        fetch_renewal_details:
            description: "Fetch renewal details for the sw_license"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Renewal_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.compliance_check_complete == False:
            transition to @topic.compliance_check
        if @variables.eligibility_score >= 80:
            set @variables.sw_license_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.sw_license_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the renewal stage for the sw_license.
              Current sw_license status: {! @variables.sw_license_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Renewal result: {! @variables.renewal_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.sw_license_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_renewal: @actions.process_renewal_data
                with record_ref=@variables.sw_license_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.sw_license_category
                set @variables.renewal_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.renewal_complete = @outputs.is_passed
            fetch_renewal_info: @actions.fetch_renewal_details
                with record_ref=@variables.sw_license_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.sw_license_tier = @outputs.tier_value
                available when @variables.sw_license_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.renewal_complete == True:
            set @variables.sw_license_status = "renewal_done"
        if @variables.attempt_count >= 3 and @variables.renewal_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for sw_license issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the sw_license issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the sw_license interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the sw_license request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Sw License status: {! @variables.sw_license_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.sw_license_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.sw_license_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.sw_license_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.sw_license_status = "escalated"
        set @variables.escalation_requested = False

