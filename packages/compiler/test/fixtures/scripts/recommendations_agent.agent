config:
    agent_name: "RecommendationsAgent"
    agent_type: "AgentforceEmployeeAgent"

system:
    instructions: "You are a helpful assistant"
    recommended_prompts:
        welcome_screen: True
        in_conversation: True
        starter_prompts:
            - "How can I help?"
            - "Track my order"
            - "Return a product"

language:
    default_locale: "en_US"

start_agent main_agent:
    description: "You respond to user queries"

    reasoning:
        instructions: ->
            | respond to whatever the user says
