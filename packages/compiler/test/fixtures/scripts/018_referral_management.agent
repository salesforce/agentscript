system:
    instructions: |
        You are a professional referral management agent assistant.
        Help users manage their referral requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: capture -> routing -> tracking -> closure.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Referral Management Agent Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "referral_management_agent_v18"
    default_agent_user: "referral_management@example.com"
    agent_description: "Assists users with referral management through the referral management agent workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    referral_record_id: mutable string
        description: "Record ID of the referral"
    referral_status: mutable string = ""
        description: "Current status of the referral"
    referral_tier: mutable string = "standard"
        description: "Tier classification for the referral"
    referral_category: mutable string = ""
        description: "Category of the referral"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    capture_complete: mutable boolean = False
        description: "Whether the capture stage is complete"
    capture_result: mutable string = ""
        description: "Result from the capture stage"
    routing_complete: mutable boolean = False
        description: "Whether the routing stage is complete"
    routing_result: mutable string = ""
        description: "Result from the routing stage"
    tracking_complete: mutable boolean = False
        description: "Whether the tracking stage is complete"
    tracking_result: mutable string = ""
        description: "Result from the tracking stage"
    closure_complete: mutable boolean = False
        description: "Whether the closure stage is complete"
    closure_result: mutable string = ""
        description: "Result from the closure stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate referral management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a referral management agent assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current referral status: {! @variables.referral_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_capture} for capture requests.
              Use {!@actions.go_to_routing} for routing requests.
              Use {!@actions.go_to_tracking} for tracking requests.
              Use {!@actions.go_to_closure} for closure requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_capture: @utils.transition to @topic.capture
                description: "Transition to capture topic."
            go_to_routing: @utils.transition to @topic.routing
                description: "Transition to routing topic."
                available when @variables.is_verified == True
            go_to_tracking: @utils.transition to @topic.tracking
                description: "Transition to tracking topic."
                available when @variables.is_verified == True
            go_to_closure: @utils.transition to @topic.closure
                description: "Transition to closure topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic capture:
    description: "Handles the capture stage of the referral process"

    actions:
        process_capture_data:
            description: "Process capture stage data for the referral"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_Capture"

        validate_capture_info:
            description: "Validate capture information for the referral"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Capture_Info"

        fetch_capture_details:
            description: "Fetch capture details for the referral"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Capture_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_capture_info
                with record_ref=@variables.referral_record_id
                with contact_ref=@variables.contact_email
                set @variables.referral_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the capture stage for the referral.
              Current referral status: {! @variables.referral_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Capture result: {! @variables.capture_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.referral_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_capture} to begin processing.
        actions:
            run_capture: @actions.process_capture_data
                with record_ref=@variables.referral_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.referral_category
                set @variables.capture_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.capture_complete = @outputs.is_passed
            fetch_capture_info: @actions.fetch_capture_details
                with record_ref=@variables.referral_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.referral_tier = @outputs.tier_value
            go_to_routing: @utils.transition to @topic.routing
                description: "Move to routing stage."
                available when @variables.capture_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.referral_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.referral_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.referral_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.capture_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic routing:
    description: "Handles the routing stage of the referral process"

    actions:
        process_routing_data:
            description: "Process routing stage data for the referral"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_Routing_Data"

        validate_routing_info:
            description: "Validate routing information for the referral"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Routing_Info"

        fetch_routing_details:
            description: "Fetch routing details for the referral"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Routing_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.capture_complete == False:
            transition to @topic.capture

    reasoning:
        instructions: ->
            | Handle the routing stage for the referral.
              Current referral status: {! @variables.referral_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Routing result: {! @variables.routing_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.referral_tier }
              Review the routing results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_routing: @actions.process_routing_data
                with record_ref=@variables.referral_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.referral_category
                set @variables.routing_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.routing_complete = @outputs.is_passed
            fetch_routing_info: @actions.fetch_routing_details
                with record_ref=@variables.referral_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.referral_tier = @outputs.tier_value
                available when @variables.referral_record_id is not None
            go_to_tracking: @utils.transition to @topic.tracking
                description: "Move to tracking stage."
                available when @variables.routing_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.routing_complete == True:
            set @variables.referral_status = "routing_done"
        if @variables.routing_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.tracking
        if @variables.attempt_count >= 3 and @variables.routing_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic tracking:
    description: "Handles the tracking stage of the referral process"

    actions:
        process_tracking_data:
            description: "Process tracking stage data for the referral"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_Tracking"

        validate_tracking_info:
            description: "Validate tracking information for the referral"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Tracking_Info"

        fetch_tracking_details:
            description: "Fetch tracking details for the referral"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Tracking_Details"

    before_reasoning:
        if @variables.tracking_complete == False:
            run @actions.fetch_tracking_details
                with record_ref=@variables.referral_record_id
                with include_history=True
                set @variables.tracking_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.referral_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.referral_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.referral_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the tracking stage for the referral.
              Current referral status: {! @variables.referral_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Tracking result: {! @variables.tracking_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.referral_tier }
              Review the tracking results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_tracking: @actions.process_tracking_data
                with record_ref=@variables.referral_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.referral_category
                set @variables.tracking_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.tracking_complete = @outputs.is_passed
            fetch_tracking_info: @actions.fetch_tracking_details
                with record_ref=@variables.referral_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.referral_tier = @outputs.tier_value
                available when @variables.referral_record_id is not None
            go_to_closure: @utils.transition to @topic.closure
                description: "Move to closure stage."
                available when @variables.tracking_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.referral_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.referral_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.referral_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.tracking_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic closure:
    description: "Handles the closure stage of the referral process"

    actions:
        process_closure_data:
            description: "Process closure stage data for the referral"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_Closure"

        validate_closure_info:
            description: "Validate closure information for the referral"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Closure_Info"

        fetch_closure_details:
            description: "Fetch closure details for the referral"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Closure_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.tracking_complete == False:
            transition to @topic.tracking
        if @variables.eligibility_score >= 80:
            set @variables.referral_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.referral_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the closure stage for the referral.
              Current referral status: {! @variables.referral_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Closure result: {! @variables.closure_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.referral_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_closure: @actions.process_closure_data
                with record_ref=@variables.referral_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.referral_category
                set @variables.closure_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.closure_complete = @outputs.is_passed
            fetch_closure_info: @actions.fetch_closure_details
                with record_ref=@variables.referral_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.referral_tier = @outputs.tier_value
                available when @variables.referral_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.closure_complete == True:
            set @variables.referral_status = "closure_done"
        if @variables.attempt_count >= 3 and @variables.closure_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for referral issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the referral issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the referral interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the referral request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Referral status: {! @variables.referral_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.referral_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.referral_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.referral_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.referral_status = "escalated"
        set @variables.escalation_requested = False

