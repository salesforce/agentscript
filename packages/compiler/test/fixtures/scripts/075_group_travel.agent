system:
    instructions: |
        You are a professional group travel coordinator assistant.
        Help users manage their group_booking requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: requirement_gathering -> venue_selection -> negotiation -> logistics.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Group Travel Coordinator Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "group_travel_agent_v75"
    default_agent_user: "group_travel@example.com"
    agent_description: "Assists users with group_booking management through the group travel coordinator workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    group_booking_record_id: mutable string
        description: "Record ID of the group_booking"
    group_booking_status: mutable string = ""
        description: "Current status of the group_booking"
    group_booking_tier: mutable string = "standard"
        description: "Tier classification for the group_booking"
    group_booking_category: mutable string = ""
        description: "Category of the group_booking"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    requirement_gathering_complete: mutable boolean = False
        description: "Whether the requirement_gathering stage is complete"
    requirement_gathering_result: mutable string = ""
        description: "Result from the requirement_gathering stage"
    venue_selection_complete: mutable boolean = False
        description: "Whether the venue_selection stage is complete"
    venue_selection_result: mutable string = ""
        description: "Result from the venue_selection stage"
    negotiation_complete: mutable boolean = False
        description: "Whether the negotiation stage is complete"
    negotiation_result: mutable string = ""
        description: "Result from the negotiation stage"
    logistics_complete: mutable boolean = False
        description: "Whether the logistics stage is complete"
    logistics_result: mutable string = ""
        description: "Result from the logistics stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate group_booking management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a group travel coordinator assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current group_booking status: {! @variables.group_booking_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_requirement_gathering} for requirement gathering requests.
              Use {!@actions.go_to_venue_selection} for venue selection requests.
              Use {!@actions.go_to_negotiation} for negotiation requests.
              Use {!@actions.go_to_logistics} for logistics requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_requirement_gathering: @utils.transition to @topic.requirement_gathering
                description: "Transition to requirement gathering topic."
            go_to_venue_selection: @utils.transition to @topic.venue_selection
                description: "Transition to venue selection topic."
                available when @variables.is_verified == True
            go_to_negotiation: @utils.transition to @topic.negotiation
                description: "Transition to negotiation topic."
                available when @variables.is_verified == True
            go_to_logistics: @utils.transition to @topic.logistics
                description: "Transition to logistics topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic requirement_gathering:
    description: "Handles the requirement gathering stage of the group_booking process"

    actions:
        process_requirement_gathering_data:
            description: "Process requirement gathering stage data for the group_booking"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_RequirementGathering"

        validate_requirement_gathering_info:
            description: "Validate requirement gathering information for the group_booking"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_RequirementGathering_Info"

        fetch_requirement_gathering_details:
            description: "Fetch requirement gathering details for the group_booking"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_RequirementGathering_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_requirement_gathering_info
                with record_ref=@variables.group_booking_record_id
                with contact_ref=@variables.contact_email
                set @variables.group_booking_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the requirement gathering stage for the group_booking.
              Current group_booking status: {! @variables.group_booking_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Requirement Gathering result: {! @variables.requirement_gathering_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.group_booking_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_requirement_gathering} to begin processing.
        actions:
            run_requirement_gathering: @actions.process_requirement_gathering_data
                with record_ref=@variables.group_booking_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.group_booking_category
                set @variables.requirement_gathering_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.requirement_gathering_complete = @outputs.is_passed
            fetch_requirement_gathering_info: @actions.fetch_requirement_gathering_details
                with record_ref=@variables.group_booking_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.group_booking_tier = @outputs.tier_value
            go_to_venue_selection: @utils.transition to @topic.venue_selection
                description: "Move to venue selection stage."
                available when @variables.requirement_gathering_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.group_booking_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.group_booking_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.group_booking_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.requirement_gathering_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic venue_selection:
    description: "Handles the venue selection stage of the group_booking process"

    actions:
        process_venue_selection_data:
            description: "Process venue selection stage data for the group_booking"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_VenueSelection_Data"

        validate_venue_selection_info:
            description: "Validate venue selection information for the group_booking"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_VenueSelection_Info"

        fetch_venue_selection_details:
            description: "Fetch venue selection details for the group_booking"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_VenueSelection_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.requirement_gathering_complete == False:
            transition to @topic.requirement_gathering

    reasoning:
        instructions: ->
            | Handle the venue selection stage for the group_booking.
              Current group_booking status: {! @variables.group_booking_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Venue Selection result: {! @variables.venue_selection_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.group_booking_tier }
              Review the venue selection results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_venue_selection: @actions.process_venue_selection_data
                with record_ref=@variables.group_booking_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.group_booking_category
                set @variables.venue_selection_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.venue_selection_complete = @outputs.is_passed
            fetch_venue_selection_info: @actions.fetch_venue_selection_details
                with record_ref=@variables.group_booking_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.group_booking_tier = @outputs.tier_value
                available when @variables.group_booking_record_id is not None
            go_to_negotiation: @utils.transition to @topic.negotiation
                description: "Move to negotiation stage."
                available when @variables.venue_selection_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.venue_selection_complete == True:
            set @variables.group_booking_status = "venue_selection_done"
        if @variables.venue_selection_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.negotiation
        if @variables.attempt_count >= 3 and @variables.venue_selection_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic negotiation:
    description: "Handles the negotiation stage of the group_booking process"

    actions:
        process_negotiation_data:
            description: "Process negotiation stage data for the group_booking"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_Negotiation"

        validate_negotiation_info:
            description: "Validate negotiation information for the group_booking"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Negotiation_Info"

        fetch_negotiation_details:
            description: "Fetch negotiation details for the group_booking"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Negotiation_Details"

    before_reasoning:
        if @variables.negotiation_complete == False:
            run @actions.fetch_negotiation_details
                with record_ref=@variables.group_booking_record_id
                with include_history=True
                set @variables.negotiation_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.group_booking_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.group_booking_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.group_booking_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the negotiation stage for the group_booking.
              Current group_booking status: {! @variables.group_booking_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Negotiation result: {! @variables.negotiation_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.group_booking_tier }
              Review the negotiation results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_negotiation: @actions.process_negotiation_data
                with record_ref=@variables.group_booking_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.group_booking_category
                set @variables.negotiation_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.negotiation_complete = @outputs.is_passed
            fetch_negotiation_info: @actions.fetch_negotiation_details
                with record_ref=@variables.group_booking_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.group_booking_tier = @outputs.tier_value
                available when @variables.group_booking_record_id is not None
            go_to_logistics: @utils.transition to @topic.logistics
                description: "Move to logistics stage."
                available when @variables.negotiation_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.group_booking_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.group_booking_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.group_booking_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.negotiation_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic logistics:
    description: "Handles the logistics stage of the group_booking process"

    actions:
        process_logistics_data:
            description: "Process logistics stage data for the group_booking"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_Logistics"

        validate_logistics_info:
            description: "Validate logistics information for the group_booking"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Logistics_Info"

        fetch_logistics_details:
            description: "Fetch logistics details for the group_booking"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Logistics_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.negotiation_complete == False:
            transition to @topic.negotiation
        if @variables.eligibility_score >= 80:
            set @variables.group_booking_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.group_booking_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the logistics stage for the group_booking.
              Current group_booking status: {! @variables.group_booking_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Logistics result: {! @variables.logistics_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.group_booking_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_logistics: @actions.process_logistics_data
                with record_ref=@variables.group_booking_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.group_booking_category
                set @variables.logistics_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.logistics_complete = @outputs.is_passed
            fetch_logistics_info: @actions.fetch_logistics_details
                with record_ref=@variables.group_booking_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.group_booking_tier = @outputs.tier_value
                available when @variables.group_booking_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.logistics_complete == True:
            set @variables.group_booking_status = "logistics_done"
        if @variables.attempt_count >= 3 and @variables.logistics_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for group_booking issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the group_booking issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the group_booking interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the group_booking request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Group Booking status: {! @variables.group_booking_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.group_booking_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.group_booking_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.group_booking_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.group_booking_status = "escalated"
        set @variables.escalation_requested = False

