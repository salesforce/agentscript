system:
    instructions: |
        You are a professional premium calculation specialist assistant.
        Help users manage their premium requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: data_collection -> factor_analysis -> computation -> comparison.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Premium Calculation Specialist Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "premium_calculation_agent_v54"
    default_agent_user: "premium_calculation@example.com"
    agent_description: "Assists users with premium management through the premium calculation specialist workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    premium_record_id: mutable string
        description: "Record ID of the premium"
    premium_status: mutable string = ""
        description: "Current status of the premium"
    premium_tier: mutable string = "standard"
        description: "Tier classification for the premium"
    premium_category: mutable string = ""
        description: "Category of the premium"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    data_collection_complete: mutable boolean = False
        description: "Whether the data_collection stage is complete"
    data_collection_result: mutable string = ""
        description: "Result from the data_collection stage"
    factor_analysis_complete: mutable boolean = False
        description: "Whether the factor_analysis stage is complete"
    factor_analysis_result: mutable string = ""
        description: "Result from the factor_analysis stage"
    computation_complete: mutable boolean = False
        description: "Whether the computation stage is complete"
    computation_result: mutable string = ""
        description: "Result from the computation stage"
    comparison_complete: mutable boolean = False
        description: "Whether the comparison stage is complete"
    comparison_result: mutable string = ""
        description: "Result from the comparison stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate premium management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a premium calculation specialist assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current premium status: {! @variables.premium_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_data_collection} for data collection requests.
              Use {!@actions.go_to_factor_analysis} for factor analysis requests.
              Use {!@actions.go_to_computation} for computation requests.
              Use {!@actions.go_to_comparison} for comparison requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_data_collection: @utils.transition to @topic.data_collection
                description: "Transition to data collection topic."
            go_to_factor_analysis: @utils.transition to @topic.factor_analysis
                description: "Transition to factor analysis topic."
                available when @variables.is_verified == True
            go_to_computation: @utils.transition to @topic.computation
                description: "Transition to computation topic."
                available when @variables.is_verified == True
            go_to_comparison: @utils.transition to @topic.comparison
                description: "Transition to comparison topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic data_collection:
    description: "Handles the data collection stage of the premium process"

    actions:
        process_data_collection_data:
            description: "Process data collection stage data for the premium"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_DataCollection"

        validate_data_collection_info:
            description: "Validate data collection information for the premium"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_DataCollection_Info"

        fetch_data_collection_details:
            description: "Fetch data collection details for the premium"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_DataCollection_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_data_collection_info
                with record_ref=@variables.premium_record_id
                with contact_ref=@variables.contact_email
                set @variables.premium_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the data collection stage for the premium.
              Current premium status: {! @variables.premium_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Data Collection result: {! @variables.data_collection_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.premium_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_data_collection} to begin processing.
        actions:
            run_data_collection: @actions.process_data_collection_data
                with record_ref=@variables.premium_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.premium_category
                set @variables.data_collection_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.data_collection_complete = @outputs.is_passed
            fetch_data_collection_info: @actions.fetch_data_collection_details
                with record_ref=@variables.premium_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.premium_tier = @outputs.tier_value
            go_to_factor_analysis: @utils.transition to @topic.factor_analysis
                description: "Move to factor analysis stage."
                available when @variables.data_collection_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.premium_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.premium_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.premium_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.data_collection_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic factor_analysis:
    description: "Handles the factor analysis stage of the premium process"

    actions:
        process_factor_analysis_data:
            description: "Process factor analysis stage data for the premium"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_FactorAnalysis_Data"

        validate_factor_analysis_info:
            description: "Validate factor analysis information for the premium"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_FactorAnalysis_Info"

        fetch_factor_analysis_details:
            description: "Fetch factor analysis details for the premium"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_FactorAnalysis_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.data_collection_complete == False:
            transition to @topic.data_collection

    reasoning:
        instructions: ->
            | Handle the factor analysis stage for the premium.
              Current premium status: {! @variables.premium_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Factor Analysis result: {! @variables.factor_analysis_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.premium_tier }
              Review the factor analysis results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_factor_analysis: @actions.process_factor_analysis_data
                with record_ref=@variables.premium_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.premium_category
                set @variables.factor_analysis_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.factor_analysis_complete = @outputs.is_passed
            fetch_factor_analysis_info: @actions.fetch_factor_analysis_details
                with record_ref=@variables.premium_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.premium_tier = @outputs.tier_value
                available when @variables.premium_record_id is not None
            go_to_computation: @utils.transition to @topic.computation
                description: "Move to computation stage."
                available when @variables.factor_analysis_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.factor_analysis_complete == True:
            set @variables.premium_status = "factor_analysis_done"
        if @variables.factor_analysis_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.computation
        if @variables.attempt_count >= 3 and @variables.factor_analysis_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic computation:
    description: "Handles the computation stage of the premium process"

    actions:
        process_computation_data:
            description: "Process computation stage data for the premium"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_Computation"

        validate_computation_info:
            description: "Validate computation information for the premium"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Computation_Info"

        fetch_computation_details:
            description: "Fetch computation details for the premium"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Computation_Details"

    before_reasoning:
        if @variables.computation_complete == False:
            run @actions.fetch_computation_details
                with record_ref=@variables.premium_record_id
                with include_history=True
                set @variables.computation_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.premium_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.premium_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.premium_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the computation stage for the premium.
              Current premium status: {! @variables.premium_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Computation result: {! @variables.computation_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.premium_tier }
              Review the computation results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_computation: @actions.process_computation_data
                with record_ref=@variables.premium_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.premium_category
                set @variables.computation_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.computation_complete = @outputs.is_passed
            fetch_computation_info: @actions.fetch_computation_details
                with record_ref=@variables.premium_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.premium_tier = @outputs.tier_value
                available when @variables.premium_record_id is not None
            go_to_comparison: @utils.transition to @topic.comparison
                description: "Move to comparison stage."
                available when @variables.computation_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.premium_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.premium_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.premium_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.computation_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic comparison:
    description: "Handles the comparison stage of the premium process"

    actions:
        process_comparison_data:
            description: "Process comparison stage data for the premium"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_Comparison"

        validate_comparison_info:
            description: "Validate comparison information for the premium"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Comparison_Info"

        fetch_comparison_details:
            description: "Fetch comparison details for the premium"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Comparison_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.computation_complete == False:
            transition to @topic.computation
        if @variables.eligibility_score >= 80:
            set @variables.premium_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.premium_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the comparison stage for the premium.
              Current premium status: {! @variables.premium_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Comparison result: {! @variables.comparison_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.premium_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_comparison: @actions.process_comparison_data
                with record_ref=@variables.premium_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.premium_category
                set @variables.comparison_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.comparison_complete = @outputs.is_passed
            fetch_comparison_info: @actions.fetch_comparison_details
                with record_ref=@variables.premium_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.premium_tier = @outputs.tier_value
                available when @variables.premium_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.comparison_complete == True:
            set @variables.premium_status = "comparison_done"
        if @variables.attempt_count >= 3 and @variables.comparison_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for premium issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the premium issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the premium interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the premium request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Premium status: {! @variables.premium_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.premium_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.premium_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.premium_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.premium_status = "escalated"
        set @variables.escalation_requested = False

