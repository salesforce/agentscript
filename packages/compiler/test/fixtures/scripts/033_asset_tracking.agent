system:
    instructions: |
        You are a professional IT asset tracking agent assistant.
        Help users manage their asset requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: discovery -> registration -> lifecycle_mgmt -> retirement.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your It Asset Tracking Agent Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "asset_tracking_agent_v33"
    default_agent_user: "asset_tracking@example.com"
    agent_description: "Assists users with asset management through the IT asset tracking agent workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    asset_record_id: mutable string
        description: "Record ID of the asset"
    asset_status: mutable string = ""
        description: "Current status of the asset"
    asset_tier: mutable string = "standard"
        description: "Tier classification for the asset"
    asset_category: mutable string = ""
        description: "Category of the asset"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    discovery_complete: mutable boolean = False
        description: "Whether the discovery stage is complete"
    discovery_result: mutable string = ""
        description: "Result from the discovery stage"
    registration_complete: mutable boolean = False
        description: "Whether the registration stage is complete"
    registration_result: mutable string = ""
        description: "Result from the registration stage"
    lifecycle_mgmt_complete: mutable boolean = False
        description: "Whether the lifecycle_mgmt stage is complete"
    lifecycle_mgmt_result: mutable string = ""
        description: "Result from the lifecycle_mgmt stage"
    retirement_complete: mutable boolean = False
        description: "Whether the retirement stage is complete"
    retirement_result: mutable string = ""
        description: "Result from the retirement stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate asset management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a IT asset tracking agent assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current asset status: {! @variables.asset_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_discovery} for discovery requests.
              Use {!@actions.go_to_registration} for registration requests.
              Use {!@actions.go_to_lifecycle_mgmt} for lifecycle mgmt requests.
              Use {!@actions.go_to_retirement} for retirement requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_discovery: @utils.transition to @topic.discovery
                description: "Transition to discovery topic."
            go_to_registration: @utils.transition to @topic.registration
                description: "Transition to registration topic."
                available when @variables.is_verified == True
            go_to_lifecycle_mgmt: @utils.transition to @topic.lifecycle_mgmt
                description: "Transition to lifecycle mgmt topic."
                available when @variables.is_verified == True
            go_to_retirement: @utils.transition to @topic.retirement
                description: "Transition to retirement topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic discovery:
    description: "Handles the discovery stage of the asset process"

    actions:
        process_discovery_data:
            description: "Process discovery stage data for the asset"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_Discovery"

        validate_discovery_info:
            description: "Validate discovery information for the asset"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Discovery_Info"

        fetch_discovery_details:
            description: "Fetch discovery details for the asset"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Discovery_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_discovery_info
                with record_ref=@variables.asset_record_id
                with contact_ref=@variables.contact_email
                set @variables.asset_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the discovery stage for the asset.
              Current asset status: {! @variables.asset_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Discovery result: {! @variables.discovery_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.asset_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_discovery} to begin processing.
        actions:
            run_discovery: @actions.process_discovery_data
                with record_ref=@variables.asset_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.asset_category
                set @variables.discovery_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.discovery_complete = @outputs.is_passed
            fetch_discovery_info: @actions.fetch_discovery_details
                with record_ref=@variables.asset_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.asset_tier = @outputs.tier_value
            go_to_registration: @utils.transition to @topic.registration
                description: "Move to registration stage."
                available when @variables.discovery_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.asset_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.asset_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.asset_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.discovery_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic registration:
    description: "Handles the registration stage of the asset process"

    actions:
        process_registration_data:
            description: "Process registration stage data for the asset"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_Registration_Data"

        validate_registration_info:
            description: "Validate registration information for the asset"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Registration_Info"

        fetch_registration_details:
            description: "Fetch registration details for the asset"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Registration_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.discovery_complete == False:
            transition to @topic.discovery

    reasoning:
        instructions: ->
            | Handle the registration stage for the asset.
              Current asset status: {! @variables.asset_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Registration result: {! @variables.registration_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.asset_tier }
              Review the registration results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_registration: @actions.process_registration_data
                with record_ref=@variables.asset_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.asset_category
                set @variables.registration_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.registration_complete = @outputs.is_passed
            fetch_registration_info: @actions.fetch_registration_details
                with record_ref=@variables.asset_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.asset_tier = @outputs.tier_value
                available when @variables.asset_record_id is not None
            go_to_lifecycle_mgmt: @utils.transition to @topic.lifecycle_mgmt
                description: "Move to lifecycle mgmt stage."
                available when @variables.registration_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.registration_complete == True:
            set @variables.asset_status = "registration_done"
        if @variables.registration_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.lifecycle_mgmt
        if @variables.attempt_count >= 3 and @variables.registration_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic lifecycle_mgmt:
    description: "Handles the lifecycle mgmt stage of the asset process"

    actions:
        process_lifecycle_mgmt_data:
            description: "Process lifecycle mgmt stage data for the asset"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_LifecycleMgmt"

        validate_lifecycle_mgmt_info:
            description: "Validate lifecycle mgmt information for the asset"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_LifecycleMgmt_Info"

        fetch_lifecycle_mgmt_details:
            description: "Fetch lifecycle mgmt details for the asset"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_LifecycleMgmt_Details"

    before_reasoning:
        if @variables.lifecycle_mgmt_complete == False:
            run @actions.fetch_lifecycle_mgmt_details
                with record_ref=@variables.asset_record_id
                with include_history=True
                set @variables.lifecycle_mgmt_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.asset_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.asset_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.asset_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the lifecycle mgmt stage for the asset.
              Current asset status: {! @variables.asset_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Lifecycle Mgmt result: {! @variables.lifecycle_mgmt_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.asset_tier }
              Review the lifecycle mgmt results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_lifecycle_mgmt: @actions.process_lifecycle_mgmt_data
                with record_ref=@variables.asset_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.asset_category
                set @variables.lifecycle_mgmt_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.lifecycle_mgmt_complete = @outputs.is_passed
            fetch_lifecycle_mgmt_info: @actions.fetch_lifecycle_mgmt_details
                with record_ref=@variables.asset_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.asset_tier = @outputs.tier_value
                available when @variables.asset_record_id is not None
            go_to_retirement: @utils.transition to @topic.retirement
                description: "Move to retirement stage."
                available when @variables.lifecycle_mgmt_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.asset_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.asset_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.asset_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.lifecycle_mgmt_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic retirement:
    description: "Handles the retirement stage of the asset process"

    actions:
        process_retirement_data:
            description: "Process retirement stage data for the asset"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_Retirement"

        validate_retirement_info:
            description: "Validate retirement information for the asset"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Retirement_Info"

        fetch_retirement_details:
            description: "Fetch retirement details for the asset"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Retirement_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.lifecycle_mgmt_complete == False:
            transition to @topic.lifecycle_mgmt
        if @variables.eligibility_score >= 80:
            set @variables.asset_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.asset_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the retirement stage for the asset.
              Current asset status: {! @variables.asset_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Retirement result: {! @variables.retirement_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.asset_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_retirement: @actions.process_retirement_data
                with record_ref=@variables.asset_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.asset_category
                set @variables.retirement_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.retirement_complete = @outputs.is_passed
            fetch_retirement_info: @actions.fetch_retirement_details
                with record_ref=@variables.asset_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.asset_tier = @outputs.tier_value
                available when @variables.asset_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.retirement_complete == True:
            set @variables.asset_status = "retirement_done"
        if @variables.attempt_count >= 3 and @variables.retirement_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for asset issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the asset issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the asset interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the asset request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Asset status: {! @variables.asset_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.asset_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.asset_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.asset_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.asset_status = "escalated"
        set @variables.escalation_requested = False

