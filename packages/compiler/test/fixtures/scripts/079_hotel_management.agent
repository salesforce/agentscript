system:
    instructions: |
        You are a professional hotel management agent assistant.
        Help users manage their reservation requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: room_search -> booking -> check_in_prep -> guest_services.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Hotel Management Agent Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "hotel_management_agent_v79"
    default_agent_user: "hotel_management@example.com"
    agent_description: "Assists users with reservation management through the hotel management agent workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    reservation_record_id: mutable string
        description: "Record ID of the reservation"
    reservation_status: mutable string = ""
        description: "Current status of the reservation"
    reservation_tier: mutable string = "standard"
        description: "Tier classification for the reservation"
    reservation_category: mutable string = ""
        description: "Category of the reservation"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    room_search_complete: mutable boolean = False
        description: "Whether the room_search stage is complete"
    room_search_result: mutable string = ""
        description: "Result from the room_search stage"
    booking_complete: mutable boolean = False
        description: "Whether the booking stage is complete"
    booking_result: mutable string = ""
        description: "Result from the booking stage"
    check_in_prep_complete: mutable boolean = False
        description: "Whether the check_in_prep stage is complete"
    check_in_prep_result: mutable string = ""
        description: "Result from the check_in_prep stage"
    guest_services_complete: mutable boolean = False
        description: "Whether the guest_services stage is complete"
    guest_services_result: mutable string = ""
        description: "Result from the guest_services stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate reservation management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a hotel management agent assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current reservation status: {! @variables.reservation_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_room_search} for room search requests.
              Use {!@actions.go_to_booking} for booking requests.
              Use {!@actions.go_to_check_in_prep} for check in prep requests.
              Use {!@actions.go_to_guest_services} for guest services requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_room_search: @utils.transition to @topic.room_search
                description: "Transition to room search topic."
            go_to_booking: @utils.transition to @topic.booking
                description: "Transition to booking topic."
                available when @variables.is_verified == True
            go_to_check_in_prep: @utils.transition to @topic.check_in_prep
                description: "Transition to check in prep topic."
                available when @variables.is_verified == True
            go_to_guest_services: @utils.transition to @topic.guest_services
                description: "Transition to guest services topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic room_search:
    description: "Handles the room search stage of the reservation process"

    actions:
        process_room_search_data:
            description: "Process room search stage data for the reservation"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_RoomSearch_Data"

        validate_room_search_info:
            description: "Validate room search information for the reservation"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_RoomSearch_Info"

        fetch_room_search_details:
            description: "Fetch room search details for the reservation"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_RoomSearch_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_room_search_info
                with record_ref=@variables.reservation_record_id
                with contact_ref=@variables.contact_email
                set @variables.reservation_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the room search stage for the reservation.
              Current reservation status: {! @variables.reservation_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Room Search result: {! @variables.room_search_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.reservation_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_room_search} to begin processing.
        actions:
            run_room_search: @actions.process_room_search_data
                with record_ref=@variables.reservation_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.reservation_category
                set @variables.room_search_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.room_search_complete = @outputs.is_passed
            fetch_room_search_info: @actions.fetch_room_search_details
                with record_ref=@variables.reservation_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.reservation_tier = @outputs.tier_value
            go_to_booking: @utils.transition to @topic.booking
                description: "Move to booking stage."
                available when @variables.room_search_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.reservation_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.reservation_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.reservation_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.room_search_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic booking:
    description: "Handles the booking stage of the reservation process"

    actions:
        process_booking_data:
            description: "Process booking stage data for the reservation"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_Booking"

        validate_booking_info:
            description: "Validate booking information for the reservation"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Booking_Info"

        fetch_booking_details:
            description: "Fetch booking details for the reservation"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Booking_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.room_search_complete == False:
            transition to @topic.room_search

    reasoning:
        instructions: ->
            | Handle the booking stage for the reservation.
              Current reservation status: {! @variables.reservation_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Booking result: {! @variables.booking_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.reservation_tier }
              Review the booking results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_booking: @actions.process_booking_data
                with record_ref=@variables.reservation_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.reservation_category
                set @variables.booking_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.booking_complete = @outputs.is_passed
            fetch_booking_info: @actions.fetch_booking_details
                with record_ref=@variables.reservation_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.reservation_tier = @outputs.tier_value
                available when @variables.reservation_record_id is not None
            go_to_check_in_prep: @utils.transition to @topic.check_in_prep
                description: "Move to check in prep stage."
                available when @variables.booking_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.booking_complete == True:
            set @variables.reservation_status = "booking_done"
        if @variables.booking_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.check_in_prep
        if @variables.attempt_count >= 3 and @variables.booking_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic check_in_prep:
    description: "Handles the check in prep stage of the reservation process"

    actions:
        process_check_in_prep_data:
            description: "Process check in prep stage data for the reservation"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_CheckInPrep"

        validate_check_in_prep_info:
            description: "Validate check in prep information for the reservation"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_CheckInPrep_Info"

        fetch_check_in_prep_details:
            description: "Fetch check in prep details for the reservation"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_CheckInPrep_Details"

    before_reasoning:
        if @variables.check_in_prep_complete == False:
            run @actions.fetch_check_in_prep_details
                with record_ref=@variables.reservation_record_id
                with include_history=True
                set @variables.check_in_prep_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.reservation_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.reservation_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.reservation_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the check in prep stage for the reservation.
              Current reservation status: {! @variables.reservation_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Check In Prep result: {! @variables.check_in_prep_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.reservation_tier }
              Review the check in prep results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_check_in_prep: @actions.process_check_in_prep_data
                with record_ref=@variables.reservation_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.reservation_category
                set @variables.check_in_prep_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.check_in_prep_complete = @outputs.is_passed
            fetch_check_in_prep_info: @actions.fetch_check_in_prep_details
                with record_ref=@variables.reservation_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.reservation_tier = @outputs.tier_value
                available when @variables.reservation_record_id is not None
            go_to_guest_services: @utils.transition to @topic.guest_services
                description: "Move to guest services stage."
                available when @variables.check_in_prep_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.reservation_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.reservation_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.reservation_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.check_in_prep_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic guest_services:
    description: "Handles the guest services stage of the reservation process"

    actions:
        process_guest_services_data:
            description: "Process guest services stage data for the reservation"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_GuestServices_Data"

        validate_guest_services_info:
            description: "Validate guest services information for the reservation"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_GuestServices_Info"

        fetch_guest_services_details:
            description: "Fetch guest services details for the reservation"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_GuestServices_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.check_in_prep_complete == False:
            transition to @topic.check_in_prep
        if @variables.eligibility_score >= 80:
            set @variables.reservation_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.reservation_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the guest services stage for the reservation.
              Current reservation status: {! @variables.reservation_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Guest Services result: {! @variables.guest_services_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.reservation_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_guest_services: @actions.process_guest_services_data
                with record_ref=@variables.reservation_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.reservation_category
                set @variables.guest_services_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.guest_services_complete = @outputs.is_passed
            fetch_guest_services_info: @actions.fetch_guest_services_details
                with record_ref=@variables.reservation_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.reservation_tier = @outputs.tier_value
                available when @variables.reservation_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.guest_services_complete == True:
            set @variables.reservation_status = "guest_services_done"
        if @variables.attempt_count >= 3 and @variables.guest_services_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for reservation issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the reservation issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the reservation interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the reservation request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Reservation status: {! @variables.reservation_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.reservation_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.reservation_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.reservation_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.reservation_status = "escalated"
        set @variables.escalation_requested = False

