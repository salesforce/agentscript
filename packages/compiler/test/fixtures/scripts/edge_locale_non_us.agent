# Non-US default locale with all additional locales
system:
    instructions: "Vous etes un agent de service client francais."
    messages:
        welcome: "Bonjour! Comment puis-je vous aider?"
        error: "Desole, une erreur s'est produite."

config:
    agent_name: "French_Agent"
    agent_type: "AgentforceServiceAgent"
    developer_name: "French_Agent"
    description: "Agent with French default locale"

language:
    default_locale: "fr"
    all_additional_locales: True

start_agent main:
    description: "Point d'entree pour l'agent francais"
    reasoning:
        instructions: ->
            | Traiter la demande de l'utilisateur en francais
