# Multiple additional locales
system:
    instructions: "You are a multilingual agent supporting multiple languages."
    messages:
        welcome: "Welcome! We support multiple languages."
        error: "An error occurred."

config:
    agent_name: "Multi_Locale_Agent"
    agent_type: "AgentforceServiceAgent"
    developer_name: "Multi_Locale_Agent"
    description: "Agent with multiple additional locales"

language:
    default_locale: "en_US"
    additional_locales: "fr, de, es, ja, zh_CN, pt_BR, it, ko"

start_agent main:
    description: "Multi-locale entry point"
    reasoning:
        instructions: ->
            | Process the user request in their preferred language
