system:
    instructions: "You are a helpful AI assistant."

config:
    agent_name: "ConditionalRuntimeTest"
    agent_type: "AgentforceServiceAgent"
    default_agent_user: "service_user"

variables:
    x: mutable boolean = True

start_agent test_conditional:
    description: "Test conditional runtime evaluation"
    before_reasoning:
        if @variables.x == True:
            set @variables.x = False
        else:
            set @variables.x = True
    reasoning:
        instructions: ->
            | Please help the user
