system:
    instructions: "You are a helpful assistant that handles conditional logic."
    messages:
        welcome: "Hello! How can I help?"
        error: "Something went wrong."

config:
    developer_name: "Edge_Cond_If_Else"
    default_agent_user: "test_user"
    description: "Tests basic if/else in before_reasoning"

variables:
    x: mutable boolean = True
    status_message: mutable string = ""

start_agent main:
    description: "Tests if/else conditional in before_reasoning"

    before_reasoning:
        if @variables.x == True:
            set @variables.status_message = "x is true"
        else:
            set @variables.status_message = "x is false"

    reasoning:
        instructions: ->
            | Help the user based on the current status.
              Status: {! @variables.status_message }
