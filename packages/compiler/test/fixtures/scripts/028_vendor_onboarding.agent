system:
    instructions: |
        You are a professional vendor onboarding specialist assistant.
        Help users manage their vendor requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: application -> compliance_check -> contract_setup -> activation.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Vendor Onboarding Specialist Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "vendor_onboarding_agent_v28"
    default_agent_user: "vendor_onboarding@example.com"
    agent_description: "Assists users with vendor management through the vendor onboarding specialist workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    vendor_record_id: mutable string
        description: "Record ID of the vendor"
    vendor_status: mutable string = ""
        description: "Current status of the vendor"
    vendor_tier: mutable string = "standard"
        description: "Tier classification for the vendor"
    vendor_category: mutable string = ""
        description: "Category of the vendor"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    application_complete: mutable boolean = False
        description: "Whether the application stage is complete"
    application_result: mutable string = ""
        description: "Result from the application stage"
    compliance_check_complete: mutable boolean = False
        description: "Whether the compliance_check stage is complete"
    compliance_check_result: mutable string = ""
        description: "Result from the compliance_check stage"
    contract_setup_complete: mutable boolean = False
        description: "Whether the contract_setup stage is complete"
    contract_setup_result: mutable string = ""
        description: "Result from the contract_setup stage"
    activation_complete: mutable boolean = False
        description: "Whether the activation stage is complete"
    activation_result: mutable string = ""
        description: "Result from the activation stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate vendor management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a vendor onboarding specialist assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current vendor status: {! @variables.vendor_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_application} for application requests.
              Use {!@actions.go_to_compliance_check} for compliance check requests.
              Use {!@actions.go_to_contract_setup} for contract setup requests.
              Use {!@actions.go_to_activation} for activation requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_application: @utils.transition to @topic.application
                description: "Transition to application topic."
            go_to_compliance_check: @utils.transition to @topic.compliance_check
                description: "Transition to compliance check topic."
                available when @variables.is_verified == True
            go_to_contract_setup: @utils.transition to @topic.contract_setup
                description: "Transition to contract setup topic."
                available when @variables.is_verified == True
            go_to_activation: @utils.transition to @topic.activation
                description: "Transition to activation topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic application:
    description: "Handles the application stage of the vendor process"

    actions:
        process_application_data:
            description: "Process application stage data for the vendor"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_Application_Data"

        validate_application_info:
            description: "Validate application information for the vendor"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Application_Info"

        fetch_application_details:
            description: "Fetch application details for the vendor"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Application_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_application_info
                with record_ref=@variables.vendor_record_id
                with contact_ref=@variables.contact_email
                set @variables.vendor_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the application stage for the vendor.
              Current vendor status: {! @variables.vendor_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Application result: {! @variables.application_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.vendor_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_application} to begin processing.
        actions:
            run_application: @actions.process_application_data
                with record_ref=@variables.vendor_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.vendor_category
                set @variables.application_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.application_complete = @outputs.is_passed
            fetch_application_info: @actions.fetch_application_details
                with record_ref=@variables.vendor_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.vendor_tier = @outputs.tier_value
            go_to_compliance_check: @utils.transition to @topic.compliance_check
                description: "Move to compliance check stage."
                available when @variables.application_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.vendor_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.vendor_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.vendor_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.application_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic compliance_check:
    description: "Handles the compliance check stage of the vendor process"

    actions:
        process_compliance_check_data:
            description: "Process compliance check stage data for the vendor"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_ComplianceCheck"

        validate_compliance_check_info:
            description: "Validate compliance check information for the vendor"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_ComplianceCheck_Info"

        fetch_compliance_check_details:
            description: "Fetch compliance check details for the vendor"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_ComplianceCheck_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.application_complete == False:
            transition to @topic.application

    reasoning:
        instructions: ->
            | Handle the compliance check stage for the vendor.
              Current vendor status: {! @variables.vendor_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Compliance Check result: {! @variables.compliance_check_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.vendor_tier }
              Review the compliance check results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_compliance_check: @actions.process_compliance_check_data
                with record_ref=@variables.vendor_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.vendor_category
                set @variables.compliance_check_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.compliance_check_complete = @outputs.is_passed
            fetch_compliance_check_info: @actions.fetch_compliance_check_details
                with record_ref=@variables.vendor_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.vendor_tier = @outputs.tier_value
                available when @variables.vendor_record_id is not None
            go_to_contract_setup: @utils.transition to @topic.contract_setup
                description: "Move to contract setup stage."
                available when @variables.compliance_check_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.compliance_check_complete == True:
            set @variables.vendor_status = "compliance_check_done"
        if @variables.compliance_check_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.contract_setup
        if @variables.attempt_count >= 3 and @variables.compliance_check_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic contract_setup:
    description: "Handles the contract setup stage of the vendor process"

    actions:
        process_contract_setup_data:
            description: "Process contract setup stage data for the vendor"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_ContractSetup"

        validate_contract_setup_info:
            description: "Validate contract setup information for the vendor"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_ContractSetup_Info"

        fetch_contract_setup_details:
            description: "Fetch contract setup details for the vendor"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_ContractSetup_Details"

    before_reasoning:
        if @variables.contract_setup_complete == False:
            run @actions.fetch_contract_setup_details
                with record_ref=@variables.vendor_record_id
                with include_history=True
                set @variables.contract_setup_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.vendor_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.vendor_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.vendor_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the contract setup stage for the vendor.
              Current vendor status: {! @variables.vendor_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Contract Setup result: {! @variables.contract_setup_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.vendor_tier }
              Review the contract setup results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_contract_setup: @actions.process_contract_setup_data
                with record_ref=@variables.vendor_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.vendor_category
                set @variables.contract_setup_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.contract_setup_complete = @outputs.is_passed
            fetch_contract_setup_info: @actions.fetch_contract_setup_details
                with record_ref=@variables.vendor_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.vendor_tier = @outputs.tier_value
                available when @variables.vendor_record_id is not None
            go_to_activation: @utils.transition to @topic.activation
                description: "Move to activation stage."
                available when @variables.contract_setup_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.vendor_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.vendor_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.vendor_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.contract_setup_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic activation:
    description: "Handles the activation stage of the vendor process"

    actions:
        process_activation_data:
            description: "Process activation stage data for the vendor"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_Activation_Data"

        validate_activation_info:
            description: "Validate activation information for the vendor"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Activation_Info"

        fetch_activation_details:
            description: "Fetch activation details for the vendor"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Activation_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.contract_setup_complete == False:
            transition to @topic.contract_setup
        if @variables.eligibility_score >= 80:
            set @variables.vendor_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.vendor_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the activation stage for the vendor.
              Current vendor status: {! @variables.vendor_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Activation result: {! @variables.activation_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.vendor_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_activation: @actions.process_activation_data
                with record_ref=@variables.vendor_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.vendor_category
                set @variables.activation_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.activation_complete = @outputs.is_passed
            fetch_activation_info: @actions.fetch_activation_details
                with record_ref=@variables.vendor_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.vendor_tier = @outputs.tier_value
                available when @variables.vendor_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.activation_complete == True:
            set @variables.vendor_status = "activation_done"
        if @variables.attempt_count >= 3 and @variables.activation_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for vendor issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the vendor issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the vendor interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the vendor request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Vendor status: {! @variables.vendor_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.vendor_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.vendor_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.vendor_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.vendor_status = "escalated"
        set @variables.escalation_requested = False

