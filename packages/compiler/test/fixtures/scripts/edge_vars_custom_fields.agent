# Variables with Salesforce custom field names
system:
    instructions: "You are an agent for testing custom field variable names."

config:
    agent_type: "AgentforceServiceAgent"
    developer_name: "Custom_Fields_Agent"
    description: "Agent with custom field variable names"

variables:
    Customer_Tier_c: mutable string = "Standard"
        description: "Customer tier custom field"
    Loyalty_Points_c: mutable number = 0
        description: "Loyalty points custom field"
    Is_Premium_c: mutable boolean = False
        description: "Premium status custom field"
    Last_Interaction_c: mutable string = ""
        description: "Last interaction date custom field"
    Preferred_Channel_c: mutable string = "email"
        description: "Preferred contact channel"
    Account_Region_c: mutable string = ""
        description: "Account region custom field"
    Support_Plan_c: mutable string = "Basic"
        description: "Support plan custom field"
    Custom_Object_c: mutable object = None
        description: "Custom object data"

start_agent main:
    description: "Process using custom field variables"
    reasoning:
        instructions: ->
            | Check the customer tier and loyalty points
