config:
  agent_name: "EscalationRouter"
  agent_type: "AgentforceServiceAgent"
  default_agent_user: "service_user"

system:
  instructions: "You are a support coordinator."

start_agent Triage:
  description: "Main orchestrator"
  reasoning:
    instructions: ->
      | Route requests.

connected_subagent Bad_Agent:
  target: "agent://Bad_Agent"
  label: "Bad Agent"
  description: "This uses an invalid value for delegate_escalation"
  delegate_escalation: "yes"
