system:
    instructions: |
        You are a professional gift registry assistant assistant.
        Help users manage their registry requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: creation -> item_management -> sharing -> purchase_tracking.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Gift Registry Assistant Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "gift_registry_agent_v26"
    default_agent_user: "gift_registry@example.com"
    agent_description: "Assists users with registry management through the gift registry assistant workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    registry_record_id: mutable string
        description: "Record ID of the registry"
    registry_status: mutable string = ""
        description: "Current status of the registry"
    registry_tier: mutable string = "standard"
        description: "Tier classification for the registry"
    registry_category: mutable string = ""
        description: "Category of the registry"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    creation_complete: mutable boolean = False
        description: "Whether the creation stage is complete"
    creation_result: mutable string = ""
        description: "Result from the creation stage"
    item_management_complete: mutable boolean = False
        description: "Whether the item_management stage is complete"
    item_management_result: mutable string = ""
        description: "Result from the item_management stage"
    sharing_complete: mutable boolean = False
        description: "Whether the sharing stage is complete"
    sharing_result: mutable string = ""
        description: "Result from the sharing stage"
    purchase_tracking_complete: mutable boolean = False
        description: "Whether the purchase_tracking stage is complete"
    purchase_tracking_result: mutable string = ""
        description: "Result from the purchase_tracking stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate registry management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a gift registry assistant assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current registry status: {! @variables.registry_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_creation} for creation requests.
              Use {!@actions.go_to_item_management} for item management requests.
              Use {!@actions.go_to_sharing} for sharing requests.
              Use {!@actions.go_to_purchase_tracking} for purchase tracking requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_creation: @utils.transition to @topic.creation
                description: "Transition to creation topic."
            go_to_item_management: @utils.transition to @topic.item_management
                description: "Transition to item management topic."
                available when @variables.is_verified == True
            go_to_sharing: @utils.transition to @topic.sharing
                description: "Transition to sharing topic."
                available when @variables.is_verified == True
            go_to_purchase_tracking: @utils.transition to @topic.purchase_tracking
                description: "Transition to purchase tracking topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic creation:
    description: "Handles the creation stage of the registry process"

    actions:
        process_creation_data:
            description: "Process creation stage data for the registry"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_Creation"

        validate_creation_info:
            description: "Validate creation information for the registry"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Creation_Info"

        fetch_creation_details:
            description: "Fetch creation details for the registry"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Creation_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_creation_info
                with record_ref=@variables.registry_record_id
                with contact_ref=@variables.contact_email
                set @variables.registry_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the creation stage for the registry.
              Current registry status: {! @variables.registry_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Creation result: {! @variables.creation_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.registry_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_creation} to begin processing.
        actions:
            run_creation: @actions.process_creation_data
                with record_ref=@variables.registry_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.registry_category
                set @variables.creation_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.creation_complete = @outputs.is_passed
            fetch_creation_info: @actions.fetch_creation_details
                with record_ref=@variables.registry_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.registry_tier = @outputs.tier_value
            go_to_item_management: @utils.transition to @topic.item_management
                description: "Move to item management stage."
                available when @variables.creation_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.registry_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.registry_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.registry_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.creation_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic item_management:
    description: "Handles the item management stage of the registry process"

    actions:
        process_item_management_data:
            description: "Process item management stage data for the registry"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_ItemManagement"

        validate_item_management_info:
            description: "Validate item management information for the registry"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_ItemManagement_Info"

        fetch_item_management_details:
            description: "Fetch item management details for the registry"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_ItemManagement_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.creation_complete == False:
            transition to @topic.creation

    reasoning:
        instructions: ->
            | Handle the item management stage for the registry.
              Current registry status: {! @variables.registry_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Item Management result: {! @variables.item_management_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.registry_tier }
              Review the item management results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_item_management: @actions.process_item_management_data
                with record_ref=@variables.registry_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.registry_category
                set @variables.item_management_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.item_management_complete = @outputs.is_passed
            fetch_item_management_info: @actions.fetch_item_management_details
                with record_ref=@variables.registry_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.registry_tier = @outputs.tier_value
                available when @variables.registry_record_id is not None
            go_to_sharing: @utils.transition to @topic.sharing
                description: "Move to sharing stage."
                available when @variables.item_management_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.item_management_complete == True:
            set @variables.registry_status = "item_management_done"
        if @variables.item_management_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.sharing
        if @variables.attempt_count >= 3 and @variables.item_management_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic sharing:
    description: "Handles the sharing stage of the registry process"

    actions:
        process_sharing_data:
            description: "Process sharing stage data for the registry"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_Sharing_Data"

        validate_sharing_info:
            description: "Validate sharing information for the registry"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Sharing_Info"

        fetch_sharing_details:
            description: "Fetch sharing details for the registry"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Sharing_Details"

    before_reasoning:
        if @variables.sharing_complete == False:
            run @actions.fetch_sharing_details
                with record_ref=@variables.registry_record_id
                with include_history=True
                set @variables.sharing_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.registry_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.registry_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.registry_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the sharing stage for the registry.
              Current registry status: {! @variables.registry_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Sharing result: {! @variables.sharing_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.registry_tier }
              Review the sharing results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_sharing: @actions.process_sharing_data
                with record_ref=@variables.registry_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.registry_category
                set @variables.sharing_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.sharing_complete = @outputs.is_passed
            fetch_sharing_info: @actions.fetch_sharing_details
                with record_ref=@variables.registry_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.registry_tier = @outputs.tier_value
                available when @variables.registry_record_id is not None
            go_to_purchase_tracking: @utils.transition to @topic.purchase_tracking
                description: "Move to purchase tracking stage."
                available when @variables.sharing_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.registry_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.registry_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.registry_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.sharing_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic purchase_tracking:
    description: "Handles the purchase tracking stage of the registry process"

    actions:
        process_purchase_tracking_data:
            description: "Process purchase tracking stage data for the registry"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_PurchaseTracking"

        validate_purchase_tracking_info:
            description: "Validate purchase tracking information for the registry"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_PurchaseTracking_Info"

        fetch_purchase_tracking_details:
            description: "Fetch purchase tracking details for the registry"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_PurchaseTracking_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.sharing_complete == False:
            transition to @topic.sharing
        if @variables.eligibility_score >= 80:
            set @variables.registry_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.registry_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the purchase tracking stage for the registry.
              Current registry status: {! @variables.registry_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Purchase Tracking result: {! @variables.purchase_tracking_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.registry_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_purchase_tracking: @actions.process_purchase_tracking_data
                with record_ref=@variables.registry_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.registry_category
                set @variables.purchase_tracking_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.purchase_tracking_complete = @outputs.is_passed
            fetch_purchase_tracking_info: @actions.fetch_purchase_tracking_details
                with record_ref=@variables.registry_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.registry_tier = @outputs.tier_value
                available when @variables.registry_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.purchase_tracking_complete == True:
            set @variables.registry_status = "purchase_tracking_done"
        if @variables.attempt_count >= 3 and @variables.purchase_tracking_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for registry issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the registry issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the registry interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the registry request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Registry status: {! @variables.registry_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.registry_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.registry_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.registry_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.registry_status = "escalated"
        set @variables.escalation_requested = False

