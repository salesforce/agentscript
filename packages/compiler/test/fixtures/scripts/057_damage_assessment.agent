system:
    instructions: |
        You are a professional damage assessment specialist assistant.
        Help users manage their damage requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: report_intake -> photo_review -> cost_estimation -> approval.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Damage Assessment Specialist Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "damage_assessment_agent_v57"
    default_agent_user: "damage_assessment@example.com"
    agent_description: "Assists users with damage management through the damage assessment specialist workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    damage_record_id: mutable string
        description: "Record ID of the damage"
    damage_status: mutable string = ""
        description: "Current status of the damage"
    damage_tier: mutable string = "standard"
        description: "Tier classification for the damage"
    damage_category: mutable string = ""
        description: "Category of the damage"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    report_intake_complete: mutable boolean = False
        description: "Whether the report_intake stage is complete"
    report_intake_result: mutable string = ""
        description: "Result from the report_intake stage"
    photo_review_complete: mutable boolean = False
        description: "Whether the photo_review stage is complete"
    photo_review_result: mutable string = ""
        description: "Result from the photo_review stage"
    cost_estimation_complete: mutable boolean = False
        description: "Whether the cost_estimation stage is complete"
    cost_estimation_result: mutable string = ""
        description: "Result from the cost_estimation stage"
    approval_complete: mutable boolean = False
        description: "Whether the approval stage is complete"
    approval_result: mutable string = ""
        description: "Result from the approval stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate damage management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a damage assessment specialist assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current damage status: {! @variables.damage_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_report_intake} for report intake requests.
              Use {!@actions.go_to_photo_review} for photo review requests.
              Use {!@actions.go_to_cost_estimation} for cost estimation requests.
              Use {!@actions.go_to_approval} for approval requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_report_intake: @utils.transition to @topic.report_intake
                description: "Transition to report intake topic."
            go_to_photo_review: @utils.transition to @topic.photo_review
                description: "Transition to photo review topic."
                available when @variables.is_verified == True
            go_to_cost_estimation: @utils.transition to @topic.cost_estimation
                description: "Transition to cost estimation topic."
                available when @variables.is_verified == True
            go_to_approval: @utils.transition to @topic.approval
                description: "Transition to approval topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic report_intake:
    description: "Handles the report intake stage of the damage process"

    actions:
        process_report_intake_data:
            description: "Process report intake stage data for the damage"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_ReportIntake"

        validate_report_intake_info:
            description: "Validate report intake information for the damage"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_ReportIntake_Info"

        fetch_report_intake_details:
            description: "Fetch report intake details for the damage"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_ReportIntake_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_report_intake_info
                with record_ref=@variables.damage_record_id
                with contact_ref=@variables.contact_email
                set @variables.damage_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the report intake stage for the damage.
              Current damage status: {! @variables.damage_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Report Intake result: {! @variables.report_intake_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.damage_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_report_intake} to begin processing.
        actions:
            run_report_intake: @actions.process_report_intake_data
                with record_ref=@variables.damage_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.damage_category
                set @variables.report_intake_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.report_intake_complete = @outputs.is_passed
            fetch_report_intake_info: @actions.fetch_report_intake_details
                with record_ref=@variables.damage_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.damage_tier = @outputs.tier_value
            go_to_photo_review: @utils.transition to @topic.photo_review
                description: "Move to photo review stage."
                available when @variables.report_intake_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.damage_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.damage_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.damage_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.report_intake_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic photo_review:
    description: "Handles the photo review stage of the damage process"

    actions:
        process_photo_review_data:
            description: "Process photo review stage data for the damage"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_PhotoReview_Data"

        validate_photo_review_info:
            description: "Validate photo review information for the damage"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_PhotoReview_Info"

        fetch_photo_review_details:
            description: "Fetch photo review details for the damage"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_PhotoReview_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.report_intake_complete == False:
            transition to @topic.report_intake

    reasoning:
        instructions: ->
            | Handle the photo review stage for the damage.
              Current damage status: {! @variables.damage_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Photo Review result: {! @variables.photo_review_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.damage_tier }
              Review the photo review results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_photo_review: @actions.process_photo_review_data
                with record_ref=@variables.damage_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.damage_category
                set @variables.photo_review_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.photo_review_complete = @outputs.is_passed
            fetch_photo_review_info: @actions.fetch_photo_review_details
                with record_ref=@variables.damage_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.damage_tier = @outputs.tier_value
                available when @variables.damage_record_id is not None
            go_to_cost_estimation: @utils.transition to @topic.cost_estimation
                description: "Move to cost estimation stage."
                available when @variables.photo_review_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.photo_review_complete == True:
            set @variables.damage_status = "photo_review_done"
        if @variables.photo_review_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.cost_estimation
        if @variables.attempt_count >= 3 and @variables.photo_review_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic cost_estimation:
    description: "Handles the cost estimation stage of the damage process"

    actions:
        process_cost_estimation_data:
            description: "Process cost estimation stage data for the damage"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_CostEstimation"

        validate_cost_estimation_info:
            description: "Validate cost estimation information for the damage"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_CostEstimation_Info"

        fetch_cost_estimation_details:
            description: "Fetch cost estimation details for the damage"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_CostEstimation_Details"

    before_reasoning:
        if @variables.cost_estimation_complete == False:
            run @actions.fetch_cost_estimation_details
                with record_ref=@variables.damage_record_id
                with include_history=True
                set @variables.cost_estimation_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.damage_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.damage_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.damage_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the cost estimation stage for the damage.
              Current damage status: {! @variables.damage_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Cost Estimation result: {! @variables.cost_estimation_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.damage_tier }
              Review the cost estimation results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_cost_estimation: @actions.process_cost_estimation_data
                with record_ref=@variables.damage_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.damage_category
                set @variables.cost_estimation_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.cost_estimation_complete = @outputs.is_passed
            fetch_cost_estimation_info: @actions.fetch_cost_estimation_details
                with record_ref=@variables.damage_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.damage_tier = @outputs.tier_value
                available when @variables.damage_record_id is not None
            go_to_approval: @utils.transition to @topic.approval
                description: "Move to approval stage."
                available when @variables.cost_estimation_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.damage_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.damage_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.damage_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.cost_estimation_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic approval:
    description: "Handles the approval stage of the damage process"

    actions:
        process_approval_data:
            description: "Process approval stage data for the damage"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_Approval"

        validate_approval_info:
            description: "Validate approval information for the damage"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Approval_Info"

        fetch_approval_details:
            description: "Fetch approval details for the damage"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Approval_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.cost_estimation_complete == False:
            transition to @topic.cost_estimation
        if @variables.eligibility_score >= 80:
            set @variables.damage_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.damage_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the approval stage for the damage.
              Current damage status: {! @variables.damage_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Approval result: {! @variables.approval_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.damage_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_approval: @actions.process_approval_data
                with record_ref=@variables.damage_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.damage_category
                set @variables.approval_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.approval_complete = @outputs.is_passed
            fetch_approval_info: @actions.fetch_approval_details
                with record_ref=@variables.damage_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.damage_tier = @outputs.tier_value
                available when @variables.damage_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.approval_complete == True:
            set @variables.damage_status = "approval_done"
        if @variables.attempt_count >= 3 and @variables.approval_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for damage issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the damage issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the damage interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the damage request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Damage status: {! @variables.damage_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.damage_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.damage_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.damage_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.damage_status = "escalated"
        set @variables.escalation_requested = False

