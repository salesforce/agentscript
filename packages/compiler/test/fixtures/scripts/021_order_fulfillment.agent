system:
    instructions: |
        You are a professional order fulfillment specialist assistant.
        Help users manage their order requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: validation -> picking -> packing -> shipment.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Order Fulfillment Specialist Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "order_fulfillment_agent_v21"
    default_agent_user: "order_fulfillment@example.com"
    agent_description: "Assists users with order management through the order fulfillment specialist workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    order_record_id: mutable string
        description: "Record ID of the order"
    order_status: mutable string = ""
        description: "Current status of the order"
    order_tier: mutable string = "standard"
        description: "Tier classification for the order"
    order_category: mutable string = ""
        description: "Category of the order"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    validation_complete: mutable boolean = False
        description: "Whether the validation stage is complete"
    validation_result: mutable string = ""
        description: "Result from the validation stage"
    picking_complete: mutable boolean = False
        description: "Whether the picking stage is complete"
    picking_result: mutable string = ""
        description: "Result from the picking stage"
    packing_complete: mutable boolean = False
        description: "Whether the packing stage is complete"
    packing_result: mutable string = ""
        description: "Result from the packing stage"
    shipment_complete: mutable boolean = False
        description: "Whether the shipment stage is complete"
    shipment_result: mutable string = ""
        description: "Result from the shipment stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate order management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a order fulfillment specialist assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current order status: {! @variables.order_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_validation} for validation requests.
              Use {!@actions.go_to_picking} for picking requests.
              Use {!@actions.go_to_packing} for packing requests.
              Use {!@actions.go_to_shipment} for shipment requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_validation: @utils.transition to @topic.validation
                description: "Transition to validation topic."
            go_to_picking: @utils.transition to @topic.picking
                description: "Transition to picking topic."
                available when @variables.is_verified == True
            go_to_packing: @utils.transition to @topic.packing
                description: "Transition to packing topic."
                available when @variables.is_verified == True
            go_to_shipment: @utils.transition to @topic.shipment
                description: "Transition to shipment topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic validation:
    description: "Handles the validation stage of the order process"

    actions:
        process_validation_data:
            description: "Process validation stage data for the order"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_Validation"

        validate_validation_info:
            description: "Validate validation information for the order"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Validation_Info"

        fetch_validation_details:
            description: "Fetch validation details for the order"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Validation_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_validation_info
                with record_ref=@variables.order_record_id
                with contact_ref=@variables.contact_email
                set @variables.order_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the validation stage for the order.
              Current order status: {! @variables.order_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Validation result: {! @variables.validation_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.order_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_validation} to begin processing.
        actions:
            run_validation: @actions.process_validation_data
                with record_ref=@variables.order_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.order_category
                set @variables.validation_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.validation_complete = @outputs.is_passed
            fetch_validation_info: @actions.fetch_validation_details
                with record_ref=@variables.order_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.order_tier = @outputs.tier_value
            go_to_picking: @utils.transition to @topic.picking
                description: "Move to picking stage."
                available when @variables.validation_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.order_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.order_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.order_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.validation_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic picking:
    description: "Handles the picking stage of the order process"

    actions:
        process_picking_data:
            description: "Process picking stage data for the order"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_Picking_Data"

        validate_picking_info:
            description: "Validate picking information for the order"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Picking_Info"

        fetch_picking_details:
            description: "Fetch picking details for the order"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Picking_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.validation_complete == False:
            transition to @topic.validation

    reasoning:
        instructions: ->
            | Handle the picking stage for the order.
              Current order status: {! @variables.order_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Picking result: {! @variables.picking_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.order_tier }
              Review the picking results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_picking: @actions.process_picking_data
                with record_ref=@variables.order_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.order_category
                set @variables.picking_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.picking_complete = @outputs.is_passed
            fetch_picking_info: @actions.fetch_picking_details
                with record_ref=@variables.order_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.order_tier = @outputs.tier_value
                available when @variables.order_record_id is not None
            go_to_packing: @utils.transition to @topic.packing
                description: "Move to packing stage."
                available when @variables.picking_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.picking_complete == True:
            set @variables.order_status = "picking_done"
        if @variables.picking_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.packing
        if @variables.attempt_count >= 3 and @variables.picking_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic packing:
    description: "Handles the packing stage of the order process"

    actions:
        process_packing_data:
            description: "Process packing stage data for the order"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_Packing"

        validate_packing_info:
            description: "Validate packing information for the order"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Packing_Info"

        fetch_packing_details:
            description: "Fetch packing details for the order"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Packing_Details"

    before_reasoning:
        if @variables.packing_complete == False:
            run @actions.fetch_packing_details
                with record_ref=@variables.order_record_id
                with include_history=True
                set @variables.packing_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.order_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.order_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.order_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the packing stage for the order.
              Current order status: {! @variables.order_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Packing result: {! @variables.packing_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.order_tier }
              Review the packing results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_packing: @actions.process_packing_data
                with record_ref=@variables.order_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.order_category
                set @variables.packing_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.packing_complete = @outputs.is_passed
            fetch_packing_info: @actions.fetch_packing_details
                with record_ref=@variables.order_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.order_tier = @outputs.tier_value
                available when @variables.order_record_id is not None
            go_to_shipment: @utils.transition to @topic.shipment
                description: "Move to shipment stage."
                available when @variables.packing_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.order_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.order_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.order_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.packing_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic shipment:
    description: "Handles the shipment stage of the order process"

    actions:
        process_shipment_data:
            description: "Process shipment stage data for the order"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_Shipment"

        validate_shipment_info:
            description: "Validate shipment information for the order"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Shipment_Info"

        fetch_shipment_details:
            description: "Fetch shipment details for the order"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Shipment_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.packing_complete == False:
            transition to @topic.packing
        if @variables.eligibility_score >= 80:
            set @variables.order_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.order_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the shipment stage for the order.
              Current order status: {! @variables.order_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Shipment result: {! @variables.shipment_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.order_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_shipment: @actions.process_shipment_data
                with record_ref=@variables.order_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.order_category
                set @variables.shipment_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.shipment_complete = @outputs.is_passed
            fetch_shipment_info: @actions.fetch_shipment_details
                with record_ref=@variables.order_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.order_tier = @outputs.tier_value
                available when @variables.order_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.shipment_complete == True:
            set @variables.order_status = "shipment_done"
        if @variables.attempt_count >= 3 and @variables.shipment_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for order issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the order issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the order interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the order request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Order status: {! @variables.order_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.order_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.order_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.order_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.order_status = "escalated"
        set @variables.escalation_requested = False

