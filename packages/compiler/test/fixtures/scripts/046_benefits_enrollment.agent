system:
    instructions: |
        You are a professional benefits enrollment assistant assistant.
        Help users manage their enrollment requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: eligibility_review -> plan_comparison -> selection -> confirmation.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Benefits Enrollment Assistant Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "benefits_enrollment_agent_v46"
    default_agent_user: "benefits_enrollment@example.com"
    agent_description: "Assists users with enrollment management through the benefits enrollment assistant workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    enrollment_record_id: mutable string
        description: "Record ID of the enrollment"
    enrollment_status: mutable string = ""
        description: "Current status of the enrollment"
    enrollment_tier: mutable string = "standard"
        description: "Tier classification for the enrollment"
    enrollment_category: mutable string = ""
        description: "Category of the enrollment"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    eligibility_review_complete: mutable boolean = False
        description: "Whether the eligibility_review stage is complete"
    eligibility_review_result: mutable string = ""
        description: "Result from the eligibility_review stage"
    plan_comparison_complete: mutable boolean = False
        description: "Whether the plan_comparison stage is complete"
    plan_comparison_result: mutable string = ""
        description: "Result from the plan_comparison stage"
    selection_complete: mutable boolean = False
        description: "Whether the selection stage is complete"
    selection_result: mutable string = ""
        description: "Result from the selection stage"
    confirmation_complete: mutable boolean = False
        description: "Whether the confirmation stage is complete"
    confirmation_result: mutable string = ""
        description: "Result from the confirmation stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate enrollment management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a benefits enrollment assistant assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current enrollment status: {! @variables.enrollment_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_eligibility_review} for eligibility review requests.
              Use {!@actions.go_to_plan_comparison} for plan comparison requests.
              Use {!@actions.go_to_selection} for selection requests.
              Use {!@actions.go_to_confirmation} for confirmation requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_eligibility_review: @utils.transition to @topic.eligibility_review
                description: "Transition to eligibility review topic."
            go_to_plan_comparison: @utils.transition to @topic.plan_comparison
                description: "Transition to plan comparison topic."
                available when @variables.is_verified == True
            go_to_selection: @utils.transition to @topic.selection
                description: "Transition to selection topic."
                available when @variables.is_verified == True
            go_to_confirmation: @utils.transition to @topic.confirmation
                description: "Transition to confirmation topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic eligibility_review:
    description: "Handles the eligibility review stage of the enrollment process"

    actions:
        process_eligibility_review_data:
            description: "Process eligibility review stage data for the enrollment"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_EligibilityReview_Data"

        validate_eligibility_review_info:
            description: "Validate eligibility review information for the enrollment"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_EligibilityReview_Info"

        fetch_eligibility_review_details:
            description: "Fetch eligibility review details for the enrollment"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_EligibilityReview_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_eligibility_review_info
                with record_ref=@variables.enrollment_record_id
                with contact_ref=@variables.contact_email
                set @variables.enrollment_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the eligibility review stage for the enrollment.
              Current enrollment status: {! @variables.enrollment_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Eligibility Review result: {! @variables.eligibility_review_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.enrollment_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_eligibility_review} to begin processing.
        actions:
            run_eligibility_review: @actions.process_eligibility_review_data
                with record_ref=@variables.enrollment_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.enrollment_category
                set @variables.eligibility_review_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.eligibility_review_complete = @outputs.is_passed
            fetch_eligibility_review_info: @actions.fetch_eligibility_review_details
                with record_ref=@variables.enrollment_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.enrollment_tier = @outputs.tier_value
            go_to_plan_comparison: @utils.transition to @topic.plan_comparison
                description: "Move to plan comparison stage."
                available when @variables.eligibility_review_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.enrollment_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.enrollment_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.enrollment_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.eligibility_review_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic plan_comparison:
    description: "Handles the plan comparison stage of the enrollment process"

    actions:
        process_plan_comparison_data:
            description: "Process plan comparison stage data for the enrollment"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_PlanComparison"

        validate_plan_comparison_info:
            description: "Validate plan comparison information for the enrollment"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_PlanComparison_Info"

        fetch_plan_comparison_details:
            description: "Fetch plan comparison details for the enrollment"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_PlanComparison_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.eligibility_review_complete == False:
            transition to @topic.eligibility_review

    reasoning:
        instructions: ->
            | Handle the plan comparison stage for the enrollment.
              Current enrollment status: {! @variables.enrollment_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Plan Comparison result: {! @variables.plan_comparison_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.enrollment_tier }
              Review the plan comparison results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_plan_comparison: @actions.process_plan_comparison_data
                with record_ref=@variables.enrollment_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.enrollment_category
                set @variables.plan_comparison_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.plan_comparison_complete = @outputs.is_passed
            fetch_plan_comparison_info: @actions.fetch_plan_comparison_details
                with record_ref=@variables.enrollment_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.enrollment_tier = @outputs.tier_value
                available when @variables.enrollment_record_id is not None
            go_to_selection: @utils.transition to @topic.selection
                description: "Move to selection stage."
                available when @variables.plan_comparison_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.plan_comparison_complete == True:
            set @variables.enrollment_status = "plan_comparison_done"
        if @variables.plan_comparison_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.selection
        if @variables.attempt_count >= 3 and @variables.plan_comparison_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic selection:
    description: "Handles the selection stage of the enrollment process"

    actions:
        process_selection_data:
            description: "Process selection stage data for the enrollment"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_Selection"

        validate_selection_info:
            description: "Validate selection information for the enrollment"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Selection_Info"

        fetch_selection_details:
            description: "Fetch selection details for the enrollment"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Selection_Details"

    before_reasoning:
        if @variables.selection_complete == False:
            run @actions.fetch_selection_details
                with record_ref=@variables.enrollment_record_id
                with include_history=True
                set @variables.selection_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.enrollment_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.enrollment_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.enrollment_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the selection stage for the enrollment.
              Current enrollment status: {! @variables.enrollment_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Selection result: {! @variables.selection_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.enrollment_tier }
              Review the selection results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_selection: @actions.process_selection_data
                with record_ref=@variables.enrollment_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.enrollment_category
                set @variables.selection_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.selection_complete = @outputs.is_passed
            fetch_selection_info: @actions.fetch_selection_details
                with record_ref=@variables.enrollment_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.enrollment_tier = @outputs.tier_value
                available when @variables.enrollment_record_id is not None
            go_to_confirmation: @utils.transition to @topic.confirmation
                description: "Move to confirmation stage."
                available when @variables.selection_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.enrollment_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.enrollment_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.enrollment_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.selection_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic confirmation:
    description: "Handles the confirmation stage of the enrollment process"

    actions:
        process_confirmation_data:
            description: "Process confirmation stage data for the enrollment"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_Confirmation_Data"

        validate_confirmation_info:
            description: "Validate confirmation information for the enrollment"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Confirmation_Info"

        fetch_confirmation_details:
            description: "Fetch confirmation details for the enrollment"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Confirmation_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.selection_complete == False:
            transition to @topic.selection
        if @variables.eligibility_score >= 80:
            set @variables.enrollment_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.enrollment_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the confirmation stage for the enrollment.
              Current enrollment status: {! @variables.enrollment_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Confirmation result: {! @variables.confirmation_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.enrollment_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_confirmation: @actions.process_confirmation_data
                with record_ref=@variables.enrollment_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.enrollment_category
                set @variables.confirmation_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.confirmation_complete = @outputs.is_passed
            fetch_confirmation_info: @actions.fetch_confirmation_details
                with record_ref=@variables.enrollment_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.enrollment_tier = @outputs.tier_value
                available when @variables.enrollment_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.confirmation_complete == True:
            set @variables.enrollment_status = "confirmation_done"
        if @variables.attempt_count >= 3 and @variables.confirmation_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for enrollment issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the enrollment issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the enrollment interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the enrollment request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Enrollment status: {! @variables.enrollment_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.enrollment_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.enrollment_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.enrollment_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.enrollment_status = "escalated"
        set @variables.escalation_requested = False

