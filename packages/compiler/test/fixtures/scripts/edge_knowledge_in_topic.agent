system:
    instructions: "You are a support assistant with knowledge base access."
    messages:
        welcome: "Welcome to support!"
        error: "Something went wrong."

config:
    developer_name: "Edge_Knowledge_In_Topic"
    default_agent_user: "test_user"
    description: "Tests global knowledge block referenced from topic actions"

variables:
    query: mutable string = ""
    search_result: mutable string = ""

knowledge:
    citations_enabled: True
    citations_url: "https://support.example.com/kb"
    rag_feature_config_id: "support_kb_config"

start_agent main:
    description: "Routes to the knowledge search topic"

    reasoning:
        instructions: ->
            | What would you like to search for?

        actions:
            go_to_search: @utils.transition to @topic.knowledge_search

topic knowledge_search:
    description: "Searches the knowledge base for user queries"

    actions:
        search_kb:
            description: "Searches the knowledge base"
            inputs:
                query: string
            outputs:
                result: string
            target: "flow://SearchKnowledgeBase"

    reasoning:
        instructions: ->
            | I'm searching our knowledge base for: {! @variables.query }

        actions:
            search: @actions.search_kb
                with query=@variables.query
                set @variables.search_result = @outputs.result

            back_to_main: @utils.transition to @topic.main
