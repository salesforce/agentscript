system:
    instructions: |
        You are a professional permit processing agent assistant.
        Help users manage their permit requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: application_intake -> review -> site_inspection -> issuance.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Permit Processing Agent Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "permit_processing_agent_v91"
    default_agent_user: "permit_processing@example.com"
    agent_description: "Assists users with permit management through the permit processing agent workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    permit_record_id: mutable string
        description: "Record ID of the permit"
    permit_status: mutable string = ""
        description: "Current status of the permit"
    permit_tier: mutable string = "standard"
        description: "Tier classification for the permit"
    permit_category: mutable string = ""
        description: "Category of the permit"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    application_intake_complete: mutable boolean = False
        description: "Whether the application_intake stage is complete"
    application_intake_result: mutable string = ""
        description: "Result from the application_intake stage"
    review_complete: mutable boolean = False
        description: "Whether the review stage is complete"
    review_result: mutable string = ""
        description: "Result from the review stage"
    site_inspection_complete: mutable boolean = False
        description: "Whether the site_inspection stage is complete"
    site_inspection_result: mutable string = ""
        description: "Result from the site_inspection stage"
    issuance_complete: mutable boolean = False
        description: "Whether the issuance stage is complete"
    issuance_result: mutable string = ""
        description: "Result from the issuance stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate permit management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a permit processing agent assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current permit status: {! @variables.permit_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_application_intake} for application intake requests.
              Use {!@actions.go_to_review} for review requests.
              Use {!@actions.go_to_site_inspection} for site inspection requests.
              Use {!@actions.go_to_issuance} for issuance requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_application_intake: @utils.transition to @topic.application_intake
                description: "Transition to application intake topic."
            go_to_review: @utils.transition to @topic.review
                description: "Transition to review topic."
                available when @variables.is_verified == True
            go_to_site_inspection: @utils.transition to @topic.site_inspection
                description: "Transition to site inspection topic."
                available when @variables.is_verified == True
            go_to_issuance: @utils.transition to @topic.issuance
                description: "Transition to issuance topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic application_intake:
    description: "Handles the application intake stage of the permit process"

    actions:
        process_application_intake_data:
            description: "Process application intake stage data for the permit"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_ApplicationIntake_Data"

        validate_application_intake_info:
            description: "Validate application intake information for the permit"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_ApplicationIntake_Info"

        fetch_application_intake_details:
            description: "Fetch application intake details for the permit"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_ApplicationIntake_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_application_intake_info
                with record_ref=@variables.permit_record_id
                with contact_ref=@variables.contact_email
                set @variables.permit_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the application intake stage for the permit.
              Current permit status: {! @variables.permit_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Application Intake result: {! @variables.application_intake_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.permit_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_application_intake} to begin processing.
        actions:
            run_application_intake: @actions.process_application_intake_data
                with record_ref=@variables.permit_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.permit_category
                set @variables.application_intake_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.application_intake_complete = @outputs.is_passed
            fetch_application_intake_info: @actions.fetch_application_intake_details
                with record_ref=@variables.permit_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.permit_tier = @outputs.tier_value
            go_to_review: @utils.transition to @topic.review
                description: "Move to review stage."
                available when @variables.application_intake_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.permit_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.permit_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.permit_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.application_intake_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic review:
    description: "Handles the review stage of the permit process"

    actions:
        process_review_data:
            description: "Process review stage data for the permit"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_Review"

        validate_review_info:
            description: "Validate review information for the permit"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Review_Info"

        fetch_review_details:
            description: "Fetch review details for the permit"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Review_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.application_intake_complete == False:
            transition to @topic.application_intake

    reasoning:
        instructions: ->
            | Handle the review stage for the permit.
              Current permit status: {! @variables.permit_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Review result: {! @variables.review_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.permit_tier }
              Review the review results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_review: @actions.process_review_data
                with record_ref=@variables.permit_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.permit_category
                set @variables.review_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.review_complete = @outputs.is_passed
            fetch_review_info: @actions.fetch_review_details
                with record_ref=@variables.permit_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.permit_tier = @outputs.tier_value
                available when @variables.permit_record_id is not None
            go_to_site_inspection: @utils.transition to @topic.site_inspection
                description: "Move to site inspection stage."
                available when @variables.review_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.review_complete == True:
            set @variables.permit_status = "review_done"
        if @variables.review_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.site_inspection
        if @variables.attempt_count >= 3 and @variables.review_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic site_inspection:
    description: "Handles the site inspection stage of the permit process"

    actions:
        process_site_inspection_data:
            description: "Process site inspection stage data for the permit"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_SiteInspection"

        validate_site_inspection_info:
            description: "Validate site inspection information for the permit"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_SiteInspection_Info"

        fetch_site_inspection_details:
            description: "Fetch site inspection details for the permit"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_SiteInspection_Details"

    before_reasoning:
        if @variables.site_inspection_complete == False:
            run @actions.fetch_site_inspection_details
                with record_ref=@variables.permit_record_id
                with include_history=True
                set @variables.site_inspection_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.permit_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.permit_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.permit_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the site inspection stage for the permit.
              Current permit status: {! @variables.permit_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Site Inspection result: {! @variables.site_inspection_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.permit_tier }
              Review the site inspection results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_site_inspection: @actions.process_site_inspection_data
                with record_ref=@variables.permit_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.permit_category
                set @variables.site_inspection_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.site_inspection_complete = @outputs.is_passed
            fetch_site_inspection_info: @actions.fetch_site_inspection_details
                with record_ref=@variables.permit_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.permit_tier = @outputs.tier_value
                available when @variables.permit_record_id is not None
            go_to_issuance: @utils.transition to @topic.issuance
                description: "Move to issuance stage."
                available when @variables.site_inspection_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.permit_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.permit_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.permit_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.site_inspection_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic issuance:
    description: "Handles the issuance stage of the permit process"

    actions:
        process_issuance_data:
            description: "Process issuance stage data for the permit"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_Issuance_Data"

        validate_issuance_info:
            description: "Validate issuance information for the permit"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Issuance_Info"

        fetch_issuance_details:
            description: "Fetch issuance details for the permit"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Issuance_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.site_inspection_complete == False:
            transition to @topic.site_inspection
        if @variables.eligibility_score >= 80:
            set @variables.permit_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.permit_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the issuance stage for the permit.
              Current permit status: {! @variables.permit_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Issuance result: {! @variables.issuance_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.permit_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_issuance: @actions.process_issuance_data
                with record_ref=@variables.permit_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.permit_category
                set @variables.issuance_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.issuance_complete = @outputs.is_passed
            fetch_issuance_info: @actions.fetch_issuance_details
                with record_ref=@variables.permit_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.permit_tier = @outputs.tier_value
                available when @variables.permit_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.issuance_complete == True:
            set @variables.permit_status = "issuance_done"
        if @variables.attempt_count >= 3 and @variables.issuance_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for permit issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the permit issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the permit interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the permit request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Permit status: {! @variables.permit_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.permit_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.permit_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.permit_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.permit_status = "escalated"
        set @variables.escalation_requested = False

