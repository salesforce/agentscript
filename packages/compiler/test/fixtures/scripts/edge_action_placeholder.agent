system:
    instructions: "You are a helpful assistant with placeholder actions for future implementation."
    messages:
        welcome: "Hello! Some of my actions are still being developed."
        error: "An error occurred while processing your request."

config:
    developer_name: "Placeholder_Actions_Agent"
    default_agent_user: "user@test.com"
    description: "Agent demonstrating placeholder action support"

start_agent main:
    description: "Agent with both real and placeholder actions"

    actions:
        Real_Action:
            description: "A real implemented action"
            target: "flow://RealAction"
            inputs:
                input_val: string
                    label: "Input Value"
                    is_required: True
            outputs:
                real_result: string
                    label: "Real Result"

        Placeholder_Action:
            description: "A placeholder action for future implementation"
            target: "placeholder://future_feature"
            inputs:
                future_input: string
                    label: "Future Input"
                    is_required: True
            outputs:
                future_result: string
                    label: "Future Result"

        Another_Placeholder:
            description: "Another stub action"
            target: "placeholder://another_feature"
            inputs:
                stub_input: string
                    label: "Stub Input"
            outputs:
                stub_result: string
                    label: "Stub Result"

    reasoning:
        instructions: ->
            | You have access to both real and placeholder actions.
              Placeholder actions will be implemented in future releases.

        actions:
            Use_Real: @actions.Real_Action
                with input_val=...

            Use_Placeholder: @actions.Placeholder_Action
                with future_input=...

            Use_Another_Stub: @actions.Another_Placeholder
                with stub_input=...
