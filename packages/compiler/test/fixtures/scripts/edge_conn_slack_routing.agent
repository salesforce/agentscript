system:
    instructions: "You are a Slack agent with routing configuration."
    messages:
        welcome: "Hi there! I'm the Slack support bot."
        error: "Something went wrong."

config:
    developer_name: "EdgeConnSlackRouting"
    default_agent_user: "slack_bot@example.com"
    agent_label: "Slack Routing Agent"
    description: "Slack connection with routing field"

connection slack:
    adaptive_response_allowed: True

start_agent main:
    description: "Handle Slack requests with routing"

    reasoning:
        instructions: ->
            | Help the user with their Slack request.

        actions:
            escalate_to_human: @utils.escalate
                description: "Escalate to human agent via queue"
