system:
    instructions: "You are an assistant that evaluates boolean conditions."
    messages:
        welcome: "Welcome!"
        error: "An error occurred."

config:
    developer_name: "Edge_Cond_Boolean_Ops"
    default_agent_user: "test_user"
    description: "Tests and/or boolean operators in conditionals"

variables:
    x: mutable string = "hello"
    y: mutable string = "world"
    a: mutable boolean = True
    b: mutable boolean = False
    both_present: mutable boolean = False
    either_true: mutable boolean = False

start_agent main:
    description: "Tests boolean and/or operators in conditions"

    before_reasoning:
        if @variables.x != "" and @variables.y != "":
            set @variables.both_present = True
        if @variables.a == True or @variables.b == True:
            set @variables.either_true = True

    reasoning:
        instructions: ->
            | Help the user with their request.
              Both present: {! @variables.both_present }
              Either true: {! @variables.either_true }
