system:
    instructions: "You are an email-based support agent."
    messages:
        welcome: "Thank you for your email. I'll assist you shortly."
        error: "We encountered an error processing your request."

config:
    developer_name: "EdgeConnServiceEmail"
    default_agent_user: "email_bot@example.com"
    agent_label: "Email Agent"
    description: "Agent with service email connection"

connection service_email:
    adaptive_response_allowed: True

start_agent main:
    description: "Handle email-based support requests"

    reasoning:
        instructions: ->
            | Respond to the customer's email. Be thorough and professional
              as email allows for longer responses.

        actions:
            escalate_to_human: @utils.escalate
                description: "Escalate to human agent via email"
