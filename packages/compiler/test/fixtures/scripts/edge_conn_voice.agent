system:
    instructions: "You are a voice-based support agent."
    messages:
        welcome: "Hello, thank you for calling. How may I help you?"
        error: "I'm sorry, we're experiencing technical difficulties."

config:
    developer_name: "EdgeConnVoice"
    default_agent_user: "voice_bot@example.com"
    agent_label: "Voice Agent"
    description: "Agent with voice connection"

connection voice:
    adaptive_response_allowed: True

start_agent main:
    description: "Handle voice-based support requests"

    reasoning:
        instructions: ->
            | Respond to the caller. Keep responses brief and clear
              as this is a voice channel. Avoid complex formatting.

        actions:
            escalate_to_human: @utils.escalate
                description: "Transfer to human agent"
