system:
    instructions: |
        You are a professional production scheduling agent assistant.
        Help users manage their production requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: demand_review -> resource_allocation -> line_scheduling -> monitoring.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Production Scheduling Agent Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "production_scheduling_agent_v81"
    default_agent_user: "production_scheduling@example.com"
    agent_description: "Assists users with production management through the production scheduling agent workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    production_record_id: mutable string
        description: "Record ID of the production"
    production_status: mutable string = ""
        description: "Current status of the production"
    production_tier: mutable string = "standard"
        description: "Tier classification for the production"
    production_category: mutable string = ""
        description: "Category of the production"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    demand_review_complete: mutable boolean = False
        description: "Whether the demand_review stage is complete"
    demand_review_result: mutable string = ""
        description: "Result from the demand_review stage"
    resource_allocation_complete: mutable boolean = False
        description: "Whether the resource_allocation stage is complete"
    resource_allocation_result: mutable string = ""
        description: "Result from the resource_allocation stage"
    line_scheduling_complete: mutable boolean = False
        description: "Whether the line_scheduling stage is complete"
    line_scheduling_result: mutable string = ""
        description: "Result from the line_scheduling stage"
    monitoring_complete: mutable boolean = False
        description: "Whether the monitoring stage is complete"
    monitoring_result: mutable string = ""
        description: "Result from the monitoring stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate production management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a production scheduling agent assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current production status: {! @variables.production_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_demand_review} for demand review requests.
              Use {!@actions.go_to_resource_allocation} for resource allocation requests.
              Use {!@actions.go_to_line_scheduling} for line scheduling requests.
              Use {!@actions.go_to_monitoring} for monitoring requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_demand_review: @utils.transition to @topic.demand_review
                description: "Transition to demand review topic."
            go_to_resource_allocation: @utils.transition to @topic.resource_allocation
                description: "Transition to resource allocation topic."
                available when @variables.is_verified == True
            go_to_line_scheduling: @utils.transition to @topic.line_scheduling
                description: "Transition to line scheduling topic."
                available when @variables.is_verified == True
            go_to_monitoring: @utils.transition to @topic.monitoring
                description: "Transition to monitoring topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic demand_review:
    description: "Handles the demand review stage of the production process"

    actions:
        process_demand_review_data:
            description: "Process demand review stage data for the production"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_DemandReview"

        validate_demand_review_info:
            description: "Validate demand review information for the production"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_DemandReview_Info"

        fetch_demand_review_details:
            description: "Fetch demand review details for the production"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_DemandReview_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_demand_review_info
                with record_ref=@variables.production_record_id
                with contact_ref=@variables.contact_email
                set @variables.production_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the demand review stage for the production.
              Current production status: {! @variables.production_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Demand Review result: {! @variables.demand_review_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.production_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_demand_review} to begin processing.
        actions:
            run_demand_review: @actions.process_demand_review_data
                with record_ref=@variables.production_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.production_category
                set @variables.demand_review_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.demand_review_complete = @outputs.is_passed
            fetch_demand_review_info: @actions.fetch_demand_review_details
                with record_ref=@variables.production_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.production_tier = @outputs.tier_value
            go_to_resource_allocation: @utils.transition to @topic.resource_allocation
                description: "Move to resource allocation stage."
                available when @variables.demand_review_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.production_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.production_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.production_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.demand_review_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic resource_allocation:
    description: "Handles the resource allocation stage of the production process"

    actions:
        process_resource_allocation_data:
            description: "Process resource allocation stage data for the production"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_ResourceAllocation_Data"

        validate_resource_allocation_info:
            description: "Validate resource allocation information for the production"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_ResourceAllocation_Info"

        fetch_resource_allocation_details:
            description: "Fetch resource allocation details for the production"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_ResourceAllocation_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.demand_review_complete == False:
            transition to @topic.demand_review

    reasoning:
        instructions: ->
            | Handle the resource allocation stage for the production.
              Current production status: {! @variables.production_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Resource Allocation result: {! @variables.resource_allocation_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.production_tier }
              Review the resource allocation results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_resource_allocation: @actions.process_resource_allocation_data
                with record_ref=@variables.production_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.production_category
                set @variables.resource_allocation_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.resource_allocation_complete = @outputs.is_passed
            fetch_resource_allocation_info: @actions.fetch_resource_allocation_details
                with record_ref=@variables.production_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.production_tier = @outputs.tier_value
                available when @variables.production_record_id is not None
            go_to_line_scheduling: @utils.transition to @topic.line_scheduling
                description: "Move to line scheduling stage."
                available when @variables.resource_allocation_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.resource_allocation_complete == True:
            set @variables.production_status = "resource_allocation_done"
        if @variables.resource_allocation_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.line_scheduling
        if @variables.attempt_count >= 3 and @variables.resource_allocation_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic line_scheduling:
    description: "Handles the line scheduling stage of the production process"

    actions:
        process_line_scheduling_data:
            description: "Process line scheduling stage data for the production"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_LineScheduling"

        validate_line_scheduling_info:
            description: "Validate line scheduling information for the production"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_LineScheduling_Info"

        fetch_line_scheduling_details:
            description: "Fetch line scheduling details for the production"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_LineScheduling_Details"

    before_reasoning:
        if @variables.line_scheduling_complete == False:
            run @actions.fetch_line_scheduling_details
                with record_ref=@variables.production_record_id
                with include_history=True
                set @variables.line_scheduling_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.production_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.production_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.production_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the line scheduling stage for the production.
              Current production status: {! @variables.production_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Line Scheduling result: {! @variables.line_scheduling_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.production_tier }
              Review the line scheduling results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_line_scheduling: @actions.process_line_scheduling_data
                with record_ref=@variables.production_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.production_category
                set @variables.line_scheduling_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.line_scheduling_complete = @outputs.is_passed
            fetch_line_scheduling_info: @actions.fetch_line_scheduling_details
                with record_ref=@variables.production_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.production_tier = @outputs.tier_value
                available when @variables.production_record_id is not None
            go_to_monitoring: @utils.transition to @topic.monitoring
                description: "Move to monitoring stage."
                available when @variables.line_scheduling_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.production_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.production_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.production_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.line_scheduling_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic monitoring:
    description: "Handles the monitoring stage of the production process"

    actions:
        process_monitoring_data:
            description: "Process monitoring stage data for the production"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_Monitoring"

        validate_monitoring_info:
            description: "Validate monitoring information for the production"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Monitoring_Info"

        fetch_monitoring_details:
            description: "Fetch monitoring details for the production"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Monitoring_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.line_scheduling_complete == False:
            transition to @topic.line_scheduling
        if @variables.eligibility_score >= 80:
            set @variables.production_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.production_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the monitoring stage for the production.
              Current production status: {! @variables.production_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Monitoring result: {! @variables.monitoring_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.production_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_monitoring: @actions.process_monitoring_data
                with record_ref=@variables.production_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.production_category
                set @variables.monitoring_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.monitoring_complete = @outputs.is_passed
            fetch_monitoring_info: @actions.fetch_monitoring_details
                with record_ref=@variables.production_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.production_tier = @outputs.tier_value
                available when @variables.production_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.monitoring_complete == True:
            set @variables.production_status = "monitoring_done"
        if @variables.attempt_count >= 3 and @variables.monitoring_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for production issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the production issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the production interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the production request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Production status: {! @variables.production_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.production_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.production_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.production_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.production_status = "escalated"
        set @variables.escalation_requested = False

