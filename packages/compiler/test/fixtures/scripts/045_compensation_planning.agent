system:
    instructions: |
        You are a professional compensation planning agent assistant.
        Help users manage their comp_plan requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: benchmarking -> budget_analysis -> proposal -> approval.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Compensation Planning Agent Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "compensation_planning_agent_v45"
    default_agent_user: "compensation_planning@example.com"
    agent_description: "Assists users with comp_plan management through the compensation planning agent workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    comp_plan_record_id: mutable string
        description: "Record ID of the comp_plan"
    comp_plan_status: mutable string = ""
        description: "Current status of the comp_plan"
    comp_plan_tier: mutable string = "standard"
        description: "Tier classification for the comp_plan"
    comp_plan_category: mutable string = ""
        description: "Category of the comp_plan"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    benchmarking_complete: mutable boolean = False
        description: "Whether the benchmarking stage is complete"
    benchmarking_result: mutable string = ""
        description: "Result from the benchmarking stage"
    budget_analysis_complete: mutable boolean = False
        description: "Whether the budget_analysis stage is complete"
    budget_analysis_result: mutable string = ""
        description: "Result from the budget_analysis stage"
    proposal_complete: mutable boolean = False
        description: "Whether the proposal stage is complete"
    proposal_result: mutable string = ""
        description: "Result from the proposal stage"
    approval_complete: mutable boolean = False
        description: "Whether the approval stage is complete"
    approval_result: mutable string = ""
        description: "Result from the approval stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate comp_plan management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a compensation planning agent assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current comp_plan status: {! @variables.comp_plan_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_benchmarking} for benchmarking requests.
              Use {!@actions.go_to_budget_analysis} for budget analysis requests.
              Use {!@actions.go_to_proposal} for proposal requests.
              Use {!@actions.go_to_approval} for approval requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_benchmarking: @utils.transition to @topic.benchmarking
                description: "Transition to benchmarking topic."
            go_to_budget_analysis: @utils.transition to @topic.budget_analysis
                description: "Transition to budget analysis topic."
                available when @variables.is_verified == True
            go_to_proposal: @utils.transition to @topic.proposal
                description: "Transition to proposal topic."
                available when @variables.is_verified == True
            go_to_approval: @utils.transition to @topic.approval
                description: "Transition to approval topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic benchmarking:
    description: "Handles the benchmarking stage of the comp_plan process"

    actions:
        process_benchmarking_data:
            description: "Process benchmarking stage data for the comp_plan"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_Benchmarking"

        validate_benchmarking_info:
            description: "Validate benchmarking information for the comp_plan"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Benchmarking_Info"

        fetch_benchmarking_details:
            description: "Fetch benchmarking details for the comp_plan"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Benchmarking_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_benchmarking_info
                with record_ref=@variables.comp_plan_record_id
                with contact_ref=@variables.contact_email
                set @variables.comp_plan_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the benchmarking stage for the comp_plan.
              Current comp_plan status: {! @variables.comp_plan_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Benchmarking result: {! @variables.benchmarking_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.comp_plan_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_benchmarking} to begin processing.
        actions:
            run_benchmarking: @actions.process_benchmarking_data
                with record_ref=@variables.comp_plan_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.comp_plan_category
                set @variables.benchmarking_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.benchmarking_complete = @outputs.is_passed
            fetch_benchmarking_info: @actions.fetch_benchmarking_details
                with record_ref=@variables.comp_plan_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.comp_plan_tier = @outputs.tier_value
            go_to_budget_analysis: @utils.transition to @topic.budget_analysis
                description: "Move to budget analysis stage."
                available when @variables.benchmarking_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.comp_plan_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.comp_plan_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.comp_plan_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.benchmarking_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic budget_analysis:
    description: "Handles the budget analysis stage of the comp_plan process"

    actions:
        process_budget_analysis_data:
            description: "Process budget analysis stage data for the comp_plan"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_BudgetAnalysis_Data"

        validate_budget_analysis_info:
            description: "Validate budget analysis information for the comp_plan"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_BudgetAnalysis_Info"

        fetch_budget_analysis_details:
            description: "Fetch budget analysis details for the comp_plan"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_BudgetAnalysis_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.benchmarking_complete == False:
            transition to @topic.benchmarking

    reasoning:
        instructions: ->
            | Handle the budget analysis stage for the comp_plan.
              Current comp_plan status: {! @variables.comp_plan_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Budget Analysis result: {! @variables.budget_analysis_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.comp_plan_tier }
              Review the budget analysis results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_budget_analysis: @actions.process_budget_analysis_data
                with record_ref=@variables.comp_plan_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.comp_plan_category
                set @variables.budget_analysis_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.budget_analysis_complete = @outputs.is_passed
            fetch_budget_analysis_info: @actions.fetch_budget_analysis_details
                with record_ref=@variables.comp_plan_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.comp_plan_tier = @outputs.tier_value
                available when @variables.comp_plan_record_id is not None
            go_to_proposal: @utils.transition to @topic.proposal
                description: "Move to proposal stage."
                available when @variables.budget_analysis_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.budget_analysis_complete == True:
            set @variables.comp_plan_status = "budget_analysis_done"
        if @variables.budget_analysis_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.proposal
        if @variables.attempt_count >= 3 and @variables.budget_analysis_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic proposal:
    description: "Handles the proposal stage of the comp_plan process"

    actions:
        process_proposal_data:
            description: "Process proposal stage data for the comp_plan"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_Proposal"

        validate_proposal_info:
            description: "Validate proposal information for the comp_plan"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Proposal_Info"

        fetch_proposal_details:
            description: "Fetch proposal details for the comp_plan"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Proposal_Details"

    before_reasoning:
        if @variables.proposal_complete == False:
            run @actions.fetch_proposal_details
                with record_ref=@variables.comp_plan_record_id
                with include_history=True
                set @variables.proposal_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.comp_plan_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.comp_plan_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.comp_plan_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the proposal stage for the comp_plan.
              Current comp_plan status: {! @variables.comp_plan_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Proposal result: {! @variables.proposal_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.comp_plan_tier }
              Review the proposal results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_proposal: @actions.process_proposal_data
                with record_ref=@variables.comp_plan_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.comp_plan_category
                set @variables.proposal_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.proposal_complete = @outputs.is_passed
            fetch_proposal_info: @actions.fetch_proposal_details
                with record_ref=@variables.comp_plan_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.comp_plan_tier = @outputs.tier_value
                available when @variables.comp_plan_record_id is not None
            go_to_approval: @utils.transition to @topic.approval
                description: "Move to approval stage."
                available when @variables.proposal_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.comp_plan_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.comp_plan_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.comp_plan_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.proposal_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic approval:
    description: "Handles the approval stage of the comp_plan process"

    actions:
        process_approval_data:
            description: "Process approval stage data for the comp_plan"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_Approval"

        validate_approval_info:
            description: "Validate approval information for the comp_plan"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Approval_Info"

        fetch_approval_details:
            description: "Fetch approval details for the comp_plan"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Approval_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.proposal_complete == False:
            transition to @topic.proposal
        if @variables.eligibility_score >= 80:
            set @variables.comp_plan_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.comp_plan_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the approval stage for the comp_plan.
              Current comp_plan status: {! @variables.comp_plan_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Approval result: {! @variables.approval_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.comp_plan_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_approval: @actions.process_approval_data
                with record_ref=@variables.comp_plan_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.comp_plan_category
                set @variables.approval_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.approval_complete = @outputs.is_passed
            fetch_approval_info: @actions.fetch_approval_details
                with record_ref=@variables.comp_plan_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.comp_plan_tier = @outputs.tier_value
                available when @variables.comp_plan_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.approval_complete == True:
            set @variables.comp_plan_status = "approval_done"
        if @variables.attempt_count >= 3 and @variables.approval_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for comp_plan issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the comp_plan issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the comp_plan interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the comp_plan request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Comp Plan status: {! @variables.comp_plan_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.comp_plan_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.comp_plan_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.comp_plan_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.comp_plan_status = "escalated"
        set @variables.escalation_requested = False

