system:
    instructions: |
        You are a professional warehouse operations agent assistant.
        Help users manage their warehouse requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: receiving -> put_away -> pick_and_pack -> dispatch.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Warehouse Operations Agent Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "warehouse_ops_agent_v89"
    default_agent_user: "warehouse_ops@example.com"
    agent_description: "Assists users with warehouse management through the warehouse operations agent workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    warehouse_record_id: mutable string
        description: "Record ID of the warehouse"
    warehouse_status: mutable string = ""
        description: "Current status of the warehouse"
    warehouse_tier: mutable string = "standard"
        description: "Tier classification for the warehouse"
    warehouse_category: mutable string = ""
        description: "Category of the warehouse"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    receiving_complete: mutable boolean = False
        description: "Whether the receiving stage is complete"
    receiving_result: mutable string = ""
        description: "Result from the receiving stage"
    put_away_complete: mutable boolean = False
        description: "Whether the put_away stage is complete"
    put_away_result: mutable string = ""
        description: "Result from the put_away stage"
    pick_and_pack_complete: mutable boolean = False
        description: "Whether the pick_and_pack stage is complete"
    pick_and_pack_result: mutable string = ""
        description: "Result from the pick_and_pack stage"
    dispatch_complete: mutable boolean = False
        description: "Whether the dispatch stage is complete"
    dispatch_result: mutable string = ""
        description: "Result from the dispatch stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate warehouse management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a warehouse operations agent assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current warehouse status: {! @variables.warehouse_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_receiving} for receiving requests.
              Use {!@actions.go_to_put_away} for put away requests.
              Use {!@actions.go_to_pick_and_pack} for pick and pack requests.
              Use {!@actions.go_to_dispatch} for dispatch requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_receiving: @utils.transition to @topic.receiving
                description: "Transition to receiving topic."
            go_to_put_away: @utils.transition to @topic.put_away
                description: "Transition to put away topic."
                available when @variables.is_verified == True
            go_to_pick_and_pack: @utils.transition to @topic.pick_and_pack
                description: "Transition to pick and pack topic."
                available when @variables.is_verified == True
            go_to_dispatch: @utils.transition to @topic.dispatch
                description: "Transition to dispatch topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic receiving:
    description: "Handles the receiving stage of the warehouse process"

    actions:
        process_receiving_data:
            description: "Process receiving stage data for the warehouse"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_Receiving"

        validate_receiving_info:
            description: "Validate receiving information for the warehouse"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Receiving_Info"

        fetch_receiving_details:
            description: "Fetch receiving details for the warehouse"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Receiving_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_receiving_info
                with record_ref=@variables.warehouse_record_id
                with contact_ref=@variables.contact_email
                set @variables.warehouse_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the receiving stage for the warehouse.
              Current warehouse status: {! @variables.warehouse_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Receiving result: {! @variables.receiving_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.warehouse_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_receiving} to begin processing.
        actions:
            run_receiving: @actions.process_receiving_data
                with record_ref=@variables.warehouse_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.warehouse_category
                set @variables.receiving_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.receiving_complete = @outputs.is_passed
            fetch_receiving_info: @actions.fetch_receiving_details
                with record_ref=@variables.warehouse_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.warehouse_tier = @outputs.tier_value
            go_to_put_away: @utils.transition to @topic.put_away
                description: "Move to put away stage."
                available when @variables.receiving_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.warehouse_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.warehouse_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.warehouse_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.receiving_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic put_away:
    description: "Handles the put away stage of the warehouse process"

    actions:
        process_put_away_data:
            description: "Process put away stage data for the warehouse"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_PutAway"

        validate_put_away_info:
            description: "Validate put away information for the warehouse"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_PutAway_Info"

        fetch_put_away_details:
            description: "Fetch put away details for the warehouse"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_PutAway_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.receiving_complete == False:
            transition to @topic.receiving

    reasoning:
        instructions: ->
            | Handle the put away stage for the warehouse.
              Current warehouse status: {! @variables.warehouse_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Put Away result: {! @variables.put_away_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.warehouse_tier }
              Review the put away results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_put_away: @actions.process_put_away_data
                with record_ref=@variables.warehouse_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.warehouse_category
                set @variables.put_away_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.put_away_complete = @outputs.is_passed
            fetch_put_away_info: @actions.fetch_put_away_details
                with record_ref=@variables.warehouse_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.warehouse_tier = @outputs.tier_value
                available when @variables.warehouse_record_id is not None
            go_to_pick_and_pack: @utils.transition to @topic.pick_and_pack
                description: "Move to pick and pack stage."
                available when @variables.put_away_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.put_away_complete == True:
            set @variables.warehouse_status = "put_away_done"
        if @variables.put_away_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.pick_and_pack
        if @variables.attempt_count >= 3 and @variables.put_away_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic pick_and_pack:
    description: "Handles the pick and pack stage of the warehouse process"

    actions:
        process_pick_and_pack_data:
            description: "Process pick and pack stage data for the warehouse"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_PickAndPack_Data"

        validate_pick_and_pack_info:
            description: "Validate pick and pack information for the warehouse"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_PickAndPack_Info"

        fetch_pick_and_pack_details:
            description: "Fetch pick and pack details for the warehouse"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_PickAndPack_Details"

    before_reasoning:
        if @variables.pick_and_pack_complete == False:
            run @actions.fetch_pick_and_pack_details
                with record_ref=@variables.warehouse_record_id
                with include_history=True
                set @variables.pick_and_pack_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.warehouse_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.warehouse_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.warehouse_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the pick and pack stage for the warehouse.
              Current warehouse status: {! @variables.warehouse_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Pick And Pack result: {! @variables.pick_and_pack_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.warehouse_tier }
              Review the pick and pack results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_pick_and_pack: @actions.process_pick_and_pack_data
                with record_ref=@variables.warehouse_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.warehouse_category
                set @variables.pick_and_pack_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.pick_and_pack_complete = @outputs.is_passed
            fetch_pick_and_pack_info: @actions.fetch_pick_and_pack_details
                with record_ref=@variables.warehouse_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.warehouse_tier = @outputs.tier_value
                available when @variables.warehouse_record_id is not None
            go_to_dispatch: @utils.transition to @topic.dispatch
                description: "Move to dispatch stage."
                available when @variables.pick_and_pack_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.warehouse_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.warehouse_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.warehouse_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.pick_and_pack_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic dispatch:
    description: "Handles the dispatch stage of the warehouse process"

    actions:
        process_dispatch_data:
            description: "Process dispatch stage data for the warehouse"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_Dispatch"

        validate_dispatch_info:
            description: "Validate dispatch information for the warehouse"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Dispatch_Info"

        fetch_dispatch_details:
            description: "Fetch dispatch details for the warehouse"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Dispatch_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.pick_and_pack_complete == False:
            transition to @topic.pick_and_pack
        if @variables.eligibility_score >= 80:
            set @variables.warehouse_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.warehouse_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the dispatch stage for the warehouse.
              Current warehouse status: {! @variables.warehouse_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Dispatch result: {! @variables.dispatch_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.warehouse_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_dispatch: @actions.process_dispatch_data
                with record_ref=@variables.warehouse_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.warehouse_category
                set @variables.dispatch_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.dispatch_complete = @outputs.is_passed
            fetch_dispatch_info: @actions.fetch_dispatch_details
                with record_ref=@variables.warehouse_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.warehouse_tier = @outputs.tier_value
                available when @variables.warehouse_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.dispatch_complete == True:
            set @variables.warehouse_status = "dispatch_done"
        if @variables.attempt_count >= 3 and @variables.dispatch_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for warehouse issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the warehouse issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the warehouse interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the warehouse request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Warehouse status: {! @variables.warehouse_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.warehouse_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.warehouse_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.warehouse_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.warehouse_status = "escalated"
        set @variables.escalation_requested = False

