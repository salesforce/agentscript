config:
    agent_name: "v1"
    agent_type: "AgentforceServiceAgent"
    default_agent_user: "mood_bot_user"
    description: "An AI assistant for in-org business tasks."


language:
    default_locale: "en_US"

system:
    instructions: "You are a friendly and empathetic Salesforce Employee bot that help employees with their day to day questions."
    messages:
        error: "Sorry, something went wrong."
        welcome: "Hello! I'm a Salesforce Employee Bot. How are you feeling today?"

start_agent A1:
    description: "Asks the user if they want to know about something?"
    system:
        instructions: "You are Salesforce employee support bot. You can help employees with their questions about Salesforce"
    reasoning:
        actions:
            A2: @utils.transition to @topic.A2
                description: "If the user query is about something related to Salesforce Tower in San Francisco"

topic A2:
    description: "Help user with questions related to Salesforce Tower in San Francisco."
    system:
        instructions: "You are Salesforce SF Tower expert. You can help employees with their questions about Salesforce SF Tower"

    reasoning:
        actions:
            B1: @utils.transition to @topic.B1
                description: "If user query mentions meeting room at all"

topic B1:
    description: "Help user with questions related to Meeting rooms in Salesforce SF Tower."
    system:
        instructions: "You are Meeting room expert for Salesforce SF Tower. You can help employees with their meeting room in Salesforce SF Tower"

    reasoning:
        actions:
            B2: @utils.transition to @topic.B2
                description: "If user query mentions microkitchen at all"

topic B2:
    description: "Help user with questions related to microkitchen in Salesforce SF Tower."
    system:
        instructions: "You are microkitchen expert for Salesforce SF Tower. You can help employees with their microkitchen in Salesforce SF Tower"

    reasoning:
        actions:
            C1: @utils.transition to @topic.C1
                description: "If user query mentions microkitchen buffet and food items at all"

topic C1:
    description: "Help user with questions related to buffets in microkitchen in Salesforce SF Tower."
    system:
        instructions: "You are buffets in microkitchen expert for Salesforce SF Tower. You can help employees with their buffets in microkitchen in Salesforce SF Tower"

    reasoning:
        actions:
            C2: @utils.transition to @topic.C2
                description: "If user query mentions food items in buffet at all"

topic C2:
    description: "Help user with questions related to food items in buffets happening in microkitchen in Salesforce SF Tower."
    system:
        instructions: "You are buffets in food items in buffets happening microkitchen expert for Salesforce SF Tower. You can help employees with their buffet food item related questions"

    reasoning:
        actions:
            D1: @utils.transition to @topic.D1
                description: "If user query questions anything about the missing food items in buffet at all"

topic D1:
    description: "You know the answer to the Microkitchen buffet missing food item at all."
    system:
        instructions: "Let the user know that the missing item was Butter Croissant."
