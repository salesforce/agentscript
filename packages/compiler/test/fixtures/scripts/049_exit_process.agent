system:
    instructions: |
        You are a professional exit process coordinator assistant.
        Help users manage their exit requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: notification -> knowledge_transfer -> asset_return -> final_review.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Exit Process Coordinator Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "exit_process_agent_v49"
    default_agent_user: "exit_process@example.com"
    agent_description: "Assists users with exit management through the exit process coordinator workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    exit_record_id: mutable string
        description: "Record ID of the exit"
    exit_status: mutable string = ""
        description: "Current status of the exit"
    exit_tier: mutable string = "standard"
        description: "Tier classification for the exit"
    exit_category: mutable string = ""
        description: "Category of the exit"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    notification_complete: mutable boolean = False
        description: "Whether the notification stage is complete"
    notification_result: mutable string = ""
        description: "Result from the notification stage"
    knowledge_transfer_complete: mutable boolean = False
        description: "Whether the knowledge_transfer stage is complete"
    knowledge_transfer_result: mutable string = ""
        description: "Result from the knowledge_transfer stage"
    asset_return_complete: mutable boolean = False
        description: "Whether the asset_return stage is complete"
    asset_return_result: mutable string = ""
        description: "Result from the asset_return stage"
    final_review_complete: mutable boolean = False
        description: "Whether the final_review stage is complete"
    final_review_result: mutable string = ""
        description: "Result from the final_review stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate exit management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a exit process coordinator assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current exit status: {! @variables.exit_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_notification} for notification requests.
              Use {!@actions.go_to_knowledge_transfer} for knowledge transfer requests.
              Use {!@actions.go_to_asset_return} for asset return requests.
              Use {!@actions.go_to_final_review} for final review requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_notification: @utils.transition to @topic.notification
                description: "Transition to notification topic."
            go_to_knowledge_transfer: @utils.transition to @topic.knowledge_transfer
                description: "Transition to knowledge transfer topic."
                available when @variables.is_verified == True
            go_to_asset_return: @utils.transition to @topic.asset_return
                description: "Transition to asset return topic."
                available when @variables.is_verified == True
            go_to_final_review: @utils.transition to @topic.final_review
                description: "Transition to final review topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic notification:
    description: "Handles the notification stage of the exit process"

    actions:
        process_notification_data:
            description: "Process notification stage data for the exit"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_Notification_Data"

        validate_notification_info:
            description: "Validate notification information for the exit"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Notification_Info"

        fetch_notification_details:
            description: "Fetch notification details for the exit"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Notification_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_notification_info
                with record_ref=@variables.exit_record_id
                with contact_ref=@variables.contact_email
                set @variables.exit_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the notification stage for the exit.
              Current exit status: {! @variables.exit_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Notification result: {! @variables.notification_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.exit_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_notification} to begin processing.
        actions:
            run_notification: @actions.process_notification_data
                with record_ref=@variables.exit_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.exit_category
                set @variables.notification_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.notification_complete = @outputs.is_passed
            fetch_notification_info: @actions.fetch_notification_details
                with record_ref=@variables.exit_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.exit_tier = @outputs.tier_value
            go_to_knowledge_transfer: @utils.transition to @topic.knowledge_transfer
                description: "Move to knowledge transfer stage."
                available when @variables.notification_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.exit_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.exit_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.exit_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.notification_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic knowledge_transfer:
    description: "Handles the knowledge transfer stage of the exit process"

    actions:
        process_knowledge_transfer_data:
            description: "Process knowledge transfer stage data for the exit"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_KnowledgeTransfer"

        validate_knowledge_transfer_info:
            description: "Validate knowledge transfer information for the exit"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_KnowledgeTransfer_Info"

        fetch_knowledge_transfer_details:
            description: "Fetch knowledge transfer details for the exit"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_KnowledgeTransfer_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.notification_complete == False:
            transition to @topic.notification

    reasoning:
        instructions: ->
            | Handle the knowledge transfer stage for the exit.
              Current exit status: {! @variables.exit_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Knowledge Transfer result: {! @variables.knowledge_transfer_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.exit_tier }
              Review the knowledge transfer results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_knowledge_transfer: @actions.process_knowledge_transfer_data
                with record_ref=@variables.exit_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.exit_category
                set @variables.knowledge_transfer_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.knowledge_transfer_complete = @outputs.is_passed
            fetch_knowledge_transfer_info: @actions.fetch_knowledge_transfer_details
                with record_ref=@variables.exit_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.exit_tier = @outputs.tier_value
                available when @variables.exit_record_id is not None
            go_to_asset_return: @utils.transition to @topic.asset_return
                description: "Move to asset return stage."
                available when @variables.knowledge_transfer_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.knowledge_transfer_complete == True:
            set @variables.exit_status = "knowledge_transfer_done"
        if @variables.knowledge_transfer_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.asset_return
        if @variables.attempt_count >= 3 and @variables.knowledge_transfer_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic asset_return:
    description: "Handles the asset return stage of the exit process"

    actions:
        process_asset_return_data:
            description: "Process asset return stage data for the exit"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_AssetReturn"

        validate_asset_return_info:
            description: "Validate asset return information for the exit"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_AssetReturn_Info"

        fetch_asset_return_details:
            description: "Fetch asset return details for the exit"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_AssetReturn_Details"

    before_reasoning:
        if @variables.asset_return_complete == False:
            run @actions.fetch_asset_return_details
                with record_ref=@variables.exit_record_id
                with include_history=True
                set @variables.asset_return_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.exit_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.exit_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.exit_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the asset return stage for the exit.
              Current exit status: {! @variables.exit_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Asset Return result: {! @variables.asset_return_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.exit_tier }
              Review the asset return results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_asset_return: @actions.process_asset_return_data
                with record_ref=@variables.exit_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.exit_category
                set @variables.asset_return_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.asset_return_complete = @outputs.is_passed
            fetch_asset_return_info: @actions.fetch_asset_return_details
                with record_ref=@variables.exit_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.exit_tier = @outputs.tier_value
                available when @variables.exit_record_id is not None
            go_to_final_review: @utils.transition to @topic.final_review
                description: "Move to final review stage."
                available when @variables.asset_return_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.exit_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.exit_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.exit_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.asset_return_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic final_review:
    description: "Handles the final review stage of the exit process"

    actions:
        process_final_review_data:
            description: "Process final review stage data for the exit"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_FinalReview_Data"

        validate_final_review_info:
            description: "Validate final review information for the exit"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_FinalReview_Info"

        fetch_final_review_details:
            description: "Fetch final review details for the exit"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_FinalReview_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.asset_return_complete == False:
            transition to @topic.asset_return
        if @variables.eligibility_score >= 80:
            set @variables.exit_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.exit_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the final review stage for the exit.
              Current exit status: {! @variables.exit_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Final Review result: {! @variables.final_review_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.exit_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_final_review: @actions.process_final_review_data
                with record_ref=@variables.exit_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.exit_category
                set @variables.final_review_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.final_review_complete = @outputs.is_passed
            fetch_final_review_info: @actions.fetch_final_review_details
                with record_ref=@variables.exit_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.exit_tier = @outputs.tier_value
                available when @variables.exit_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.final_review_complete == True:
            set @variables.exit_status = "final_review_done"
        if @variables.attempt_count >= 3 and @variables.final_review_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for exit issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the exit issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the exit interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the exit request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Exit status: {! @variables.exit_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.exit_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.exit_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.exit_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.exit_status = "escalated"
        set @variables.escalation_requested = False

