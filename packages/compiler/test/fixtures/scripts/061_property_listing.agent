system:
    instructions: |
        You are a professional property listing agent assistant.
        Help users manage their listing requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: intake -> valuation -> marketing -> showing_coordination.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Property Listing Agent Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "property_listing_agent_v61"
    default_agent_user: "property_listing@example.com"
    agent_description: "Assists users with listing management through the property listing agent workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    listing_record_id: mutable string
        description: "Record ID of the listing"
    listing_status: mutable string = ""
        description: "Current status of the listing"
    listing_tier: mutable string = "standard"
        description: "Tier classification for the listing"
    listing_category: mutable string = ""
        description: "Category of the listing"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    intake_complete: mutable boolean = False
        description: "Whether the intake stage is complete"
    intake_result: mutable string = ""
        description: "Result from the intake stage"
    valuation_complete: mutable boolean = False
        description: "Whether the valuation stage is complete"
    valuation_result: mutable string = ""
        description: "Result from the valuation stage"
    marketing_complete: mutable boolean = False
        description: "Whether the marketing stage is complete"
    marketing_result: mutable string = ""
        description: "Result from the marketing stage"
    showing_coordination_complete: mutable boolean = False
        description: "Whether the showing_coordination stage is complete"
    showing_coordination_result: mutable string = ""
        description: "Result from the showing_coordination stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate listing management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a property listing agent assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current listing status: {! @variables.listing_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_intake} for intake requests.
              Use {!@actions.go_to_valuation} for valuation requests.
              Use {!@actions.go_to_marketing} for marketing requests.
              Use {!@actions.go_to_showing_coordination} for showing coordination requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_intake: @utils.transition to @topic.intake
                description: "Transition to intake topic."
            go_to_valuation: @utils.transition to @topic.valuation
                description: "Transition to valuation topic."
                available when @variables.is_verified == True
            go_to_marketing: @utils.transition to @topic.marketing
                description: "Transition to marketing topic."
                available when @variables.is_verified == True
            go_to_showing_coordination: @utils.transition to @topic.showing_coordination
                description: "Transition to showing coordination topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic intake:
    description: "Handles the intake stage of the listing process"

    actions:
        process_intake_data:
            description: "Process intake stage data for the listing"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_Intake_Data"

        validate_intake_info:
            description: "Validate intake information for the listing"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Intake_Info"

        fetch_intake_details:
            description: "Fetch intake details for the listing"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Intake_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_intake_info
                with record_ref=@variables.listing_record_id
                with contact_ref=@variables.contact_email
                set @variables.listing_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the intake stage for the listing.
              Current listing status: {! @variables.listing_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Intake result: {! @variables.intake_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.listing_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_intake} to begin processing.
        actions:
            run_intake: @actions.process_intake_data
                with record_ref=@variables.listing_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.listing_category
                set @variables.intake_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.intake_complete = @outputs.is_passed
            fetch_intake_info: @actions.fetch_intake_details
                with record_ref=@variables.listing_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.listing_tier = @outputs.tier_value
            go_to_valuation: @utils.transition to @topic.valuation
                description: "Move to valuation stage."
                available when @variables.intake_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.listing_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.listing_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.listing_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.intake_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic valuation:
    description: "Handles the valuation stage of the listing process"

    actions:
        process_valuation_data:
            description: "Process valuation stage data for the listing"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_Valuation"

        validate_valuation_info:
            description: "Validate valuation information for the listing"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Valuation_Info"

        fetch_valuation_details:
            description: "Fetch valuation details for the listing"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Valuation_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.intake_complete == False:
            transition to @topic.intake

    reasoning:
        instructions: ->
            | Handle the valuation stage for the listing.
              Current listing status: {! @variables.listing_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Valuation result: {! @variables.valuation_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.listing_tier }
              Review the valuation results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_valuation: @actions.process_valuation_data
                with record_ref=@variables.listing_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.listing_category
                set @variables.valuation_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.valuation_complete = @outputs.is_passed
            fetch_valuation_info: @actions.fetch_valuation_details
                with record_ref=@variables.listing_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.listing_tier = @outputs.tier_value
                available when @variables.listing_record_id is not None
            go_to_marketing: @utils.transition to @topic.marketing
                description: "Move to marketing stage."
                available when @variables.valuation_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.valuation_complete == True:
            set @variables.listing_status = "valuation_done"
        if @variables.valuation_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.marketing
        if @variables.attempt_count >= 3 and @variables.valuation_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic marketing:
    description: "Handles the marketing stage of the listing process"

    actions:
        process_marketing_data:
            description: "Process marketing stage data for the listing"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_Marketing"

        validate_marketing_info:
            description: "Validate marketing information for the listing"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Marketing_Info"

        fetch_marketing_details:
            description: "Fetch marketing details for the listing"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Marketing_Details"

    before_reasoning:
        if @variables.marketing_complete == False:
            run @actions.fetch_marketing_details
                with record_ref=@variables.listing_record_id
                with include_history=True
                set @variables.marketing_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.listing_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.listing_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.listing_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the marketing stage for the listing.
              Current listing status: {! @variables.listing_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Marketing result: {! @variables.marketing_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.listing_tier }
              Review the marketing results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_marketing: @actions.process_marketing_data
                with record_ref=@variables.listing_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.listing_category
                set @variables.marketing_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.marketing_complete = @outputs.is_passed
            fetch_marketing_info: @actions.fetch_marketing_details
                with record_ref=@variables.listing_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.listing_tier = @outputs.tier_value
                available when @variables.listing_record_id is not None
            go_to_showing_coordination: @utils.transition to @topic.showing_coordination
                description: "Move to showing coordination stage."
                available when @variables.marketing_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.listing_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.listing_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.listing_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.marketing_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic showing_coordination:
    description: "Handles the showing coordination stage of the listing process"

    actions:
        process_showing_coordination_data:
            description: "Process showing coordination stage data for the listing"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_ShowingCoordination_Data"

        validate_showing_coordination_info:
            description: "Validate showing coordination information for the listing"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_ShowingCoordination_Info"

        fetch_showing_coordination_details:
            description: "Fetch showing coordination details for the listing"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_ShowingCoordination_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.marketing_complete == False:
            transition to @topic.marketing
        if @variables.eligibility_score >= 80:
            set @variables.listing_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.listing_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the showing coordination stage for the listing.
              Current listing status: {! @variables.listing_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Showing Coordination result: {! @variables.showing_coordination_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.listing_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_showing_coordination: @actions.process_showing_coordination_data
                with record_ref=@variables.listing_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.listing_category
                set @variables.showing_coordination_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.showing_coordination_complete = @outputs.is_passed
            fetch_showing_coordination_info: @actions.fetch_showing_coordination_details
                with record_ref=@variables.listing_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.listing_tier = @outputs.tier_value
                available when @variables.listing_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.showing_coordination_complete == True:
            set @variables.listing_status = "showing_coordination_done"
        if @variables.attempt_count >= 3 and @variables.showing_coordination_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for listing issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the listing issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the listing interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the listing request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Listing status: {! @variables.listing_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.listing_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.listing_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.listing_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.listing_status = "escalated"
        set @variables.escalation_requested = False

