system:
    instructions: "You are a comprehensive customer service agent."
    messages:
        welcome: "Hello! How can I help you today?"
        error: "An error occurred. Please try again."

config:
    developer_name: "Many_Topics_Agent"
    default_agent_user: "user@test.com"
    description: "Agent with many topics demonstrating complex routing"

start_agent main:
    description: "Agent with many topics demonstrating complex routing"

    reasoning:
        instructions: ->
            | Route the user to the appropriate topic based on their request.

        actions:
            go_to_billing: @utils.transition to @topic.billing
            go_to_shipping: @utils.transition to @topic.shipping
            go_to_returns: @utils.transition to @topic.returns
            go_to_account: @utils.transition to @topic.account
            go_to_technical: @utils.transition to @topic.technical
            go_to_feedback: @utils.transition to @topic.feedback
            go_to_loyalty: @utils.transition to @topic.loyalty
            go_to_warranty: @utils.transition to @topic.warranty
            go_to_billing_dispute: @utils.transition to @topic.billing_dispute
            go_to_cancellation: @utils.transition to @topic.cancellation
            escalate_issue: @utils.escalate
                description: "Escalate to a human agent"

topic billing:
    description: "Handle billing inquiries"

    reasoning:
        instructions: ->
            | Help the user with billing questions.

topic shipping:
    description: "Handle shipping inquiries"

    reasoning:
        instructions: ->
            | Help the user with shipping questions.

topic returns:
    description: "Handle return requests"

    reasoning:
        instructions: ->
            | Help the user with returns.

topic account:
    description: "Handle account management"

    reasoning:
        instructions: ->
            | Help the user manage their account.

topic technical:
    description: "Handle technical support"

    reasoning:
        instructions: ->
            | Help the user with technical issues.

        actions:
            escalate_issue: @utils.escalate
                description: "Escalate to a human agent"

topic feedback:
    description: "Collect user feedback"

    reasoning:
        instructions: ->
            | Collect feedback from the user.

topic loyalty:
    description: "Handle loyalty program inquiries"

    reasoning:
        instructions: ->
            | Help the user with loyalty program questions.

topic warranty:
    description: "Handle warranty claims"

    reasoning:
        instructions: ->
            | Help the user with warranty claims.

topic billing_dispute:
    description: "Handle billing disputes"

    reasoning:
        instructions: ->
            | Help the user resolve billing disputes.

        actions:
            go_to_billing: @utils.transition to @topic.billing

topic cancellation:
    description: "Handle cancellation requests"

    reasoning:
        instructions: ->
            | Help the user cancel their order or subscription.

