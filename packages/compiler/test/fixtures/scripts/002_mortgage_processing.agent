system:
    instructions: |
        You are a professional mortgage processing agent assistant.
        Help users manage their mortgage requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: application -> appraisal -> title_review -> closing.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Mortgage Processing Agent Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "mortgage_processing_agent_v2"
    default_agent_user: "mortgage_processing@example.com"
    agent_description: "Assists users with mortgage management through the mortgage processing agent workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    mortgage_record_id: mutable string
        description: "Record ID of the mortgage"
    mortgage_status: mutable string = ""
        description: "Current status of the mortgage"
    mortgage_tier: mutable string = "standard"
        description: "Tier classification for the mortgage"
    mortgage_category: mutable string = ""
        description: "Category of the mortgage"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    application_complete: mutable boolean = False
        description: "Whether the application stage is complete"
    application_result: mutable string = ""
        description: "Result from the application stage"
    appraisal_complete: mutable boolean = False
        description: "Whether the appraisal stage is complete"
    appraisal_result: mutable string = ""
        description: "Result from the appraisal stage"
    title_review_complete: mutable boolean = False
        description: "Whether the title_review stage is complete"
    title_review_result: mutable string = ""
        description: "Result from the title_review stage"
    closing_complete: mutable boolean = False
        description: "Whether the closing stage is complete"
    closing_result: mutable string = ""
        description: "Result from the closing stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate mortgage management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a mortgage processing agent assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current mortgage status: {! @variables.mortgage_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_application} for application requests.
              Use {!@actions.go_to_appraisal} for appraisal requests.
              Use {!@actions.go_to_title_review} for title review requests.
              Use {!@actions.go_to_closing} for closing requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_application: @utils.transition to @topic.application
                description: "Transition to application topic."
            go_to_appraisal: @utils.transition to @topic.appraisal
                description: "Transition to appraisal topic."
                available when @variables.is_verified == True
            go_to_title_review: @utils.transition to @topic.title_review
                description: "Transition to title review topic."
                available when @variables.is_verified == True
            go_to_closing: @utils.transition to @topic.closing
                description: "Transition to closing topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic application:
    description: "Handles the application stage of the mortgage process"

    actions:
        process_application_data:
            description: "Process application stage data for the mortgage"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_Application"

        validate_application_info:
            description: "Validate application information for the mortgage"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Application_Info"

        fetch_application_details:
            description: "Fetch application details for the mortgage"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Application_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_application_info
                with record_ref=@variables.mortgage_record_id
                with contact_ref=@variables.contact_email
                set @variables.mortgage_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the application stage for the mortgage.
              Current mortgage status: {! @variables.mortgage_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Application result: {! @variables.application_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.mortgage_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_application} to begin processing.
        actions:
            run_application: @actions.process_application_data
                with record_ref=@variables.mortgage_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.mortgage_category
                set @variables.application_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.application_complete = @outputs.is_passed
            fetch_application_info: @actions.fetch_application_details
                with record_ref=@variables.mortgage_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.mortgage_tier = @outputs.tier_value
            go_to_appraisal: @utils.transition to @topic.appraisal
                description: "Move to appraisal stage."
                available when @variables.application_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.mortgage_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.mortgage_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.mortgage_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.application_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic appraisal:
    description: "Handles the appraisal stage of the mortgage process"

    actions:
        process_appraisal_data:
            description: "Process appraisal stage data for the mortgage"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_Appraisal"

        validate_appraisal_info:
            description: "Validate appraisal information for the mortgage"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Appraisal_Info"

        fetch_appraisal_details:
            description: "Fetch appraisal details for the mortgage"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Appraisal_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.application_complete == False:
            transition to @topic.application

    reasoning:
        instructions: ->
            | Handle the appraisal stage for the mortgage.
              Current mortgage status: {! @variables.mortgage_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Appraisal result: {! @variables.appraisal_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.mortgage_tier }
              Review the appraisal results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_appraisal: @actions.process_appraisal_data
                with record_ref=@variables.mortgage_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.mortgage_category
                set @variables.appraisal_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.appraisal_complete = @outputs.is_passed
            fetch_appraisal_info: @actions.fetch_appraisal_details
                with record_ref=@variables.mortgage_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.mortgage_tier = @outputs.tier_value
                available when @variables.mortgage_record_id is not None
            go_to_title_review: @utils.transition to @topic.title_review
                description: "Move to title review stage."
                available when @variables.appraisal_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.appraisal_complete == True:
            set @variables.mortgage_status = "appraisal_done"
        if @variables.appraisal_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.title_review
        if @variables.attempt_count >= 3 and @variables.appraisal_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic title_review:
    description: "Handles the title review stage of the mortgage process"

    actions:
        process_title_review_data:
            description: "Process title review stage data for the mortgage"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_TitleReview_Data"

        validate_title_review_info:
            description: "Validate title review information for the mortgage"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_TitleReview_Info"

        fetch_title_review_details:
            description: "Fetch title review details for the mortgage"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_TitleReview_Details"

    before_reasoning:
        if @variables.title_review_complete == False:
            run @actions.fetch_title_review_details
                with record_ref=@variables.mortgage_record_id
                with include_history=True
                set @variables.title_review_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.mortgage_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.mortgage_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.mortgage_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the title review stage for the mortgage.
              Current mortgage status: {! @variables.mortgage_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Title Review result: {! @variables.title_review_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.mortgage_tier }
              Review the title review results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_title_review: @actions.process_title_review_data
                with record_ref=@variables.mortgage_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.mortgage_category
                set @variables.title_review_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.title_review_complete = @outputs.is_passed
            fetch_title_review_info: @actions.fetch_title_review_details
                with record_ref=@variables.mortgage_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.mortgage_tier = @outputs.tier_value
                available when @variables.mortgage_record_id is not None
            go_to_closing: @utils.transition to @topic.closing
                description: "Move to closing stage."
                available when @variables.title_review_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.mortgage_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.mortgage_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.mortgage_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.title_review_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic closing:
    description: "Handles the closing stage of the mortgage process"

    actions:
        process_closing_data:
            description: "Process closing stage data for the mortgage"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_Closing"

        validate_closing_info:
            description: "Validate closing information for the mortgage"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Closing_Info"

        fetch_closing_details:
            description: "Fetch closing details for the mortgage"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Closing_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.title_review_complete == False:
            transition to @topic.title_review
        if @variables.eligibility_score >= 80:
            set @variables.mortgage_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.mortgage_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the closing stage for the mortgage.
              Current mortgage status: {! @variables.mortgage_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Closing result: {! @variables.closing_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.mortgage_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_closing: @actions.process_closing_data
                with record_ref=@variables.mortgage_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.mortgage_category
                set @variables.closing_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.closing_complete = @outputs.is_passed
            fetch_closing_info: @actions.fetch_closing_details
                with record_ref=@variables.mortgage_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.mortgage_tier = @outputs.tier_value
                available when @variables.mortgage_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.closing_complete == True:
            set @variables.mortgage_status = "closing_done"
        if @variables.attempt_count >= 3 and @variables.closing_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for mortgage issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the mortgage issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the mortgage interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the mortgage request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Mortgage status: {! @variables.mortgage_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.mortgage_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.mortgage_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.mortgage_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.mortgage_status = "escalated"
        set @variables.escalation_requested = False

