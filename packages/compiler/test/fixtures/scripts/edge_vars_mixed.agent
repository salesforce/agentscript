# Both linked and mutable variables in same block
system:
    instructions: "You are an agent with both linked and mutable variables."
    messages:
        welcome: "Hello {!@variables.user_name}! How can I help?"
        error: "Sorry, an error occurred."

config:
    agent_name: "Mixed_Vars_Agent"
    agent_type: "AgentforceServiceAgent"
    developer_name: "Mixed_Vars_Agent"
    description: "Agent with both linked and mutable variables"

variables:
    session_id: linked string
        source: @MessagingSession.Id
        description: "Linked session ID"
    user_name: linked string
        source: @MessagingEndUser.Name
        description: "Linked end user name"
    contact_id: linked string
        source: @MessagingEndUser.ContactId
        description: "Linked contact ID"
    intent: mutable string = ""
        description: "Detected user intent"
    sentiment: mutable string = "neutral"
        description: "Detected sentiment"
    turn_count: mutable number = 0
        description: "Number of conversation turns"
    is_authenticated: mutable boolean = False
        description: "Whether user is authenticated"
    context_data: mutable object = None
        description: "Conversation context data"
    previous_topics: mutable list[string] = None
        description: "Previously visited topics"

start_agent main:
    description: "Handle mixed variable types"
    reasoning:
        instructions: ->
            | Authenticate the user and route based on intent
