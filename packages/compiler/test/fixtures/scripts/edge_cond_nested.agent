system:
    instructions: "You are a helpful assistant with nested conditional logic."
    messages:
        welcome: "Hello!"
        error: "Error occurred."

config:
    developer_name: "Edge_Cond_Nested"
    default_agent_user: "test_user"
    description: "Tests nested if conditionals in before_reasoning"

variables:
    a: mutable boolean = True
    b: mutable boolean = False
    result: mutable string = "none"

start_agent main:
    description: "Tests nested if blocks in before_reasoning"

    before_reasoning:
        if @variables.a == True and @variables.b == True:
            set @variables.result = "both_true"
        if @variables.a == True and @variables.b == False:
            set @variables.result = "only_a_true"
        if @variables.a == False:
            set @variables.result = "a_is_false"

    reasoning:
        instructions: ->
            | Assist the user. Current result: {! @variables.result }
