system:
    instructions: |
        You are a professional property valuation specialist assistant.
        Help users manage their valuation requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: data_collection -> comparable_analysis -> adjustment -> report_generation.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Property Valuation Specialist Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "property_valuation_agent_v65"
    default_agent_user: "property_valuation@example.com"
    agent_description: "Assists users with valuation management through the property valuation specialist workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    valuation_record_id: mutable string
        description: "Record ID of the valuation"
    valuation_status: mutable string = ""
        description: "Current status of the valuation"
    valuation_tier: mutable string = "standard"
        description: "Tier classification for the valuation"
    valuation_category: mutable string = ""
        description: "Category of the valuation"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    data_collection_complete: mutable boolean = False
        description: "Whether the data_collection stage is complete"
    data_collection_result: mutable string = ""
        description: "Result from the data_collection stage"
    comparable_analysis_complete: mutable boolean = False
        description: "Whether the comparable_analysis stage is complete"
    comparable_analysis_result: mutable string = ""
        description: "Result from the comparable_analysis stage"
    adjustment_complete: mutable boolean = False
        description: "Whether the adjustment stage is complete"
    adjustment_result: mutable string = ""
        description: "Result from the adjustment stage"
    report_generation_complete: mutable boolean = False
        description: "Whether the report_generation stage is complete"
    report_generation_result: mutable string = ""
        description: "Result from the report_generation stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate valuation management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a property valuation specialist assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current valuation status: {! @variables.valuation_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_data_collection} for data collection requests.
              Use {!@actions.go_to_comparable_analysis} for comparable analysis requests.
              Use {!@actions.go_to_adjustment} for adjustment requests.
              Use {!@actions.go_to_report_generation} for report generation requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_data_collection: @utils.transition to @topic.data_collection
                description: "Transition to data collection topic."
            go_to_comparable_analysis: @utils.transition to @topic.comparable_analysis
                description: "Transition to comparable analysis topic."
                available when @variables.is_verified == True
            go_to_adjustment: @utils.transition to @topic.adjustment
                description: "Transition to adjustment topic."
                available when @variables.is_verified == True
            go_to_report_generation: @utils.transition to @topic.report_generation
                description: "Transition to report generation topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic data_collection:
    description: "Handles the data collection stage of the valuation process"

    actions:
        process_data_collection_data:
            description: "Process data collection stage data for the valuation"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_DataCollection"

        validate_data_collection_info:
            description: "Validate data collection information for the valuation"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_DataCollection_Info"

        fetch_data_collection_details:
            description: "Fetch data collection details for the valuation"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_DataCollection_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_data_collection_info
                with record_ref=@variables.valuation_record_id
                with contact_ref=@variables.contact_email
                set @variables.valuation_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the data collection stage for the valuation.
              Current valuation status: {! @variables.valuation_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Data Collection result: {! @variables.data_collection_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.valuation_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_data_collection} to begin processing.
        actions:
            run_data_collection: @actions.process_data_collection_data
                with record_ref=@variables.valuation_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.valuation_category
                set @variables.data_collection_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.data_collection_complete = @outputs.is_passed
            fetch_data_collection_info: @actions.fetch_data_collection_details
                with record_ref=@variables.valuation_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.valuation_tier = @outputs.tier_value
            go_to_comparable_analysis: @utils.transition to @topic.comparable_analysis
                description: "Move to comparable analysis stage."
                available when @variables.data_collection_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.valuation_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.valuation_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.valuation_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.data_collection_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic comparable_analysis:
    description: "Handles the comparable analysis stage of the valuation process"

    actions:
        process_comparable_analysis_data:
            description: "Process comparable analysis stage data for the valuation"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_ComparableAnalysis"

        validate_comparable_analysis_info:
            description: "Validate comparable analysis information for the valuation"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_ComparableAnalysis_Info"

        fetch_comparable_analysis_details:
            description: "Fetch comparable analysis details for the valuation"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_ComparableAnalysis_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.data_collection_complete == False:
            transition to @topic.data_collection

    reasoning:
        instructions: ->
            | Handle the comparable analysis stage for the valuation.
              Current valuation status: {! @variables.valuation_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Comparable Analysis result: {! @variables.comparable_analysis_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.valuation_tier }
              Review the comparable analysis results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_comparable_analysis: @actions.process_comparable_analysis_data
                with record_ref=@variables.valuation_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.valuation_category
                set @variables.comparable_analysis_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.comparable_analysis_complete = @outputs.is_passed
            fetch_comparable_analysis_info: @actions.fetch_comparable_analysis_details
                with record_ref=@variables.valuation_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.valuation_tier = @outputs.tier_value
                available when @variables.valuation_record_id is not None
            go_to_adjustment: @utils.transition to @topic.adjustment
                description: "Move to adjustment stage."
                available when @variables.comparable_analysis_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.comparable_analysis_complete == True:
            set @variables.valuation_status = "comparable_analysis_done"
        if @variables.comparable_analysis_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.adjustment
        if @variables.attempt_count >= 3 and @variables.comparable_analysis_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic adjustment:
    description: "Handles the adjustment stage of the valuation process"

    actions:
        process_adjustment_data:
            description: "Process adjustment stage data for the valuation"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_Adjustment_Data"

        validate_adjustment_info:
            description: "Validate adjustment information for the valuation"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Adjustment_Info"

        fetch_adjustment_details:
            description: "Fetch adjustment details for the valuation"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Adjustment_Details"

    before_reasoning:
        if @variables.adjustment_complete == False:
            run @actions.fetch_adjustment_details
                with record_ref=@variables.valuation_record_id
                with include_history=True
                set @variables.adjustment_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.valuation_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.valuation_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.valuation_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the adjustment stage for the valuation.
              Current valuation status: {! @variables.valuation_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Adjustment result: {! @variables.adjustment_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.valuation_tier }
              Review the adjustment results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_adjustment: @actions.process_adjustment_data
                with record_ref=@variables.valuation_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.valuation_category
                set @variables.adjustment_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.adjustment_complete = @outputs.is_passed
            fetch_adjustment_info: @actions.fetch_adjustment_details
                with record_ref=@variables.valuation_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.valuation_tier = @outputs.tier_value
                available when @variables.valuation_record_id is not None
            go_to_report_generation: @utils.transition to @topic.report_generation
                description: "Move to report generation stage."
                available when @variables.adjustment_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.valuation_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.valuation_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.valuation_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.adjustment_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic report_generation:
    description: "Handles the report generation stage of the valuation process"

    actions:
        process_report_generation_data:
            description: "Process report generation stage data for the valuation"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_ReportGeneration"

        validate_report_generation_info:
            description: "Validate report generation information for the valuation"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_ReportGeneration_Info"

        fetch_report_generation_details:
            description: "Fetch report generation details for the valuation"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_ReportGeneration_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.adjustment_complete == False:
            transition to @topic.adjustment
        if @variables.eligibility_score >= 80:
            set @variables.valuation_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.valuation_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the report generation stage for the valuation.
              Current valuation status: {! @variables.valuation_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Report Generation result: {! @variables.report_generation_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.valuation_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_report_generation: @actions.process_report_generation_data
                with record_ref=@variables.valuation_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.valuation_category
                set @variables.report_generation_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.report_generation_complete = @outputs.is_passed
            fetch_report_generation_info: @actions.fetch_report_generation_details
                with record_ref=@variables.valuation_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.valuation_tier = @outputs.tier_value
                available when @variables.valuation_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.report_generation_complete == True:
            set @variables.valuation_status = "report_generation_done"
        if @variables.attempt_count >= 3 and @variables.report_generation_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for valuation issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the valuation issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the valuation interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the valuation request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Valuation status: {! @variables.valuation_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.valuation_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.valuation_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.valuation_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.valuation_status = "escalated"
        set @variables.escalation_requested = False

