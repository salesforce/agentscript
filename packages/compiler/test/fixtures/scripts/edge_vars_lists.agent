# Focus on list variable types
system:
    instructions: "You are an agent for testing list variable types."

config:
    agent_name: "List_Vars_Agent"
    agent_type: "AgentforceServiceAgent"
    developer_name: "List_Vars_Agent"
    description: "Agent focused on list variable types"

variables:
    tags: mutable list[string] = None
        description: "List of tag strings"
    scores: mutable list[number] = None
        description: "List of numeric scores"
    flags: mutable list[boolean] = None
        description: "List of boolean flags"
    records: mutable list[object] = None
        description: "List of object records"
    categories: mutable list[string] = None
        description: "List of category names"
    weights: mutable list[number] = None
        description: "List of weight values"

start_agent main:
    description: "Process list variables"
    reasoning:
        instructions: ->
            | Handle list data for tags, scores, and records
