system:
    instructions: "You are a knowledge-enabled assistant."
    messages:
        welcome: "Hello! I can search our knowledge base for you."
        error: "An error occurred."

config:
    developer_name: "Edge_Knowledge_Basic"
    default_agent_user: "test_user"
    description: "Tests basic knowledge block with citations_enabled"

knowledge:
    citations_enabled: True

start_agent main:
    description: "Agent with basic knowledge block"

    reasoning:
        instructions: ->
            | I can help you find information from our knowledge base.
              What would you like to know?
