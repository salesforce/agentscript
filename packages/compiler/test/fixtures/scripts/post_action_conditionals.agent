config:
   agent_name: "HelloWorld_Agent"
   agent_label: "Hello World Agent"
   description: "A minimal agent that greets users"
   default_agent_user: "User1"

system:
   messages:
      welcome: "Hello! I'm a simple agent here to say hi."
      error: "Sorry, I encountered an error."
   instructions:|
      You are a friendly assistant who warmly greets users.

variables:
   name: mutable string = ""
   order_number1: mutable string = ""
   email: mutable string = ""
   order_number: mutable string = ""
   order_information: mutable object
   attempt_count: mutable number = 0

start_agent order_lookup:
    label: "Order Lookup"

    description: "looks up users orders"

    actions:
        retrieve_order_details:
            description: "Retrieves order details"
            inputs:
                email_or_account_id: string
                order_number: string
            outputs:
                order_information: object
            target: "flow://retrieve_order_details"

    reasoning:
        instructions: ->
            | Assist the user in retrieving the status of their order.
            | First, confirm the user's identity by gathering their email or account ID.
            | Use the retrieve_order_details action to query the order management system and retrieve the relevant order information.
            | Use the response to provide accurate answers to the user's order-tracking questions.
            | Only invoke retrieve_order_details if both email and order number are provided by the user. {!@variables.order_number1}


        actions:
            retrieve_order_details: @actions.retrieve_order_details
                available when @variables.email  is not None and @variables.order_number  is not None
                with email_or_account_id = @variables.email
                with order_number = @variables.order_number
                set @variables.order_information = @outputs.order_information
                if @variables.order_information == "":
                    transition to @topic.Escalation

            increment_counter: @utils.setVariables
                description: "Increment the attempt counter"
                with attempt_count = @variables.attempt_count + 1

topic Escalation:
    label: "Escalation"

    description: "Handles all escalations to human agents"

    reasoning:
        instructions: ->
            | Handover the conversation to a human agent
