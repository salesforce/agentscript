system:
    instructions: |
        You are a professional performance review coordinator assistant.
        Help users manage their review requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: goal_setting -> self_assessment -> manager_review -> calibration.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Performance Review Coordinator Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "performance_review_agent_v43"
    default_agent_user: "performance_review@example.com"
    agent_description: "Assists users with review management through the performance review coordinator workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    review_record_id: mutable string
        description: "Record ID of the review"
    review_status: mutable string = ""
        description: "Current status of the review"
    review_tier: mutable string = "standard"
        description: "Tier classification for the review"
    review_category: mutable string = ""
        description: "Category of the review"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    goal_setting_complete: mutable boolean = False
        description: "Whether the goal_setting stage is complete"
    goal_setting_result: mutable string = ""
        description: "Result from the goal_setting stage"
    self_assessment_complete: mutable boolean = False
        description: "Whether the self_assessment stage is complete"
    self_assessment_result: mutable string = ""
        description: "Result from the self_assessment stage"
    manager_review_complete: mutable boolean = False
        description: "Whether the manager_review stage is complete"
    manager_review_result: mutable string = ""
        description: "Result from the manager_review stage"
    calibration_complete: mutable boolean = False
        description: "Whether the calibration stage is complete"
    calibration_result: mutable string = ""
        description: "Result from the calibration stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate review management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a performance review coordinator assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current review status: {! @variables.review_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_goal_setting} for goal setting requests.
              Use {!@actions.go_to_self_assessment} for self assessment requests.
              Use {!@actions.go_to_manager_review} for manager review requests.
              Use {!@actions.go_to_calibration} for calibration requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_goal_setting: @utils.transition to @topic.goal_setting
                description: "Transition to goal setting topic."
            go_to_self_assessment: @utils.transition to @topic.self_assessment
                description: "Transition to self assessment topic."
                available when @variables.is_verified == True
            go_to_manager_review: @utils.transition to @topic.manager_review
                description: "Transition to manager review topic."
                available when @variables.is_verified == True
            go_to_calibration: @utils.transition to @topic.calibration
                description: "Transition to calibration topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic goal_setting:
    description: "Handles the goal setting stage of the review process"

    actions:
        process_goal_setting_data:
            description: "Process goal setting stage data for the review"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_GoalSetting_Data"

        validate_goal_setting_info:
            description: "Validate goal setting information for the review"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_GoalSetting_Info"

        fetch_goal_setting_details:
            description: "Fetch goal setting details for the review"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_GoalSetting_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_goal_setting_info
                with record_ref=@variables.review_record_id
                with contact_ref=@variables.contact_email
                set @variables.review_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the goal setting stage for the review.
              Current review status: {! @variables.review_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Goal Setting result: {! @variables.goal_setting_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.review_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_goal_setting} to begin processing.
        actions:
            run_goal_setting: @actions.process_goal_setting_data
                with record_ref=@variables.review_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.review_category
                set @variables.goal_setting_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.goal_setting_complete = @outputs.is_passed
            fetch_goal_setting_info: @actions.fetch_goal_setting_details
                with record_ref=@variables.review_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.review_tier = @outputs.tier_value
            go_to_self_assessment: @utils.transition to @topic.self_assessment
                description: "Move to self assessment stage."
                available when @variables.goal_setting_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.review_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.review_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.review_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.goal_setting_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic self_assessment:
    description: "Handles the self assessment stage of the review process"

    actions:
        process_self_assessment_data:
            description: "Process self assessment stage data for the review"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_SelfAssessment"

        validate_self_assessment_info:
            description: "Validate self assessment information for the review"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_SelfAssessment_Info"

        fetch_self_assessment_details:
            description: "Fetch self assessment details for the review"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_SelfAssessment_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.goal_setting_complete == False:
            transition to @topic.goal_setting

    reasoning:
        instructions: ->
            | Handle the self assessment stage for the review.
              Current review status: {! @variables.review_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Self Assessment result: {! @variables.self_assessment_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.review_tier }
              Review the self assessment results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_self_assessment: @actions.process_self_assessment_data
                with record_ref=@variables.review_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.review_category
                set @variables.self_assessment_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.self_assessment_complete = @outputs.is_passed
            fetch_self_assessment_info: @actions.fetch_self_assessment_details
                with record_ref=@variables.review_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.review_tier = @outputs.tier_value
                available when @variables.review_record_id is not None
            go_to_manager_review: @utils.transition to @topic.manager_review
                description: "Move to manager review stage."
                available when @variables.self_assessment_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.self_assessment_complete == True:
            set @variables.review_status = "self_assessment_done"
        if @variables.self_assessment_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.manager_review
        if @variables.attempt_count >= 3 and @variables.self_assessment_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic manager_review:
    description: "Handles the manager review stage of the review process"

    actions:
        process_manager_review_data:
            description: "Process manager review stage data for the review"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_ManagerReview"

        validate_manager_review_info:
            description: "Validate manager review information for the review"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_ManagerReview_Info"

        fetch_manager_review_details:
            description: "Fetch manager review details for the review"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_ManagerReview_Details"

    before_reasoning:
        if @variables.manager_review_complete == False:
            run @actions.fetch_manager_review_details
                with record_ref=@variables.review_record_id
                with include_history=True
                set @variables.manager_review_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.review_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.review_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.review_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the manager review stage for the review.
              Current review status: {! @variables.review_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Manager Review result: {! @variables.manager_review_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.review_tier }
              Review the manager review results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_manager_review: @actions.process_manager_review_data
                with record_ref=@variables.review_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.review_category
                set @variables.manager_review_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.manager_review_complete = @outputs.is_passed
            fetch_manager_review_info: @actions.fetch_manager_review_details
                with record_ref=@variables.review_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.review_tier = @outputs.tier_value
                available when @variables.review_record_id is not None
            go_to_calibration: @utils.transition to @topic.calibration
                description: "Move to calibration stage."
                available when @variables.manager_review_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.review_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.review_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.review_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.manager_review_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic calibration:
    description: "Handles the calibration stage of the review process"

    actions:
        process_calibration_data:
            description: "Process calibration stage data for the review"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_Calibration_Data"

        validate_calibration_info:
            description: "Validate calibration information for the review"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Calibration_Info"

        fetch_calibration_details:
            description: "Fetch calibration details for the review"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Calibration_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.manager_review_complete == False:
            transition to @topic.manager_review
        if @variables.eligibility_score >= 80:
            set @variables.review_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.review_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the calibration stage for the review.
              Current review status: {! @variables.review_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Calibration result: {! @variables.calibration_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.review_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_calibration: @actions.process_calibration_data
                with record_ref=@variables.review_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.review_category
                set @variables.calibration_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.calibration_complete = @outputs.is_passed
            fetch_calibration_info: @actions.fetch_calibration_details
                with record_ref=@variables.review_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.review_tier = @outputs.tier_value
                available when @variables.review_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.calibration_complete == True:
            set @variables.review_status = "calibration_done"
        if @variables.attempt_count >= 3 and @variables.calibration_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for review issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the review issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the review interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the review request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Review status: {! @variables.review_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.review_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.review_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.review_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.review_status = "escalated"
        set @variables.escalation_requested = False

