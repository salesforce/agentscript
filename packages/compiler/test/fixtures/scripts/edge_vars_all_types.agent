# Every variable type
system:
    instructions: "You are an agent for testing all variable types."

config:
    agent_name: "All_Types_Agent"
    agent_type: "AgentforceServiceAgent"
    developer_name: "All_Types_Agent"
    description: "Agent with every variable type"

variables:
    text_val: mutable string = "hello"
        description: "A string variable"
    num_val: mutable number = 42
        description: "A number variable"
    bool_val: mutable boolean = True
        description: "A boolean variable"
    obj_val: mutable object = None
        description: "An object variable"
    str_list: mutable list[string] = None
        description: "A list of strings"
    num_list: mutable list[number] = None
        description: "A list of numbers"
    bool_list: mutable list[boolean] = None
        description: "A list of booleans"
    obj_list: mutable list[object] = None
        description: "A list of objects"

start_agent main:
    description: "Entry point testing all variable types"
    reasoning:
        instructions: ->
            | Process with all variable types available
