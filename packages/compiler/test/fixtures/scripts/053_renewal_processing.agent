system:
    instructions: |
        You are a professional renewal processing agent assistant.
        Help users manage their renewal requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: eligibility_review -> rate_recalculation -> offer_generation -> acceptance.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Renewal Processing Agent Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "renewal_processing_agent_v53"
    default_agent_user: "renewal_processing@example.com"
    agent_description: "Assists users with renewal management through the renewal processing agent workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    renewal_record_id: mutable string
        description: "Record ID of the renewal"
    renewal_status: mutable string = ""
        description: "Current status of the renewal"
    renewal_tier: mutable string = "standard"
        description: "Tier classification for the renewal"
    renewal_category: mutable string = ""
        description: "Category of the renewal"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    eligibility_review_complete: mutable boolean = False
        description: "Whether the eligibility_review stage is complete"
    eligibility_review_result: mutable string = ""
        description: "Result from the eligibility_review stage"
    rate_recalculation_complete: mutable boolean = False
        description: "Whether the rate_recalculation stage is complete"
    rate_recalculation_result: mutable string = ""
        description: "Result from the rate_recalculation stage"
    offer_generation_complete: mutable boolean = False
        description: "Whether the offer_generation stage is complete"
    offer_generation_result: mutable string = ""
        description: "Result from the offer_generation stage"
    acceptance_complete: mutable boolean = False
        description: "Whether the acceptance stage is complete"
    acceptance_result: mutable string = ""
        description: "Result from the acceptance stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate renewal management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a renewal processing agent assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current renewal status: {! @variables.renewal_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_eligibility_review} for eligibility review requests.
              Use {!@actions.go_to_rate_recalculation} for rate recalculation requests.
              Use {!@actions.go_to_offer_generation} for offer generation requests.
              Use {!@actions.go_to_acceptance} for acceptance requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_eligibility_review: @utils.transition to @topic.eligibility_review
                description: "Transition to eligibility review topic."
            go_to_rate_recalculation: @utils.transition to @topic.rate_recalculation
                description: "Transition to rate recalculation topic."
                available when @variables.is_verified == True
            go_to_offer_generation: @utils.transition to @topic.offer_generation
                description: "Transition to offer generation topic."
                available when @variables.is_verified == True
            go_to_acceptance: @utils.transition to @topic.acceptance
                description: "Transition to acceptance topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic eligibility_review:
    description: "Handles the eligibility review stage of the renewal process"

    actions:
        process_eligibility_review_data:
            description: "Process eligibility review stage data for the renewal"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_EligibilityReview"

        validate_eligibility_review_info:
            description: "Validate eligibility review information for the renewal"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_EligibilityReview_Info"

        fetch_eligibility_review_details:
            description: "Fetch eligibility review details for the renewal"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_EligibilityReview_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_eligibility_review_info
                with record_ref=@variables.renewal_record_id
                with contact_ref=@variables.contact_email
                set @variables.renewal_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the eligibility review stage for the renewal.
              Current renewal status: {! @variables.renewal_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Eligibility Review result: {! @variables.eligibility_review_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.renewal_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_eligibility_review} to begin processing.
        actions:
            run_eligibility_review: @actions.process_eligibility_review_data
                with record_ref=@variables.renewal_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.renewal_category
                set @variables.eligibility_review_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.eligibility_review_complete = @outputs.is_passed
            fetch_eligibility_review_info: @actions.fetch_eligibility_review_details
                with record_ref=@variables.renewal_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.renewal_tier = @outputs.tier_value
            go_to_rate_recalculation: @utils.transition to @topic.rate_recalculation
                description: "Move to rate recalculation stage."
                available when @variables.eligibility_review_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.renewal_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.renewal_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.renewal_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.eligibility_review_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic rate_recalculation:
    description: "Handles the rate recalculation stage of the renewal process"

    actions:
        process_rate_recalculation_data:
            description: "Process rate recalculation stage data for the renewal"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_RateRecalculation"

        validate_rate_recalculation_info:
            description: "Validate rate recalculation information for the renewal"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_RateRecalculation_Info"

        fetch_rate_recalculation_details:
            description: "Fetch rate recalculation details for the renewal"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_RateRecalculation_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.eligibility_review_complete == False:
            transition to @topic.eligibility_review

    reasoning:
        instructions: ->
            | Handle the rate recalculation stage for the renewal.
              Current renewal status: {! @variables.renewal_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Rate Recalculation result: {! @variables.rate_recalculation_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.renewal_tier }
              Review the rate recalculation results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_rate_recalculation: @actions.process_rate_recalculation_data
                with record_ref=@variables.renewal_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.renewal_category
                set @variables.rate_recalculation_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.rate_recalculation_complete = @outputs.is_passed
            fetch_rate_recalculation_info: @actions.fetch_rate_recalculation_details
                with record_ref=@variables.renewal_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.renewal_tier = @outputs.tier_value
                available when @variables.renewal_record_id is not None
            go_to_offer_generation: @utils.transition to @topic.offer_generation
                description: "Move to offer generation stage."
                available when @variables.rate_recalculation_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.rate_recalculation_complete == True:
            set @variables.renewal_status = "rate_recalculation_done"
        if @variables.rate_recalculation_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.offer_generation
        if @variables.attempt_count >= 3 and @variables.rate_recalculation_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic offer_generation:
    description: "Handles the offer generation stage of the renewal process"

    actions:
        process_offer_generation_data:
            description: "Process offer generation stage data for the renewal"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_OfferGeneration_Data"

        validate_offer_generation_info:
            description: "Validate offer generation information for the renewal"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_OfferGeneration_Info"

        fetch_offer_generation_details:
            description: "Fetch offer generation details for the renewal"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_OfferGeneration_Details"

    before_reasoning:
        if @variables.offer_generation_complete == False:
            run @actions.fetch_offer_generation_details
                with record_ref=@variables.renewal_record_id
                with include_history=True
                set @variables.offer_generation_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.renewal_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.renewal_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.renewal_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the offer generation stage for the renewal.
              Current renewal status: {! @variables.renewal_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Offer Generation result: {! @variables.offer_generation_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.renewal_tier }
              Review the offer generation results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_offer_generation: @actions.process_offer_generation_data
                with record_ref=@variables.renewal_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.renewal_category
                set @variables.offer_generation_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.offer_generation_complete = @outputs.is_passed
            fetch_offer_generation_info: @actions.fetch_offer_generation_details
                with record_ref=@variables.renewal_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.renewal_tier = @outputs.tier_value
                available when @variables.renewal_record_id is not None
            go_to_acceptance: @utils.transition to @topic.acceptance
                description: "Move to acceptance stage."
                available when @variables.offer_generation_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.renewal_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.renewal_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.renewal_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.offer_generation_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic acceptance:
    description: "Handles the acceptance stage of the renewal process"

    actions:
        process_acceptance_data:
            description: "Process acceptance stage data for the renewal"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_Acceptance"

        validate_acceptance_info:
            description: "Validate acceptance information for the renewal"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Acceptance_Info"

        fetch_acceptance_details:
            description: "Fetch acceptance details for the renewal"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Acceptance_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.offer_generation_complete == False:
            transition to @topic.offer_generation
        if @variables.eligibility_score >= 80:
            set @variables.renewal_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.renewal_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the acceptance stage for the renewal.
              Current renewal status: {! @variables.renewal_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Acceptance result: {! @variables.acceptance_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.renewal_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_acceptance: @actions.process_acceptance_data
                with record_ref=@variables.renewal_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.renewal_category
                set @variables.acceptance_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.acceptance_complete = @outputs.is_passed
            fetch_acceptance_info: @actions.fetch_acceptance_details
                with record_ref=@variables.renewal_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.renewal_tier = @outputs.tier_value
                available when @variables.renewal_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.acceptance_complete == True:
            set @variables.renewal_status = "acceptance_done"
        if @variables.attempt_count >= 3 and @variables.acceptance_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for renewal issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the renewal issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the renewal interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the renewal request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Renewal status: {! @variables.renewal_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.renewal_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.renewal_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.renewal_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.renewal_status = "escalated"
        set @variables.escalation_requested = False

