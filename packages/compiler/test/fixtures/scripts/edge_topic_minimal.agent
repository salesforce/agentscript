system:
    instructions: "You are a minimal agent."
    messages:
        welcome: "Hello!"
        error: "Error."

config:
    developer_name: "Minimal_Topics_Agent"
    default_agent_user: "user@test.com"

start_agent main:
    description: "Minimal agent"

    reasoning:
        instructions: ->
            | Help the user with their request.

        actions:
            go_to_help: @utils.transition to @topic.help

topic help:
    description: "Help topic"

    reasoning:
        instructions: ->
            | Help the user with their request.

