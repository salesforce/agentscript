# Linked variables from different sources
system:
    instructions: "You are an agent that uses linked session data."
    messages:
        welcome: "Hello {!@variables.end_user_name}!"
        error: "An error occurred."

config:
    agent_name: "Linked_Vars_Agent"
    agent_type: "AgentforceServiceAgent"
    developer_name: "Linked_Vars_Agent"
    description: "Agent with linked variables from various sources"

variables:
    session_id: linked string
        source: @MessagingSession.Id
        description: "The messaging session ID"
    session_key: linked string
        source: @MessagingSession.SessionKey
        description: "The messaging session key"
    end_user_name: linked string
        source: @MessagingEndUser.Name
        description: "The end user's name"
    end_user_id: linked string
        source: @MessagingEndUser.Id
        description: "The end user's ID"
    end_user_language: linked string
        source: @MessagingSession.EndUserLanguage
        description: "The end user's language"
    contact_id: linked string
        source: @MessagingEndUser.ContactId
        description: "The contact ID of the end user"
    voice_call_id: linked string
        source: @VoiceCall.Id
        description: "This variable may also be referred to as Voice Call Id"

start_agent main:
    description: "Route using linked session data"
    reasoning:
        instructions: ->
            | Route based on session context and user information
