system:
    instructions: "You are a support assistant with described escalation."
    messages:
        welcome: "Hello! How can I help?"
        error: "An error occurred."

config:
    developer_name: "Edge_Escalation_With_Desc"
    default_agent_user: "test_user"
    description: "Tests @utils.escalate with description field"

start_agent main:
    description: "Main topic with described escalation"

    reasoning:
        instructions: ->
            | I'm here to help. If your issue requires a human agent, I can transfer you.

        actions:
            escalate_to_human: @utils.escalate
                description: "Escalate to human agent for complex issues"

            go_to_help: @utils.transition to @topic.self_help

topic self_help:
    description: "Self-help resources"

    reasoning:
        instructions: ->
            | Here are some self-help resources you might find useful.
