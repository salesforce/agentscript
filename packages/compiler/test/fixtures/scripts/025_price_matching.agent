system:
    instructions: |
        You are a professional price matching agent assistant.
        Help users manage their price_match requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: competitor_lookup -> policy_check -> approval -> adjustment.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Price Matching Agent Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "price_matching_agent_v25"
    default_agent_user: "price_matching@example.com"
    agent_description: "Assists users with price_match management through the price matching agent workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    price_match_record_id: mutable string
        description: "Record ID of the price_match"
    price_match_status: mutable string = ""
        description: "Current status of the price_match"
    price_match_tier: mutable string = "standard"
        description: "Tier classification for the price_match"
    price_match_category: mutable string = ""
        description: "Category of the price_match"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    competitor_lookup_complete: mutable boolean = False
        description: "Whether the competitor_lookup stage is complete"
    competitor_lookup_result: mutable string = ""
        description: "Result from the competitor_lookup stage"
    policy_check_complete: mutable boolean = False
        description: "Whether the policy_check stage is complete"
    policy_check_result: mutable string = ""
        description: "Result from the policy_check stage"
    approval_complete: mutable boolean = False
        description: "Whether the approval stage is complete"
    approval_result: mutable string = ""
        description: "Result from the approval stage"
    adjustment_complete: mutable boolean = False
        description: "Whether the adjustment stage is complete"
    adjustment_result: mutable string = ""
        description: "Result from the adjustment stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate price_match management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a price matching agent assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current price_match status: {! @variables.price_match_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_competitor_lookup} for competitor lookup requests.
              Use {!@actions.go_to_policy_check} for policy check requests.
              Use {!@actions.go_to_approval} for approval requests.
              Use {!@actions.go_to_adjustment} for adjustment requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_competitor_lookup: @utils.transition to @topic.competitor_lookup
                description: "Transition to competitor lookup topic."
            go_to_policy_check: @utils.transition to @topic.policy_check
                description: "Transition to policy check topic."
                available when @variables.is_verified == True
            go_to_approval: @utils.transition to @topic.approval
                description: "Transition to approval topic."
                available when @variables.is_verified == True
            go_to_adjustment: @utils.transition to @topic.adjustment
                description: "Transition to adjustment topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic competitor_lookup:
    description: "Handles the competitor lookup stage of the price_match process"

    actions:
        process_competitor_lookup_data:
            description: "Process competitor lookup stage data for the price_match"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_CompetitorLookup_Data"

        validate_competitor_lookup_info:
            description: "Validate competitor lookup information for the price_match"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_CompetitorLookup_Info"

        fetch_competitor_lookup_details:
            description: "Fetch competitor lookup details for the price_match"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_CompetitorLookup_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_competitor_lookup_info
                with record_ref=@variables.price_match_record_id
                with contact_ref=@variables.contact_email
                set @variables.price_match_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the competitor lookup stage for the price_match.
              Current price_match status: {! @variables.price_match_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Competitor Lookup result: {! @variables.competitor_lookup_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.price_match_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_competitor_lookup} to begin processing.
        actions:
            run_competitor_lookup: @actions.process_competitor_lookup_data
                with record_ref=@variables.price_match_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.price_match_category
                set @variables.competitor_lookup_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.competitor_lookup_complete = @outputs.is_passed
            fetch_competitor_lookup_info: @actions.fetch_competitor_lookup_details
                with record_ref=@variables.price_match_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.price_match_tier = @outputs.tier_value
            go_to_policy_check: @utils.transition to @topic.policy_check
                description: "Move to policy check stage."
                available when @variables.competitor_lookup_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.price_match_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.price_match_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.price_match_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.competitor_lookup_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic policy_check:
    description: "Handles the policy check stage of the price_match process"

    actions:
        process_policy_check_data:
            description: "Process policy check stage data for the price_match"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_PolicyCheck"

        validate_policy_check_info:
            description: "Validate policy check information for the price_match"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_PolicyCheck_Info"

        fetch_policy_check_details:
            description: "Fetch policy check details for the price_match"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_PolicyCheck_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.competitor_lookup_complete == False:
            transition to @topic.competitor_lookup

    reasoning:
        instructions: ->
            | Handle the policy check stage for the price_match.
              Current price_match status: {! @variables.price_match_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Policy Check result: {! @variables.policy_check_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.price_match_tier }
              Review the policy check results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_policy_check: @actions.process_policy_check_data
                with record_ref=@variables.price_match_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.price_match_category
                set @variables.policy_check_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.policy_check_complete = @outputs.is_passed
            fetch_policy_check_info: @actions.fetch_policy_check_details
                with record_ref=@variables.price_match_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.price_match_tier = @outputs.tier_value
                available when @variables.price_match_record_id is not None
            go_to_approval: @utils.transition to @topic.approval
                description: "Move to approval stage."
                available when @variables.policy_check_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.policy_check_complete == True:
            set @variables.price_match_status = "policy_check_done"
        if @variables.policy_check_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.approval
        if @variables.attempt_count >= 3 and @variables.policy_check_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic approval:
    description: "Handles the approval stage of the price_match process"

    actions:
        process_approval_data:
            description: "Process approval stage data for the price_match"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_Approval"

        validate_approval_info:
            description: "Validate approval information for the price_match"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Approval_Info"

        fetch_approval_details:
            description: "Fetch approval details for the price_match"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Approval_Details"

    before_reasoning:
        if @variables.approval_complete == False:
            run @actions.fetch_approval_details
                with record_ref=@variables.price_match_record_id
                with include_history=True
                set @variables.approval_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.price_match_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.price_match_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.price_match_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the approval stage for the price_match.
              Current price_match status: {! @variables.price_match_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Approval result: {! @variables.approval_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.price_match_tier }
              Review the approval results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_approval: @actions.process_approval_data
                with record_ref=@variables.price_match_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.price_match_category
                set @variables.approval_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.approval_complete = @outputs.is_passed
            fetch_approval_info: @actions.fetch_approval_details
                with record_ref=@variables.price_match_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.price_match_tier = @outputs.tier_value
                available when @variables.price_match_record_id is not None
            go_to_adjustment: @utils.transition to @topic.adjustment
                description: "Move to adjustment stage."
                available when @variables.approval_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.price_match_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.price_match_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.price_match_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.approval_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic adjustment:
    description: "Handles the adjustment stage of the price_match process"

    actions:
        process_adjustment_data:
            description: "Process adjustment stage data for the price_match"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_Adjustment_Data"

        validate_adjustment_info:
            description: "Validate adjustment information for the price_match"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Adjustment_Info"

        fetch_adjustment_details:
            description: "Fetch adjustment details for the price_match"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Adjustment_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.approval_complete == False:
            transition to @topic.approval
        if @variables.eligibility_score >= 80:
            set @variables.price_match_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.price_match_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the adjustment stage for the price_match.
              Current price_match status: {! @variables.price_match_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Adjustment result: {! @variables.adjustment_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.price_match_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_adjustment: @actions.process_adjustment_data
                with record_ref=@variables.price_match_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.price_match_category
                set @variables.adjustment_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.adjustment_complete = @outputs.is_passed
            fetch_adjustment_info: @actions.fetch_adjustment_details
                with record_ref=@variables.price_match_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.price_match_tier = @outputs.tier_value
                available when @variables.price_match_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.adjustment_complete == True:
            set @variables.price_match_status = "adjustment_done"
        if @variables.attempt_count >= 3 and @variables.adjustment_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for price_match issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the price_match issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the price_match interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the price_match request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Price Match status: {! @variables.price_match_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.price_match_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.price_match_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.price_match_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.price_match_status = "escalated"
        set @variables.escalation_requested = False

