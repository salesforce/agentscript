system:
    instructions: "You are a central routing agent for customer service."
    messages:
        welcome: "Hello! How can I help you today?"
        error: "An error occurred. Please try again."

config:
    developer_name: "Hub_Topics_Agent"
    default_agent_user: "user@test.com"
    description: "Hub agent that routes to many specialized topics"

start_agent main:
    description: "Hub agent that routes to many specialized topics"

    reasoning:
        instructions: ->
            | You are a central routing agent. Determine the user's need
              and route them to the appropriate specialized topic.

        actions:
            go_to_orders: @utils.transition to @topic.orders
            go_to_payments: @utils.transition to @topic.payments
            go_to_shipping: @utils.transition to @topic.shipping
            go_to_returns: @utils.transition to @topic.returns
            go_to_account: @utils.transition to @topic.account
            go_to_promotions: @utils.transition to @topic.promotions
            escalate_to_human: @utils.escalate
                description: "Escalate to a human agent"

topic orders:
    description: "Handle order-related inquiries"

    reasoning:
        instructions: ->
            | Help the user with order questions.

topic payments:
    description: "Handle payment-related inquiries"

    reasoning:
        instructions: ->
            | Help the user with payment questions.

topic shipping:
    description: "Handle shipping-related inquiries"

    reasoning:
        instructions: ->
            | Help the user with shipping questions.

topic returns:
    description: "Handle return requests"

    reasoning:
        instructions: ->
            | Help the user with return requests.

topic account:
    description: "Handle account management"

    reasoning:
        instructions: ->
            | Help the user manage their account.

topic promotions:
    description: "Handle promotions and discounts"

    reasoning:
        instructions: ->
            | Help the user with promotions and discount codes.

