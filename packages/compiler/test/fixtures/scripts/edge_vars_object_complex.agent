# Object variables with complex_data_type_name annotations
system:
    instructions: "You are an agent for testing complex object type annotations."

config:
    agent_name: "Complex_Object_Agent"
    agent_type: "AgentforceServiceAgent"
    developer_name: "Complex_Object_Agent"
    description: "Agent with complex object type annotations"

variables:
    contact_record: mutable object = None
        description: "A contact record"
    case_record: mutable object = None
        description: "A case record"
    order_items: mutable list[object] = None
        description: "List of order line items"
    account_data: mutable object = None
        description: "Account information"
    custom_payload: mutable object = None
        description: "Custom API response payload"

start_agent main:
    description: "Work with complex object variables"
    reasoning:
        instructions: ->
            | Load contact and case records for the user
