system:
    instructions: |
        You are a professional license renewal specialist assistant.
        Help users manage their renewal_app requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: eligibility_check -> document_review -> fee_processing -> issuance.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your License Renewal Specialist Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "license_renewal_agent_v92"
    default_agent_user: "license_renewal@example.com"
    agent_description: "Assists users with renewal_app management through the license renewal specialist workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    renewal_app_record_id: mutable string
        description: "Record ID of the renewal_app"
    renewal_app_status: mutable string = ""
        description: "Current status of the renewal_app"
    renewal_app_tier: mutable string = "standard"
        description: "Tier classification for the renewal_app"
    renewal_app_category: mutable string = ""
        description: "Category of the renewal_app"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    eligibility_check_complete: mutable boolean = False
        description: "Whether the eligibility_check stage is complete"
    eligibility_check_result: mutable string = ""
        description: "Result from the eligibility_check stage"
    document_review_complete: mutable boolean = False
        description: "Whether the document_review stage is complete"
    document_review_result: mutable string = ""
        description: "Result from the document_review stage"
    fee_processing_complete: mutable boolean = False
        description: "Whether the fee_processing stage is complete"
    fee_processing_result: mutable string = ""
        description: "Result from the fee_processing stage"
    issuance_complete: mutable boolean = False
        description: "Whether the issuance stage is complete"
    issuance_result: mutable string = ""
        description: "Result from the issuance stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate renewal_app management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a license renewal specialist assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current renewal_app status: {! @variables.renewal_app_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_eligibility_check} for eligibility check requests.
              Use {!@actions.go_to_document_review} for document review requests.
              Use {!@actions.go_to_fee_processing} for fee processing requests.
              Use {!@actions.go_to_issuance} for issuance requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_eligibility_check: @utils.transition to @topic.eligibility_check
                description: "Transition to eligibility check topic."
            go_to_document_review: @utils.transition to @topic.document_review
                description: "Transition to document review topic."
                available when @variables.is_verified == True
            go_to_fee_processing: @utils.transition to @topic.fee_processing
                description: "Transition to fee processing topic."
                available when @variables.is_verified == True
            go_to_issuance: @utils.transition to @topic.issuance
                description: "Transition to issuance topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic eligibility_check:
    description: "Handles the eligibility check stage of the renewal_app process"

    actions:
        process_eligibility_check_data:
            description: "Process eligibility check stage data for the renewal_app"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_EligibilityCheck"

        validate_eligibility_check_info:
            description: "Validate eligibility check information for the renewal_app"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_EligibilityCheck_Info"

        fetch_eligibility_check_details:
            description: "Fetch eligibility check details for the renewal_app"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_EligibilityCheck_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_eligibility_check_info
                with record_ref=@variables.renewal_app_record_id
                with contact_ref=@variables.contact_email
                set @variables.renewal_app_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the eligibility check stage for the renewal_app.
              Current renewal_app status: {! @variables.renewal_app_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Eligibility Check result: {! @variables.eligibility_check_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.renewal_app_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_eligibility_check} to begin processing.
        actions:
            run_eligibility_check: @actions.process_eligibility_check_data
                with record_ref=@variables.renewal_app_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.renewal_app_category
                set @variables.eligibility_check_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.eligibility_check_complete = @outputs.is_passed
            fetch_eligibility_check_info: @actions.fetch_eligibility_check_details
                with record_ref=@variables.renewal_app_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.renewal_app_tier = @outputs.tier_value
            go_to_document_review: @utils.transition to @topic.document_review
                description: "Move to document review stage."
                available when @variables.eligibility_check_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.renewal_app_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.renewal_app_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.renewal_app_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.eligibility_check_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic document_review:
    description: "Handles the document review stage of the renewal_app process"

    actions:
        process_document_review_data:
            description: "Process document review stage data for the renewal_app"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_DocumentReview"

        validate_document_review_info:
            description: "Validate document review information for the renewal_app"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_DocumentReview_Info"

        fetch_document_review_details:
            description: "Fetch document review details for the renewal_app"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_DocumentReview_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.eligibility_check_complete == False:
            transition to @topic.eligibility_check

    reasoning:
        instructions: ->
            | Handle the document review stage for the renewal_app.
              Current renewal_app status: {! @variables.renewal_app_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Document Review result: {! @variables.document_review_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.renewal_app_tier }
              Review the document review results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_document_review: @actions.process_document_review_data
                with record_ref=@variables.renewal_app_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.renewal_app_category
                set @variables.document_review_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.document_review_complete = @outputs.is_passed
            fetch_document_review_info: @actions.fetch_document_review_details
                with record_ref=@variables.renewal_app_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.renewal_app_tier = @outputs.tier_value
                available when @variables.renewal_app_record_id is not None
            go_to_fee_processing: @utils.transition to @topic.fee_processing
                description: "Move to fee processing stage."
                available when @variables.document_review_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.document_review_complete == True:
            set @variables.renewal_app_status = "document_review_done"
        if @variables.document_review_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.fee_processing
        if @variables.attempt_count >= 3 and @variables.document_review_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic fee_processing:
    description: "Handles the fee processing stage of the renewal_app process"

    actions:
        process_fee_processing_data:
            description: "Process fee processing stage data for the renewal_app"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_FeeProcessing_Data"

        validate_fee_processing_info:
            description: "Validate fee processing information for the renewal_app"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_FeeProcessing_Info"

        fetch_fee_processing_details:
            description: "Fetch fee processing details for the renewal_app"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_FeeProcessing_Details"

    before_reasoning:
        if @variables.fee_processing_complete == False:
            run @actions.fetch_fee_processing_details
                with record_ref=@variables.renewal_app_record_id
                with include_history=True
                set @variables.fee_processing_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.renewal_app_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.renewal_app_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.renewal_app_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the fee processing stage for the renewal_app.
              Current renewal_app status: {! @variables.renewal_app_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Fee Processing result: {! @variables.fee_processing_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.renewal_app_tier }
              Review the fee processing results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_fee_processing: @actions.process_fee_processing_data
                with record_ref=@variables.renewal_app_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.renewal_app_category
                set @variables.fee_processing_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.fee_processing_complete = @outputs.is_passed
            fetch_fee_processing_info: @actions.fetch_fee_processing_details
                with record_ref=@variables.renewal_app_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.renewal_app_tier = @outputs.tier_value
                available when @variables.renewal_app_record_id is not None
            go_to_issuance: @utils.transition to @topic.issuance
                description: "Move to issuance stage."
                available when @variables.fee_processing_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.renewal_app_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.renewal_app_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.renewal_app_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.fee_processing_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic issuance:
    description: "Handles the issuance stage of the renewal_app process"

    actions:
        process_issuance_data:
            description: "Process issuance stage data for the renewal_app"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_Issuance"

        validate_issuance_info:
            description: "Validate issuance information for the renewal_app"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Issuance_Info"

        fetch_issuance_details:
            description: "Fetch issuance details for the renewal_app"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Issuance_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.fee_processing_complete == False:
            transition to @topic.fee_processing
        if @variables.eligibility_score >= 80:
            set @variables.renewal_app_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.renewal_app_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the issuance stage for the renewal_app.
              Current renewal_app status: {! @variables.renewal_app_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Issuance result: {! @variables.issuance_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.renewal_app_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_issuance: @actions.process_issuance_data
                with record_ref=@variables.renewal_app_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.renewal_app_category
                set @variables.issuance_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.issuance_complete = @outputs.is_passed
            fetch_issuance_info: @actions.fetch_issuance_details
                with record_ref=@variables.renewal_app_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.renewal_app_tier = @outputs.tier_value
                available when @variables.renewal_app_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.issuance_complete == True:
            set @variables.renewal_app_status = "issuance_done"
        if @variables.attempt_count >= 3 and @variables.issuance_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for renewal_app issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the renewal_app issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the renewal_app interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the renewal_app request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Renewal App status: {! @variables.renewal_app_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.renewal_app_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.renewal_app_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.renewal_app_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.renewal_app_status = "escalated"
        set @variables.escalation_requested = False

