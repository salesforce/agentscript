system:
    instructions: |
        You are a professional payment reconciliation specialist assistant.
        Help users manage their payment requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: transaction_matching -> discrepancy_check -> adjustment -> finalization.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Payment Reconciliation Specialist Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "payment_reconciliation_agent_v8"
    default_agent_user: "payment_reconciliation@example.com"
    agent_description: "Assists users with payment management through the payment reconciliation specialist workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    payment_record_id: mutable string
        description: "Record ID of the payment"
    payment_status: mutable string = ""
        description: "Current status of the payment"
    payment_tier: mutable string = "standard"
        description: "Tier classification for the payment"
    payment_category: mutable string = ""
        description: "Category of the payment"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    transaction_matching_complete: mutable boolean = False
        description: "Whether the transaction_matching stage is complete"
    transaction_matching_result: mutable string = ""
        description: "Result from the transaction_matching stage"
    discrepancy_check_complete: mutable boolean = False
        description: "Whether the discrepancy_check stage is complete"
    discrepancy_check_result: mutable string = ""
        description: "Result from the discrepancy_check stage"
    adjustment_complete: mutable boolean = False
        description: "Whether the adjustment stage is complete"
    adjustment_result: mutable string = ""
        description: "Result from the adjustment stage"
    finalization_complete: mutable boolean = False
        description: "Whether the finalization stage is complete"
    finalization_result: mutable string = ""
        description: "Result from the finalization stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate payment management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a payment reconciliation specialist assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current payment status: {! @variables.payment_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_transaction_matching} for transaction matching requests.
              Use {!@actions.go_to_discrepancy_check} for discrepancy check requests.
              Use {!@actions.go_to_adjustment} for adjustment requests.
              Use {!@actions.go_to_finalization} for finalization requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_transaction_matching: @utils.transition to @topic.transaction_matching
                description: "Transition to transaction matching topic."
            go_to_discrepancy_check: @utils.transition to @topic.discrepancy_check
                description: "Transition to discrepancy check topic."
                available when @variables.is_verified == True
            go_to_adjustment: @utils.transition to @topic.adjustment
                description: "Transition to adjustment topic."
                available when @variables.is_verified == True
            go_to_finalization: @utils.transition to @topic.finalization
                description: "Transition to finalization topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic transaction_matching:
    description: "Handles the transaction matching stage of the payment process"

    actions:
        process_transaction_matching_data:
            description: "Process transaction matching stage data for the payment"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_TransactionMatching"

        validate_transaction_matching_info:
            description: "Validate transaction matching information for the payment"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_TransactionMatching_Info"

        fetch_transaction_matching_details:
            description: "Fetch transaction matching details for the payment"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_TransactionMatching_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_transaction_matching_info
                with record_ref=@variables.payment_record_id
                with contact_ref=@variables.contact_email
                set @variables.payment_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the transaction matching stage for the payment.
              Current payment status: {! @variables.payment_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Transaction Matching result: {! @variables.transaction_matching_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.payment_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_transaction_matching} to begin processing.
        actions:
            run_transaction_matching: @actions.process_transaction_matching_data
                with record_ref=@variables.payment_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.payment_category
                set @variables.transaction_matching_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.transaction_matching_complete = @outputs.is_passed
            fetch_transaction_matching_info: @actions.fetch_transaction_matching_details
                with record_ref=@variables.payment_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.payment_tier = @outputs.tier_value
            go_to_discrepancy_check: @utils.transition to @topic.discrepancy_check
                description: "Move to discrepancy check stage."
                available when @variables.transaction_matching_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.payment_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.payment_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.payment_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.transaction_matching_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic discrepancy_check:
    description: "Handles the discrepancy check stage of the payment process"

    actions:
        process_discrepancy_check_data:
            description: "Process discrepancy check stage data for the payment"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_DiscrepancyCheck"

        validate_discrepancy_check_info:
            description: "Validate discrepancy check information for the payment"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_DiscrepancyCheck_Info"

        fetch_discrepancy_check_details:
            description: "Fetch discrepancy check details for the payment"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_DiscrepancyCheck_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.transaction_matching_complete == False:
            transition to @topic.transaction_matching

    reasoning:
        instructions: ->
            | Handle the discrepancy check stage for the payment.
              Current payment status: {! @variables.payment_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Discrepancy Check result: {! @variables.discrepancy_check_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.payment_tier }
              Review the discrepancy check results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_discrepancy_check: @actions.process_discrepancy_check_data
                with record_ref=@variables.payment_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.payment_category
                set @variables.discrepancy_check_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.discrepancy_check_complete = @outputs.is_passed
            fetch_discrepancy_check_info: @actions.fetch_discrepancy_check_details
                with record_ref=@variables.payment_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.payment_tier = @outputs.tier_value
                available when @variables.payment_record_id is not None
            go_to_adjustment: @utils.transition to @topic.adjustment
                description: "Move to adjustment stage."
                available when @variables.discrepancy_check_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.discrepancy_check_complete == True:
            set @variables.payment_status = "discrepancy_check_done"
        if @variables.discrepancy_check_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.adjustment
        if @variables.attempt_count >= 3 and @variables.discrepancy_check_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic adjustment:
    description: "Handles the adjustment stage of the payment process"

    actions:
        process_adjustment_data:
            description: "Process adjustment stage data for the payment"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_Adjustment_Data"

        validate_adjustment_info:
            description: "Validate adjustment information for the payment"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Adjustment_Info"

        fetch_adjustment_details:
            description: "Fetch adjustment details for the payment"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Adjustment_Details"

    before_reasoning:
        if @variables.adjustment_complete == False:
            run @actions.fetch_adjustment_details
                with record_ref=@variables.payment_record_id
                with include_history=True
                set @variables.adjustment_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.payment_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.payment_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.payment_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the adjustment stage for the payment.
              Current payment status: {! @variables.payment_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Adjustment result: {! @variables.adjustment_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.payment_tier }
              Review the adjustment results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_adjustment: @actions.process_adjustment_data
                with record_ref=@variables.payment_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.payment_category
                set @variables.adjustment_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.adjustment_complete = @outputs.is_passed
            fetch_adjustment_info: @actions.fetch_adjustment_details
                with record_ref=@variables.payment_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.payment_tier = @outputs.tier_value
                available when @variables.payment_record_id is not None
            go_to_finalization: @utils.transition to @topic.finalization
                description: "Move to finalization stage."
                available when @variables.adjustment_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.payment_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.payment_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.payment_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.adjustment_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic finalization:
    description: "Handles the finalization stage of the payment process"

    actions:
        process_finalization_data:
            description: "Process finalization stage data for the payment"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_Finalization"

        validate_finalization_info:
            description: "Validate finalization information for the payment"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Finalization_Info"

        fetch_finalization_details:
            description: "Fetch finalization details for the payment"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Finalization_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.adjustment_complete == False:
            transition to @topic.adjustment
        if @variables.eligibility_score >= 80:
            set @variables.payment_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.payment_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the finalization stage for the payment.
              Current payment status: {! @variables.payment_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Finalization result: {! @variables.finalization_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.payment_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_finalization: @actions.process_finalization_data
                with record_ref=@variables.payment_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.payment_category
                set @variables.finalization_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.finalization_complete = @outputs.is_passed
            fetch_finalization_info: @actions.fetch_finalization_details
                with record_ref=@variables.payment_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.payment_tier = @outputs.tier_value
                available when @variables.payment_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.finalization_complete == True:
            set @variables.payment_status = "finalization_done"
        if @variables.attempt_count >= 3 and @variables.finalization_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for payment issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the payment issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the payment interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the payment request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Payment status: {! @variables.payment_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.payment_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.payment_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.payment_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.payment_status = "escalated"
        set @variables.escalation_requested = False

