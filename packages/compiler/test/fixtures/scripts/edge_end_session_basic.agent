system:
    instructions: "You are a support assistant that can end sessions."
    messages:
        welcome: "Hello! How can I help?"
        error: "An error occurred."

config:
    developer_name: "Edge_End_Session_Basic"
    default_agent_user: "test_user"
    description: "Tests basic @utils.end_session in reasoning actions"

start_agent main:
    description: "Main topic with end session option"

    reasoning:
        instructions: ->
            | I'm here to help. When we're done, I can end the session.

        actions:
            end_conversation: @utils.end_session
                description: "End the current session"

            go_to_faq: @utils.transition to @topic.faq

topic faq:
    description: "Frequently asked questions"

    reasoning:
        instructions: ->
            | Here are some common questions I can help with.
