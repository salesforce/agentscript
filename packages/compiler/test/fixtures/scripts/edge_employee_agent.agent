# Employee agent type configuration
system:
    instructions: "You are an employee assistant for handling internal requests."
    messages:
        welcome: "Hello! I'm your employee assistant."
        error: "Something went wrong. Please try again."

config:
    agent_name: "Employee_Helper"
    agent_type: "AgentforceEmployeeAgent"
    developer_name: "Employee_Helper"
    description: "An employee-facing agent for internal requests"

start_agent main:
    description: "Handles employee inquiries and routes to appropriate topics"
    reasoning:
        instructions: ->
            | Route the employee to the right topic based on their request

topic EmployeeSupport:
    description: "Handles general employee support requests"
    reasoning:
        instructions: ->
            | Process the employee support request
