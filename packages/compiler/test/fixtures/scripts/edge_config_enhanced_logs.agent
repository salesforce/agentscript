# Config with enhanced logs, company, and role
system:
    instructions: "You are a customer service representative for Acme Corp products."
    messages:
        welcome: "Hello! I'm your Acme Corp assistant."
        error: "Sorry, something went wrong."

config:
    agent_name: "Enhanced_Logs_Agent"
    agent_type: "AgentforceServiceAgent"
    developer_name: "Enhanced_Logs_Agent"
    description: "Agent with enhanced event logging enabled"
    enable_enhanced_event_logs: True
    company: "Acme Corporation"
    role: "Customer service representative for Acme Corp products"

start_agent main:
    description: "Routes customer inquiries"
    reasoning:
        instructions: ->
            | Route the customer request to the appropriate support topic

topic Support:
    description: "Customer support topic"
    reasoning:
        instructions: ->
            | Help the customer with their support request
