# Variables without description annotations
system:
    instructions: "You are an agent with variables that have no descriptions."

config:
    agent_name: "No_Desc_Vars_Agent"
    agent_type: "AgentforceServiceAgent"
    developer_name: "No_Desc_Vars_Agent"
    description: "Agent with variables that have no descriptions"

variables:
    name: mutable string = ""
    age: mutable number = 0
    active: mutable boolean = True
    data: mutable object = None
    items: mutable list[string] = None
    counts: mutable list[number] = None
    session_ref: linked string
        source: @MessagingSession.Id

start_agent main:
    description: "Process without described variables"
    reasoning:
        instructions: ->
            | Process the request using available variables
