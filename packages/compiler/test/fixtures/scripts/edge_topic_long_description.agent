system:
    instructions: "You are a comprehensive customer service agent designed to handle complex scenarios."
    messages:
        welcome: "Hello! I'm here to help with any customer service needs."
        error: "An error occurred. Please try again."

config:
    developer_name: "Long_Description_Agent"
    default_agent_user: "user@test.com"
    description: "Agent testing very long multi-line descriptions across blocks for complex customer service scenarios"

start_agent main:
    description: "Main entry point for handling order tracking, billing, technical support, account management, returns, refunds, shipping, loyalty program, and general feedback"

    reasoning:
        instructions: ->
            | You are a comprehensive customer service agent.
              Handle all customer inquiries with care and professionalism.
              Route to specialized topics when appropriate.

        actions:
            go_to_detailed: @utils.transition to @topic.detailed_topic

topic detailed_topic:
    description: "Handles detailed and complex customer inquiries requiring extensive context, multi-step resolution, identity verification, account history checks, and comprehensive solutions"

    reasoning:
        instructions: ->
            | Handle complex inquiries step by step.
              First verify identity, then gather details,
              then propose a solution.

        actions:
            escalate_to_human: @utils.escalate
                description: "Escalate to a human agent"
