system:
    instructions: |
        You are a professional change request coordinator assistant.
        Help users manage their change_req requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: submission -> impact_analysis -> approval_flow -> implementation.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Change Request Coordinator Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "change_request_agent_v32"
    default_agent_user: "change_request@example.com"
    agent_description: "Assists users with change_req management through the change request coordinator workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    change_req_record_id: mutable string
        description: "Record ID of the change_req"
    change_req_status: mutable string = ""
        description: "Current status of the change_req"
    change_req_tier: mutable string = "standard"
        description: "Tier classification for the change_req"
    change_req_category: mutable string = ""
        description: "Category of the change_req"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    submission_complete: mutable boolean = False
        description: "Whether the submission stage is complete"
    submission_result: mutable string = ""
        description: "Result from the submission stage"
    impact_analysis_complete: mutable boolean = False
        description: "Whether the impact_analysis stage is complete"
    impact_analysis_result: mutable string = ""
        description: "Result from the impact_analysis stage"
    approval_flow_complete: mutable boolean = False
        description: "Whether the approval_flow stage is complete"
    approval_flow_result: mutable string = ""
        description: "Result from the approval_flow stage"
    implementation_complete: mutable boolean = False
        description: "Whether the implementation stage is complete"
    implementation_result: mutable string = ""
        description: "Result from the implementation stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate change_req management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a change request coordinator assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current change_req status: {! @variables.change_req_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_submission} for submission requests.
              Use {!@actions.go_to_impact_analysis} for impact analysis requests.
              Use {!@actions.go_to_approval_flow} for approval flow requests.
              Use {!@actions.go_to_implementation} for implementation requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_submission: @utils.transition to @topic.submission
                description: "Transition to submission topic."
            go_to_impact_analysis: @utils.transition to @topic.impact_analysis
                description: "Transition to impact analysis topic."
                available when @variables.is_verified == True
            go_to_approval_flow: @utils.transition to @topic.approval_flow
                description: "Transition to approval flow topic."
                available when @variables.is_verified == True
            go_to_implementation: @utils.transition to @topic.implementation
                description: "Transition to implementation topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic submission:
    description: "Handles the submission stage of the change_req process"

    actions:
        process_submission_data:
            description: "Process submission stage data for the change_req"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_Submission"

        validate_submission_info:
            description: "Validate submission information for the change_req"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Submission_Info"

        fetch_submission_details:
            description: "Fetch submission details for the change_req"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Submission_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_submission_info
                with record_ref=@variables.change_req_record_id
                with contact_ref=@variables.contact_email
                set @variables.change_req_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the submission stage for the change_req.
              Current change_req status: {! @variables.change_req_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Submission result: {! @variables.submission_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.change_req_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_submission} to begin processing.
        actions:
            run_submission: @actions.process_submission_data
                with record_ref=@variables.change_req_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.change_req_category
                set @variables.submission_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.submission_complete = @outputs.is_passed
            fetch_submission_info: @actions.fetch_submission_details
                with record_ref=@variables.change_req_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.change_req_tier = @outputs.tier_value
            go_to_impact_analysis: @utils.transition to @topic.impact_analysis
                description: "Move to impact analysis stage."
                available when @variables.submission_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.change_req_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.change_req_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.change_req_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.submission_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic impact_analysis:
    description: "Handles the impact analysis stage of the change_req process"

    actions:
        process_impact_analysis_data:
            description: "Process impact analysis stage data for the change_req"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_ImpactAnalysis"

        validate_impact_analysis_info:
            description: "Validate impact analysis information for the change_req"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_ImpactAnalysis_Info"

        fetch_impact_analysis_details:
            description: "Fetch impact analysis details for the change_req"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_ImpactAnalysis_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.submission_complete == False:
            transition to @topic.submission

    reasoning:
        instructions: ->
            | Handle the impact analysis stage for the change_req.
              Current change_req status: {! @variables.change_req_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Impact Analysis result: {! @variables.impact_analysis_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.change_req_tier }
              Review the impact analysis results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_impact_analysis: @actions.process_impact_analysis_data
                with record_ref=@variables.change_req_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.change_req_category
                set @variables.impact_analysis_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.impact_analysis_complete = @outputs.is_passed
            fetch_impact_analysis_info: @actions.fetch_impact_analysis_details
                with record_ref=@variables.change_req_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.change_req_tier = @outputs.tier_value
                available when @variables.change_req_record_id is not None
            go_to_approval_flow: @utils.transition to @topic.approval_flow
                description: "Move to approval flow stage."
                available when @variables.impact_analysis_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.impact_analysis_complete == True:
            set @variables.change_req_status = "impact_analysis_done"
        if @variables.impact_analysis_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.approval_flow
        if @variables.attempt_count >= 3 and @variables.impact_analysis_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic approval_flow:
    description: "Handles the approval flow stage of the change_req process"

    actions:
        process_approval_flow_data:
            description: "Process approval flow stage data for the change_req"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_ApprovalFlow_Data"

        validate_approval_flow_info:
            description: "Validate approval flow information for the change_req"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_ApprovalFlow_Info"

        fetch_approval_flow_details:
            description: "Fetch approval flow details for the change_req"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_ApprovalFlow_Details"

    before_reasoning:
        if @variables.approval_flow_complete == False:
            run @actions.fetch_approval_flow_details
                with record_ref=@variables.change_req_record_id
                with include_history=True
                set @variables.approval_flow_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.change_req_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.change_req_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.change_req_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the approval flow stage for the change_req.
              Current change_req status: {! @variables.change_req_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Approval Flow result: {! @variables.approval_flow_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.change_req_tier }
              Review the approval flow results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_approval_flow: @actions.process_approval_flow_data
                with record_ref=@variables.change_req_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.change_req_category
                set @variables.approval_flow_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.approval_flow_complete = @outputs.is_passed
            fetch_approval_flow_info: @actions.fetch_approval_flow_details
                with record_ref=@variables.change_req_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.change_req_tier = @outputs.tier_value
                available when @variables.change_req_record_id is not None
            go_to_implementation: @utils.transition to @topic.implementation
                description: "Move to implementation stage."
                available when @variables.approval_flow_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.change_req_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.change_req_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.change_req_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.approval_flow_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic implementation:
    description: "Handles the implementation stage of the change_req process"

    actions:
        process_implementation_data:
            description: "Process implementation stage data for the change_req"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_Implementation"

        validate_implementation_info:
            description: "Validate implementation information for the change_req"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Implementation_Info"

        fetch_implementation_details:
            description: "Fetch implementation details for the change_req"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Implementation_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.approval_flow_complete == False:
            transition to @topic.approval_flow
        if @variables.eligibility_score >= 80:
            set @variables.change_req_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.change_req_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the implementation stage for the change_req.
              Current change_req status: {! @variables.change_req_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Implementation result: {! @variables.implementation_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.change_req_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_implementation: @actions.process_implementation_data
                with record_ref=@variables.change_req_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.change_req_category
                set @variables.implementation_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.implementation_complete = @outputs.is_passed
            fetch_implementation_info: @actions.fetch_implementation_details
                with record_ref=@variables.change_req_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.change_req_tier = @outputs.tier_value
                available when @variables.change_req_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.implementation_complete == True:
            set @variables.change_req_status = "implementation_done"
        if @variables.attempt_count >= 3 and @variables.implementation_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for change_req issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the change_req issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the change_req interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the change_req request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Change Req status: {! @variables.change_req_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.change_req_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.change_req_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.change_req_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.change_req_status = "escalated"
        set @variables.escalation_requested = False

