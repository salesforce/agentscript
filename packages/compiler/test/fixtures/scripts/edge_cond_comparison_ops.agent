system:
    instructions: "You are an assistant that evaluates numeric comparisons."
    messages:
        welcome: "Welcome!"
        error: "An error occurred."

config:
    developer_name: "Edge_Cond_Comparison_Ops"
    default_agent_user: "test_user"
    description: "Tests all comparison operators on number variables"

variables:
    score: mutable number = 75
    threshold: mutable number = 50
    result_eq: mutable boolean = False
    result_neq: mutable boolean = False
    result_lt: mutable boolean = False
    result_gt: mutable boolean = False
    result_lte: mutable boolean = False
    result_gte: mutable boolean = False

start_agent main:
    description: "Tests ==, !=, <, >, <=, >= comparison operators"

    before_reasoning:
        if @variables.score == 75:
            set @variables.result_eq = True
        if @variables.score != 50:
            set @variables.result_neq = True
        if @variables.score > 50:
            set @variables.result_gt = True
        if @variables.score < 100:
            set @variables.result_lt = True
        if @variables.score >= 75:
            set @variables.result_gte = True
        if @variables.score <= 75:
            set @variables.result_lte = True

    reasoning:
        instructions: ->
            | Provide analysis based on the score: {! @variables.score }
