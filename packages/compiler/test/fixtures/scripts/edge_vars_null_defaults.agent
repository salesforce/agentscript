# Variables with None defaults and no defaults
system:
    instructions: "You are an agent for testing None defaults and variables without defaults."

config:
    agent_name: "Null_Defaults_Agent"
    agent_type: "AgentforceServiceAgent"
    developer_name: "Null_Defaults_Agent"
    description: "Agent with None defaults and variables without defaults"

variables:
    str_none: mutable string = None
        description: "String with None default"
    num_none: mutable number = None
        description: "Number with None default"
    bool_none: mutable boolean = None
        description: "Boolean with None default"
    obj_none: mutable object = None
        description: "Object with None default"
    list_none: mutable list[string] = None
        description: "List with None default"
    str_no_default: mutable string
        description: "String with no default value"
    num_no_default: mutable number
        description: "Number with no default value"
    bool_no_default: mutable boolean
        description: "Boolean with no default value"
    obj_no_default: mutable object
        description: "Object with no default value"
    list_no_default: mutable list[object]
        description: "List with no default value"

start_agent main:
    description: "Test null and missing defaults"
    reasoning:
        instructions: ->
            | Initialize variables and process the request
