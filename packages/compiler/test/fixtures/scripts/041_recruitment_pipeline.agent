system:
    instructions: |
        You are a professional recruitment pipeline agent assistant.
        Help users manage their candidate requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: sourcing -> screening -> interview_scheduling -> offer_mgmt.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Recruitment Pipeline Agent Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "recruitment_pipeline_agent_v41"
    default_agent_user: "recruitment_pipeline@example.com"
    agent_description: "Assists users with candidate management through the recruitment pipeline agent workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    candidate_record_id: mutable string
        description: "Record ID of the candidate"
    candidate_status: mutable string = ""
        description: "Current status of the candidate"
    candidate_tier: mutable string = "standard"
        description: "Tier classification for the candidate"
    candidate_category: mutable string = ""
        description: "Category of the candidate"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    sourcing_complete: mutable boolean = False
        description: "Whether the sourcing stage is complete"
    sourcing_result: mutable string = ""
        description: "Result from the sourcing stage"
    screening_complete: mutable boolean = False
        description: "Whether the screening stage is complete"
    screening_result: mutable string = ""
        description: "Result from the screening stage"
    interview_scheduling_complete: mutable boolean = False
        description: "Whether the interview_scheduling stage is complete"
    interview_scheduling_result: mutable string = ""
        description: "Result from the interview_scheduling stage"
    offer_mgmt_complete: mutable boolean = False
        description: "Whether the offer_mgmt stage is complete"
    offer_mgmt_result: mutable string = ""
        description: "Result from the offer_mgmt stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate candidate management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a recruitment pipeline agent assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current candidate status: {! @variables.candidate_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_sourcing} for sourcing requests.
              Use {!@actions.go_to_screening} for screening requests.
              Use {!@actions.go_to_interview_scheduling} for interview scheduling requests.
              Use {!@actions.go_to_offer_mgmt} for offer mgmt requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_sourcing: @utils.transition to @topic.sourcing
                description: "Transition to sourcing topic."
            go_to_screening: @utils.transition to @topic.screening
                description: "Transition to screening topic."
                available when @variables.is_verified == True
            go_to_interview_scheduling: @utils.transition to @topic.interview_scheduling
                description: "Transition to interview scheduling topic."
                available when @variables.is_verified == True
            go_to_offer_mgmt: @utils.transition to @topic.offer_mgmt
                description: "Transition to offer mgmt topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic sourcing:
    description: "Handles the sourcing stage of the candidate process"

    actions:
        process_sourcing_data:
            description: "Process sourcing stage data for the candidate"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_Sourcing"

        validate_sourcing_info:
            description: "Validate sourcing information for the candidate"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Sourcing_Info"

        fetch_sourcing_details:
            description: "Fetch sourcing details for the candidate"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Sourcing_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_sourcing_info
                with record_ref=@variables.candidate_record_id
                with contact_ref=@variables.contact_email
                set @variables.candidate_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the sourcing stage for the candidate.
              Current candidate status: {! @variables.candidate_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Sourcing result: {! @variables.sourcing_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.candidate_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_sourcing} to begin processing.
        actions:
            run_sourcing: @actions.process_sourcing_data
                with record_ref=@variables.candidate_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.candidate_category
                set @variables.sourcing_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.sourcing_complete = @outputs.is_passed
            fetch_sourcing_info: @actions.fetch_sourcing_details
                with record_ref=@variables.candidate_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.candidate_tier = @outputs.tier_value
            go_to_screening: @utils.transition to @topic.screening
                description: "Move to screening stage."
                available when @variables.sourcing_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.candidate_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.candidate_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.candidate_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.sourcing_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic screening:
    description: "Handles the screening stage of the candidate process"

    actions:
        process_screening_data:
            description: "Process screening stage data for the candidate"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_Screening"

        validate_screening_info:
            description: "Validate screening information for the candidate"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Screening_Info"

        fetch_screening_details:
            description: "Fetch screening details for the candidate"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Screening_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.sourcing_complete == False:
            transition to @topic.sourcing

    reasoning:
        instructions: ->
            | Handle the screening stage for the candidate.
              Current candidate status: {! @variables.candidate_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Screening result: {! @variables.screening_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.candidate_tier }
              Review the screening results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_screening: @actions.process_screening_data
                with record_ref=@variables.candidate_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.candidate_category
                set @variables.screening_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.screening_complete = @outputs.is_passed
            fetch_screening_info: @actions.fetch_screening_details
                with record_ref=@variables.candidate_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.candidate_tier = @outputs.tier_value
                available when @variables.candidate_record_id is not None
            go_to_interview_scheduling: @utils.transition to @topic.interview_scheduling
                description: "Move to interview scheduling stage."
                available when @variables.screening_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.screening_complete == True:
            set @variables.candidate_status = "screening_done"
        if @variables.screening_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.interview_scheduling
        if @variables.attempt_count >= 3 and @variables.screening_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic interview_scheduling:
    description: "Handles the interview scheduling stage of the candidate process"

    actions:
        process_interview_scheduling_data:
            description: "Process interview scheduling stage data for the candidate"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_InterviewScheduling_Data"

        validate_interview_scheduling_info:
            description: "Validate interview scheduling information for the candidate"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_InterviewScheduling_Info"

        fetch_interview_scheduling_details:
            description: "Fetch interview scheduling details for the candidate"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_InterviewScheduling_Details"

    before_reasoning:
        if @variables.interview_scheduling_complete == False:
            run @actions.fetch_interview_scheduling_details
                with record_ref=@variables.candidate_record_id
                with include_history=True
                set @variables.interview_scheduling_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.candidate_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.candidate_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.candidate_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the interview scheduling stage for the candidate.
              Current candidate status: {! @variables.candidate_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Interview Scheduling result: {! @variables.interview_scheduling_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.candidate_tier }
              Review the interview scheduling results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_interview_scheduling: @actions.process_interview_scheduling_data
                with record_ref=@variables.candidate_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.candidate_category
                set @variables.interview_scheduling_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.interview_scheduling_complete = @outputs.is_passed
            fetch_interview_scheduling_info: @actions.fetch_interview_scheduling_details
                with record_ref=@variables.candidate_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.candidate_tier = @outputs.tier_value
                available when @variables.candidate_record_id is not None
            go_to_offer_mgmt: @utils.transition to @topic.offer_mgmt
                description: "Move to offer mgmt stage."
                available when @variables.interview_scheduling_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.candidate_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.candidate_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.candidate_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.interview_scheduling_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic offer_mgmt:
    description: "Handles the offer mgmt stage of the candidate process"

    actions:
        process_offer_mgmt_data:
            description: "Process offer mgmt stage data for the candidate"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_OfferMgmt"

        validate_offer_mgmt_info:
            description: "Validate offer mgmt information for the candidate"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_OfferMgmt_Info"

        fetch_offer_mgmt_details:
            description: "Fetch offer mgmt details for the candidate"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_OfferMgmt_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.interview_scheduling_complete == False:
            transition to @topic.interview_scheduling
        if @variables.eligibility_score >= 80:
            set @variables.candidate_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.candidate_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the offer mgmt stage for the candidate.
              Current candidate status: {! @variables.candidate_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Offer Mgmt result: {! @variables.offer_mgmt_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.candidate_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_offer_mgmt: @actions.process_offer_mgmt_data
                with record_ref=@variables.candidate_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.candidate_category
                set @variables.offer_mgmt_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.offer_mgmt_complete = @outputs.is_passed
            fetch_offer_mgmt_info: @actions.fetch_offer_mgmt_details
                with record_ref=@variables.candidate_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.candidate_tier = @outputs.tier_value
                available when @variables.candidate_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.offer_mgmt_complete == True:
            set @variables.candidate_status = "offer_mgmt_done"
        if @variables.attempt_count >= 3 and @variables.offer_mgmt_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for candidate issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the candidate issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the candidate interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the candidate request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Candidate status: {! @variables.candidate_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.candidate_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.candidate_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.candidate_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.candidate_status = "escalated"
        set @variables.escalation_requested = False

