system:
  instructions: "You are a helpful customer service representative"
  messages:
    welcome: "hello"
    error: "goodbye"
config:
  developer_name: "TwoTopic"
  agent_id: "1"
  agent_type: "AgentforceServiceAgent"
  default_agent_user: "service_user"

language:
  default_locale: "en_US"

variables:
  name: mutable string
  issue: mutable string
  customer_name: mutable string
  issue_type: mutable string = "general"
  priority: mutable number = 1

start_agent greeting:
  description: "Greet the customer and gather basic information"

  actions:
    collect_info:
        description: "collect all the info needed"
        inputs:
          name: string
          issue: string
        outputs:
          name: string
          issue: string
        target: "apex://collect_info"

  reasoning:
    instructions: ->
        | Hello! I'm here to help you today.
          Could you please tell me your name and how I can assist you?

    actions:
        collect_info: @actions.collect_info
            with name=@variables.name, issue=@variables.issue

topic hello:
  description: "Say hello to the world"

  actions:
    collect_info:
        description: "collect all the info needed"
        inputs:
          name: string
          issue: string
        outputs:
          name: string
          issue: string
        target: "apex://collect_info"

  reasoning:
    instructions: ->
        | Hello! I'm here to help you today.
          Could you please tell me your name and how I can assist you?

    actions:
        collect_info: @actions.collect_info
            with name=@variables.name, issue=@variables.issue
