system:
    instructions: |
        You are a professional reinsurance management agent assistant.
        Help users manage their reinsurance requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: treaty_review -> cession_calculation -> reporting -> settlement.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Reinsurance Management Agent Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "reinsurance_mgmt_agent_v60"
    default_agent_user: "reinsurance_mgmt@example.com"
    agent_description: "Assists users with reinsurance management through the reinsurance management agent workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    reinsurance_record_id: mutable string
        description: "Record ID of the reinsurance"
    reinsurance_status: mutable string = ""
        description: "Current status of the reinsurance"
    reinsurance_tier: mutable string = "standard"
        description: "Tier classification for the reinsurance"
    reinsurance_category: mutable string = ""
        description: "Category of the reinsurance"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    treaty_review_complete: mutable boolean = False
        description: "Whether the treaty_review stage is complete"
    treaty_review_result: mutable string = ""
        description: "Result from the treaty_review stage"
    cession_calculation_complete: mutable boolean = False
        description: "Whether the cession_calculation stage is complete"
    cession_calculation_result: mutable string = ""
        description: "Result from the cession_calculation stage"
    reporting_complete: mutable boolean = False
        description: "Whether the reporting stage is complete"
    reporting_result: mutable string = ""
        description: "Result from the reporting stage"
    settlement_complete: mutable boolean = False
        description: "Whether the settlement stage is complete"
    settlement_result: mutable string = ""
        description: "Result from the settlement stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate reinsurance management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a reinsurance management agent assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current reinsurance status: {! @variables.reinsurance_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_treaty_review} for treaty review requests.
              Use {!@actions.go_to_cession_calculation} for cession calculation requests.
              Use {!@actions.go_to_reporting} for reporting requests.
              Use {!@actions.go_to_settlement} for settlement requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_treaty_review: @utils.transition to @topic.treaty_review
                description: "Transition to treaty review topic."
            go_to_cession_calculation: @utils.transition to @topic.cession_calculation
                description: "Transition to cession calculation topic."
                available when @variables.is_verified == True
            go_to_reporting: @utils.transition to @topic.reporting
                description: "Transition to reporting topic."
                available when @variables.is_verified == True
            go_to_settlement: @utils.transition to @topic.settlement
                description: "Transition to settlement topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic treaty_review:
    description: "Handles the treaty review stage of the reinsurance process"

    actions:
        process_treaty_review_data:
            description: "Process treaty review stage data for the reinsurance"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_TreatyReview"

        validate_treaty_review_info:
            description: "Validate treaty review information for the reinsurance"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_TreatyReview_Info"

        fetch_treaty_review_details:
            description: "Fetch treaty review details for the reinsurance"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_TreatyReview_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_treaty_review_info
                with record_ref=@variables.reinsurance_record_id
                with contact_ref=@variables.contact_email
                set @variables.reinsurance_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the treaty review stage for the reinsurance.
              Current reinsurance status: {! @variables.reinsurance_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Treaty Review result: {! @variables.treaty_review_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.reinsurance_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_treaty_review} to begin processing.
        actions:
            run_treaty_review: @actions.process_treaty_review_data
                with record_ref=@variables.reinsurance_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.reinsurance_category
                set @variables.treaty_review_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.treaty_review_complete = @outputs.is_passed
            fetch_treaty_review_info: @actions.fetch_treaty_review_details
                with record_ref=@variables.reinsurance_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.reinsurance_tier = @outputs.tier_value
            go_to_cession_calculation: @utils.transition to @topic.cession_calculation
                description: "Move to cession calculation stage."
                available when @variables.treaty_review_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.reinsurance_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.reinsurance_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.reinsurance_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.treaty_review_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic cession_calculation:
    description: "Handles the cession calculation stage of the reinsurance process"

    actions:
        process_cession_calculation_data:
            description: "Process cession calculation stage data for the reinsurance"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_CessionCalculation_Data"

        validate_cession_calculation_info:
            description: "Validate cession calculation information for the reinsurance"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_CessionCalculation_Info"

        fetch_cession_calculation_details:
            description: "Fetch cession calculation details for the reinsurance"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_CessionCalculation_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.treaty_review_complete == False:
            transition to @topic.treaty_review

    reasoning:
        instructions: ->
            | Handle the cession calculation stage for the reinsurance.
              Current reinsurance status: {! @variables.reinsurance_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Cession Calculation result: {! @variables.cession_calculation_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.reinsurance_tier }
              Review the cession calculation results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_cession_calculation: @actions.process_cession_calculation_data
                with record_ref=@variables.reinsurance_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.reinsurance_category
                set @variables.cession_calculation_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.cession_calculation_complete = @outputs.is_passed
            fetch_cession_calculation_info: @actions.fetch_cession_calculation_details
                with record_ref=@variables.reinsurance_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.reinsurance_tier = @outputs.tier_value
                available when @variables.reinsurance_record_id is not None
            go_to_reporting: @utils.transition to @topic.reporting
                description: "Move to reporting stage."
                available when @variables.cession_calculation_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.cession_calculation_complete == True:
            set @variables.reinsurance_status = "cession_calculation_done"
        if @variables.cession_calculation_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.reporting
        if @variables.attempt_count >= 3 and @variables.cession_calculation_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic reporting:
    description: "Handles the reporting stage of the reinsurance process"

    actions:
        process_reporting_data:
            description: "Process reporting stage data for the reinsurance"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_Reporting"

        validate_reporting_info:
            description: "Validate reporting information for the reinsurance"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Reporting_Info"

        fetch_reporting_details:
            description: "Fetch reporting details for the reinsurance"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Reporting_Details"

    before_reasoning:
        if @variables.reporting_complete == False:
            run @actions.fetch_reporting_details
                with record_ref=@variables.reinsurance_record_id
                with include_history=True
                set @variables.reporting_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.reinsurance_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.reinsurance_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.reinsurance_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the reporting stage for the reinsurance.
              Current reinsurance status: {! @variables.reinsurance_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Reporting result: {! @variables.reporting_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.reinsurance_tier }
              Review the reporting results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_reporting: @actions.process_reporting_data
                with record_ref=@variables.reinsurance_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.reinsurance_category
                set @variables.reporting_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.reporting_complete = @outputs.is_passed
            fetch_reporting_info: @actions.fetch_reporting_details
                with record_ref=@variables.reinsurance_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.reinsurance_tier = @outputs.tier_value
                available when @variables.reinsurance_record_id is not None
            go_to_settlement: @utils.transition to @topic.settlement
                description: "Move to settlement stage."
                available when @variables.reporting_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.reinsurance_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.reinsurance_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.reinsurance_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.reporting_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic settlement:
    description: "Handles the settlement stage of the reinsurance process"

    actions:
        process_settlement_data:
            description: "Process settlement stage data for the reinsurance"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_Settlement"

        validate_settlement_info:
            description: "Validate settlement information for the reinsurance"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Settlement_Info"

        fetch_settlement_details:
            description: "Fetch settlement details for the reinsurance"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Settlement_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.reporting_complete == False:
            transition to @topic.reporting
        if @variables.eligibility_score >= 80:
            set @variables.reinsurance_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.reinsurance_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the settlement stage for the reinsurance.
              Current reinsurance status: {! @variables.reinsurance_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Settlement result: {! @variables.settlement_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.reinsurance_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_settlement: @actions.process_settlement_data
                with record_ref=@variables.reinsurance_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.reinsurance_category
                set @variables.settlement_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.settlement_complete = @outputs.is_passed
            fetch_settlement_info: @actions.fetch_settlement_details
                with record_ref=@variables.reinsurance_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.reinsurance_tier = @outputs.tier_value
                available when @variables.reinsurance_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.settlement_complete == True:
            set @variables.reinsurance_status = "settlement_done"
        if @variables.attempt_count >= 3 and @variables.settlement_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for reinsurance issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the reinsurance issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the reinsurance interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the reinsurance request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Reinsurance status: {! @variables.reinsurance_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.reinsurance_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.reinsurance_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.reinsurance_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.reinsurance_status = "escalated"
        set @variables.escalation_requested = False

