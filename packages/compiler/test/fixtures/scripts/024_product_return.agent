system:
    instructions: |
        You are a professional product return specialist assistant.
        Help users manage their return_req requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: eligibility_check -> rma_creation -> inspection -> refund_processing.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Product Return Specialist Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "product_return_agent_v24"
    default_agent_user: "product_return@example.com"
    agent_description: "Assists users with return_req management through the product return specialist workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    return_req_record_id: mutable string
        description: "Record ID of the return_req"
    return_req_status: mutable string = ""
        description: "Current status of the return_req"
    return_req_tier: mutable string = "standard"
        description: "Tier classification for the return_req"
    return_req_category: mutable string = ""
        description: "Category of the return_req"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    eligibility_check_complete: mutable boolean = False
        description: "Whether the eligibility_check stage is complete"
    eligibility_check_result: mutable string = ""
        description: "Result from the eligibility_check stage"
    rma_creation_complete: mutable boolean = False
        description: "Whether the rma_creation stage is complete"
    rma_creation_result: mutable string = ""
        description: "Result from the rma_creation stage"
    inspection_complete: mutable boolean = False
        description: "Whether the inspection stage is complete"
    inspection_result: mutable string = ""
        description: "Result from the inspection stage"
    refund_processing_complete: mutable boolean = False
        description: "Whether the refund_processing stage is complete"
    refund_processing_result: mutable string = ""
        description: "Result from the refund_processing stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate return_req management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a product return specialist assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current return_req status: {! @variables.return_req_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_eligibility_check} for eligibility check requests.
              Use {!@actions.go_to_rma_creation} for rma creation requests.
              Use {!@actions.go_to_inspection} for inspection requests.
              Use {!@actions.go_to_refund_processing} for refund processing requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_eligibility_check: @utils.transition to @topic.eligibility_check
                description: "Transition to eligibility check topic."
            go_to_rma_creation: @utils.transition to @topic.rma_creation
                description: "Transition to rma creation topic."
                available when @variables.is_verified == True
            go_to_inspection: @utils.transition to @topic.inspection
                description: "Transition to inspection topic."
                available when @variables.is_verified == True
            go_to_refund_processing: @utils.transition to @topic.refund_processing
                description: "Transition to refund processing topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic eligibility_check:
    description: "Handles the eligibility check stage of the return_req process"

    actions:
        process_eligibility_check_data:
            description: "Process eligibility check stage data for the return_req"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_EligibilityCheck"

        validate_eligibility_check_info:
            description: "Validate eligibility check information for the return_req"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_EligibilityCheck_Info"

        fetch_eligibility_check_details:
            description: "Fetch eligibility check details for the return_req"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_EligibilityCheck_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_eligibility_check_info
                with record_ref=@variables.return_req_record_id
                with contact_ref=@variables.contact_email
                set @variables.return_req_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the eligibility check stage for the return_req.
              Current return_req status: {! @variables.return_req_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Eligibility Check result: {! @variables.eligibility_check_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.return_req_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_eligibility_check} to begin processing.
        actions:
            run_eligibility_check: @actions.process_eligibility_check_data
                with record_ref=@variables.return_req_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.return_req_category
                set @variables.eligibility_check_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.eligibility_check_complete = @outputs.is_passed
            fetch_eligibility_check_info: @actions.fetch_eligibility_check_details
                with record_ref=@variables.return_req_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.return_req_tier = @outputs.tier_value
            go_to_rma_creation: @utils.transition to @topic.rma_creation
                description: "Move to rma creation stage."
                available when @variables.eligibility_check_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.return_req_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.return_req_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.return_req_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.eligibility_check_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic rma_creation:
    description: "Handles the rma creation stage of the return_req process"

    actions:
        process_rma_creation_data:
            description: "Process rma creation stage data for the return_req"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_RmaCreation_Data"

        validate_rma_creation_info:
            description: "Validate rma creation information for the return_req"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_RmaCreation_Info"

        fetch_rma_creation_details:
            description: "Fetch rma creation details for the return_req"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_RmaCreation_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.eligibility_check_complete == False:
            transition to @topic.eligibility_check

    reasoning:
        instructions: ->
            | Handle the rma creation stage for the return_req.
              Current return_req status: {! @variables.return_req_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Rma Creation result: {! @variables.rma_creation_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.return_req_tier }
              Review the rma creation results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_rma_creation: @actions.process_rma_creation_data
                with record_ref=@variables.return_req_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.return_req_category
                set @variables.rma_creation_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.rma_creation_complete = @outputs.is_passed
            fetch_rma_creation_info: @actions.fetch_rma_creation_details
                with record_ref=@variables.return_req_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.return_req_tier = @outputs.tier_value
                available when @variables.return_req_record_id is not None
            go_to_inspection: @utils.transition to @topic.inspection
                description: "Move to inspection stage."
                available when @variables.rma_creation_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.rma_creation_complete == True:
            set @variables.return_req_status = "rma_creation_done"
        if @variables.rma_creation_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.inspection
        if @variables.attempt_count >= 3 and @variables.rma_creation_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic inspection:
    description: "Handles the inspection stage of the return_req process"

    actions:
        process_inspection_data:
            description: "Process inspection stage data for the return_req"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_Inspection"

        validate_inspection_info:
            description: "Validate inspection information for the return_req"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Inspection_Info"

        fetch_inspection_details:
            description: "Fetch inspection details for the return_req"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Inspection_Details"

    before_reasoning:
        if @variables.inspection_complete == False:
            run @actions.fetch_inspection_details
                with record_ref=@variables.return_req_record_id
                with include_history=True
                set @variables.inspection_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.return_req_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.return_req_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.return_req_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the inspection stage for the return_req.
              Current return_req status: {! @variables.return_req_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Inspection result: {! @variables.inspection_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.return_req_tier }
              Review the inspection results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_inspection: @actions.process_inspection_data
                with record_ref=@variables.return_req_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.return_req_category
                set @variables.inspection_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.inspection_complete = @outputs.is_passed
            fetch_inspection_info: @actions.fetch_inspection_details
                with record_ref=@variables.return_req_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.return_req_tier = @outputs.tier_value
                available when @variables.return_req_record_id is not None
            go_to_refund_processing: @utils.transition to @topic.refund_processing
                description: "Move to refund processing stage."
                available when @variables.inspection_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.return_req_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.return_req_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.return_req_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.inspection_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic refund_processing:
    description: "Handles the refund processing stage of the return_req process"

    actions:
        process_refund_processing_data:
            description: "Process refund processing stage data for the return_req"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_RefundProcessing"

        validate_refund_processing_info:
            description: "Validate refund processing information for the return_req"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_RefundProcessing_Info"

        fetch_refund_processing_details:
            description: "Fetch refund processing details for the return_req"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_RefundProcessing_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.inspection_complete == False:
            transition to @topic.inspection
        if @variables.eligibility_score >= 80:
            set @variables.return_req_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.return_req_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the refund processing stage for the return_req.
              Current return_req status: {! @variables.return_req_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Refund Processing result: {! @variables.refund_processing_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.return_req_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_refund_processing: @actions.process_refund_processing_data
                with record_ref=@variables.return_req_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.return_req_category
                set @variables.refund_processing_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.refund_processing_complete = @outputs.is_passed
            fetch_refund_processing_info: @actions.fetch_refund_processing_details
                with record_ref=@variables.return_req_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.return_req_tier = @outputs.tier_value
                available when @variables.return_req_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.refund_processing_complete == True:
            set @variables.return_req_status = "refund_processing_done"
        if @variables.attempt_count >= 3 and @variables.refund_processing_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for return_req issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the return_req issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the return_req interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the return_req request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Return Req status: {! @variables.return_req_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.return_req_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.return_req_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.return_req_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.return_req_status = "escalated"
        set @variables.escalation_requested = False

