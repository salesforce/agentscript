system:
    instructions: |
        You are a professional expense reporting agent assistant.
        Help users manage their expense requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: receipt_capture -> categorization -> policy_check -> submission.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Expense Reporting Agent Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "expense_reporting_agent_v78"
    default_agent_user: "expense_reporting@example.com"
    agent_description: "Assists users with expense management through the expense reporting agent workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    expense_record_id: mutable string
        description: "Record ID of the expense"
    expense_status: mutable string = ""
        description: "Current status of the expense"
    expense_tier: mutable string = "standard"
        description: "Tier classification for the expense"
    expense_category: mutable string = ""
        description: "Category of the expense"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    receipt_capture_complete: mutable boolean = False
        description: "Whether the receipt_capture stage is complete"
    receipt_capture_result: mutable string = ""
        description: "Result from the receipt_capture stage"
    categorization_complete: mutable boolean = False
        description: "Whether the categorization stage is complete"
    categorization_result: mutable string = ""
        description: "Result from the categorization stage"
    policy_check_complete: mutable boolean = False
        description: "Whether the policy_check stage is complete"
    policy_check_result: mutable string = ""
        description: "Result from the policy_check stage"
    submission_complete: mutable boolean = False
        description: "Whether the submission stage is complete"
    submission_result: mutable string = ""
        description: "Result from the submission stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate expense management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a expense reporting agent assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current expense status: {! @variables.expense_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_receipt_capture} for receipt capture requests.
              Use {!@actions.go_to_categorization} for categorization requests.
              Use {!@actions.go_to_policy_check} for policy check requests.
              Use {!@actions.go_to_submission} for submission requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_receipt_capture: @utils.transition to @topic.receipt_capture
                description: "Transition to receipt capture topic."
            go_to_categorization: @utils.transition to @topic.categorization
                description: "Transition to categorization topic."
                available when @variables.is_verified == True
            go_to_policy_check: @utils.transition to @topic.policy_check
                description: "Transition to policy check topic."
                available when @variables.is_verified == True
            go_to_submission: @utils.transition to @topic.submission
                description: "Transition to submission topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic receipt_capture:
    description: "Handles the receipt capture stage of the expense process"

    actions:
        process_receipt_capture_data:
            description: "Process receipt capture stage data for the expense"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_ReceiptCapture"

        validate_receipt_capture_info:
            description: "Validate receipt capture information for the expense"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_ReceiptCapture_Info"

        fetch_receipt_capture_details:
            description: "Fetch receipt capture details for the expense"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_ReceiptCapture_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_receipt_capture_info
                with record_ref=@variables.expense_record_id
                with contact_ref=@variables.contact_email
                set @variables.expense_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the receipt capture stage for the expense.
              Current expense status: {! @variables.expense_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Receipt Capture result: {! @variables.receipt_capture_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.expense_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_receipt_capture} to begin processing.
        actions:
            run_receipt_capture: @actions.process_receipt_capture_data
                with record_ref=@variables.expense_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.expense_category
                set @variables.receipt_capture_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.receipt_capture_complete = @outputs.is_passed
            fetch_receipt_capture_info: @actions.fetch_receipt_capture_details
                with record_ref=@variables.expense_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.expense_tier = @outputs.tier_value
            go_to_categorization: @utils.transition to @topic.categorization
                description: "Move to categorization stage."
                available when @variables.receipt_capture_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.expense_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.expense_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.expense_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.receipt_capture_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic categorization:
    description: "Handles the categorization stage of the expense process"

    actions:
        process_categorization_data:
            description: "Process categorization stage data for the expense"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_Categorization_Data"

        validate_categorization_info:
            description: "Validate categorization information for the expense"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Categorization_Info"

        fetch_categorization_details:
            description: "Fetch categorization details for the expense"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Categorization_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.receipt_capture_complete == False:
            transition to @topic.receipt_capture

    reasoning:
        instructions: ->
            | Handle the categorization stage for the expense.
              Current expense status: {! @variables.expense_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Categorization result: {! @variables.categorization_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.expense_tier }
              Review the categorization results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_categorization: @actions.process_categorization_data
                with record_ref=@variables.expense_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.expense_category
                set @variables.categorization_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.categorization_complete = @outputs.is_passed
            fetch_categorization_info: @actions.fetch_categorization_details
                with record_ref=@variables.expense_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.expense_tier = @outputs.tier_value
                available when @variables.expense_record_id is not None
            go_to_policy_check: @utils.transition to @topic.policy_check
                description: "Move to policy check stage."
                available when @variables.categorization_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.categorization_complete == True:
            set @variables.expense_status = "categorization_done"
        if @variables.categorization_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.policy_check
        if @variables.attempt_count >= 3 and @variables.categorization_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic policy_check:
    description: "Handles the policy check stage of the expense process"

    actions:
        process_policy_check_data:
            description: "Process policy check stage data for the expense"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_PolicyCheck"

        validate_policy_check_info:
            description: "Validate policy check information for the expense"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_PolicyCheck_Info"

        fetch_policy_check_details:
            description: "Fetch policy check details for the expense"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_PolicyCheck_Details"

    before_reasoning:
        if @variables.policy_check_complete == False:
            run @actions.fetch_policy_check_details
                with record_ref=@variables.expense_record_id
                with include_history=True
                set @variables.policy_check_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.expense_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.expense_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.expense_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the policy check stage for the expense.
              Current expense status: {! @variables.expense_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Policy Check result: {! @variables.policy_check_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.expense_tier }
              Review the policy check results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_policy_check: @actions.process_policy_check_data
                with record_ref=@variables.expense_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.expense_category
                set @variables.policy_check_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.policy_check_complete = @outputs.is_passed
            fetch_policy_check_info: @actions.fetch_policy_check_details
                with record_ref=@variables.expense_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.expense_tier = @outputs.tier_value
                available when @variables.expense_record_id is not None
            go_to_submission: @utils.transition to @topic.submission
                description: "Move to submission stage."
                available when @variables.policy_check_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.expense_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.expense_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.expense_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.policy_check_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic submission:
    description: "Handles the submission stage of the expense process"

    actions:
        process_submission_data:
            description: "Process submission stage data for the expense"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_Submission"

        validate_submission_info:
            description: "Validate submission information for the expense"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_Submission_Info"

        fetch_submission_details:
            description: "Fetch submission details for the expense"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_Submission_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.policy_check_complete == False:
            transition to @topic.policy_check
        if @variables.eligibility_score >= 80:
            set @variables.expense_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.expense_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the submission stage for the expense.
              Current expense status: {! @variables.expense_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Submission result: {! @variables.submission_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.expense_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_submission: @actions.process_submission_data
                with record_ref=@variables.expense_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.expense_category
                set @variables.submission_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.submission_complete = @outputs.is_passed
            fetch_submission_info: @actions.fetch_submission_details
                with record_ref=@variables.expense_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.expense_tier = @outputs.tier_value
                available when @variables.expense_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.submission_complete == True:
            set @variables.expense_status = "submission_done"
        if @variables.attempt_count >= 3 and @variables.submission_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for expense issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the expense issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the expense interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the expense request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Expense status: {! @variables.expense_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.expense_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.expense_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.expense_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.expense_status = "escalated"
        set @variables.escalation_requested = False

