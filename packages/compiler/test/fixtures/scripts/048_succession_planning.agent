system:
    instructions: |
        You are a professional succession planning agent assistant.
        Help users manage their succession requests efficiently and accurately.
        Always verify the user's identity before proceeding with sensitive operations.
        Follow the established workflow: talent_identification -> readiness_assessment -> development_plan -> gap_analysis.
        Be concise, professional, and confirm next steps at the end of each exchange.
        If the user is upset or asks for a human, escalate immediately.
        Never reveal internal record IDs or system identifiers to the user.
    messages:
        welcome: "Hello! I am your Succession Planning Agent Assistant. How can I help you today?"
        error: "I apologize, something went wrong on my end. Could you please rephrase your request?"


config:
    developer_name: "succession_planning_agent_v48"
    default_agent_user: "succession_planning@example.com"
    agent_description: "Assists users with succession management through the succession planning agent workflow."
    enable_enhanced_event_logs: True


language:
    default_locale: "en_US"


variables:
    succession_record_id: mutable string
        description: "Record ID of the succession"
    succession_status: mutable string = ""
        description: "Current status of the succession"
    succession_tier: mutable string = "standard"
        description: "Tier classification for the succession"
    succession_category: mutable string = ""
        description: "Category of the succession"
    contact_name: mutable string
        description: "Full name of the contact"
    contact_email: mutable string
        description: "Email address of the contact"
    contact_phone: mutable string = ""
        description: "Phone number of the contact"
    is_verified: mutable boolean = False
        description: "Whether the user identity is verified"
    eligibility_score: mutable number = 0
        description: "Calculated eligibility score"
    step_counter: mutable number = 0
        description: "Current step in the process"
    attempt_count: mutable number = 0
        description: "Number of attempts made"
    total_items_count: mutable number = 0
        description: "Total number of items to process"
    talent_identification_complete: mutable boolean = False
        description: "Whether the talent_identification stage is complete"
    talent_identification_result: mutable string = ""
        description: "Result from the talent_identification stage"
    readiness_assessment_complete: mutable boolean = False
        description: "Whether the readiness_assessment stage is complete"
    readiness_assessment_result: mutable string = ""
        description: "Result from the readiness_assessment stage"
    development_plan_complete: mutable boolean = False
        description: "Whether the development_plan stage is complete"
    development_plan_result: mutable string = ""
        description: "Result from the development_plan stage"
    gap_analysis_complete: mutable boolean = False
        description: "Whether the gap_analysis stage is complete"
    gap_analysis_result: mutable string = ""
        description: "Result from the gap_analysis stage"
    priority_level: mutable string = "normal"
        description: "Priority level of the request"
    notes_text: mutable string = ""
        description: "Notes and comments"
    assigned_agent: mutable string = ""
        description: "Assigned agent name"
    resolution_summary: mutable string = ""
        description: "Summary of the resolution"
    escalation_requested: mutable boolean = False
        description: "Whether escalation was requested"
    is_business_hours: mutable boolean = False
        description: "Whether it is currently business hours"
    case_ref_number: mutable string = ""
        description: "Reference number for the support case"
    next_available_slot: mutable string = ""
        description: "Next available time slot"

start_agent topic_selector:
    description: "Welcome the user and route to the appropriate succession management topic"

    reasoning:
        instructions: ->
            | You are a topic selector for a succession planning agent assistant.
              Analyze the user's input and determine the most appropriate topic.
              Current succession status: {! @variables.succession_status }
              Eligibility score: {! @variables.eligibility_score }
              Steps completed: {! @variables.step_counter }
              Priority: {! @variables.priority_level }
              Use {!@actions.go_to_talent_identification} for talent identification requests.
              Use {!@actions.go_to_readiness_assessment} for readiness assessment requests.
              Use {!@actions.go_to_development_plan} for development plan requests.
              Use {!@actions.go_to_gap_analysis} for gap analysis requests.
              Use {!@actions.go_to_escalation} to escalate if the user is upset or requests a human.
        actions:
            go_to_talent_identification: @utils.transition to @topic.talent_identification
                description: "Transition to talent identification topic."
            go_to_readiness_assessment: @utils.transition to @topic.readiness_assessment
                description: "Transition to readiness assessment topic."
                available when @variables.is_verified == True
            go_to_development_plan: @utils.transition to @topic.development_plan
                description: "Transition to development plan topic."
                available when @variables.is_verified == True
            go_to_gap_analysis: @utils.transition to @topic.gap_analysis
                description: "Transition to gap analysis topic."
                available when @variables.is_verified == True
            go_to_escalation: @utils.transition to @topic.escalation_handling
                description: "Escalate to a human agent for assistance."
                available when @variables.is_verified == True


topic talent_identification:
    description: "Handles the talent identification stage of the succession process"

    actions:
        process_talent_identification_data:
            description: "Process talent identification stage data for the succession"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_TalentIdentification"

        validate_talent_identification_info:
            description: "Validate talent identification information for the succession"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_TalentIdentification_Info"

        fetch_talent_identification_details:
            description: "Fetch talent identification details for the succession"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_TalentIdentification_Details"

    before_reasoning:
        if @variables.is_verified == False:
            run @actions.validate_talent_identification_info
                with record_ref=@variables.succession_record_id
                with contact_ref=@variables.contact_email
                set @variables.succession_status = @outputs.updated_status
                set @variables.is_verified = @outputs.is_valid

    reasoning:
        instructions: ->
            | Handle the talent identification stage for the succession.
              Current succession status: {! @variables.succession_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Talent Identification result: {! @variables.talent_identification_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.succession_tier }
              If the contact information is missing, ask the user to provide their name and email.
              After collecting information, use {!@actions.run_talent_identification} to begin processing.
        actions:
            run_talent_identification: @actions.process_talent_identification_data
                with record_ref=@variables.succession_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.succession_category
                set @variables.talent_identification_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.talent_identification_complete = @outputs.is_passed
            fetch_talent_identification_info: @actions.fetch_talent_identification_details
                with record_ref=@variables.succession_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.succession_tier = @outputs.tier_value
            go_to_readiness_assessment: @utils.transition to @topic.readiness_assessment
                description: "Move to readiness assessment stage."
                available when @variables.talent_identification_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.succession_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.succession_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.succession_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.talent_identification_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic readiness_assessment:
    description: "Handles the readiness assessment stage of the succession process"

    actions:
        process_readiness_assessment_data:
            description: "Process readiness assessment stage data for the succession"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "flow://Process_ReadinessAssessment_Data"

        validate_readiness_assessment_info:
            description: "Validate readiness assessment information for the succession"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_ReadinessAssessment_Info"

        fetch_readiness_assessment_details:
            description: "Fetch readiness assessment details for the succession"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_ReadinessAssessment_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.talent_identification_complete == False:
            transition to @topic.talent_identification

    reasoning:
        instructions: ->
            | Handle the readiness assessment stage for the succession.
              Current succession status: {! @variables.succession_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Readiness Assessment result: {! @variables.readiness_assessment_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.succession_tier }
              Review the readiness assessment results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_readiness_assessment: @actions.process_readiness_assessment_data
                with record_ref=@variables.succession_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.succession_category
                set @variables.readiness_assessment_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.readiness_assessment_complete = @outputs.is_passed
            fetch_readiness_assessment_info: @actions.fetch_readiness_assessment_details
                with record_ref=@variables.succession_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.succession_tier = @outputs.tier_value
                available when @variables.succession_record_id is not None
            go_to_development_plan: @utils.transition to @topic.development_plan
                description: "Move to development plan stage."
                available when @variables.readiness_assessment_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.readiness_assessment_complete == True:
            set @variables.succession_status = "readiness_assessment_done"
        if @variables.readiness_assessment_complete == True and @variables.eligibility_score >= 50:
            transition to @topic.development_plan
        if @variables.attempt_count >= 3 and @variables.readiness_assessment_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic development_plan:
    description: "Handles the development plan stage of the succession process"

    actions:
        process_development_plan_data:
            description: "Process development plan stage data for the succession"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "standardInvocableAction://Process_DevelopmentPlan"

        validate_development_plan_info:
            description: "Validate development plan information for the succession"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_DevelopmentPlan_Info"

        fetch_development_plan_details:
            description: "Fetch development plan details for the succession"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_DevelopmentPlan_Details"

    before_reasoning:
        if @variables.development_plan_complete == False:
            run @actions.fetch_development_plan_details
                with record_ref=@variables.succession_record_id
                with include_history=True
                set @variables.development_plan_result = @outputs.detail_data
                set @variables.total_items_count = @outputs.item_count
                set @variables.succession_tier = @outputs.tier_value
        if @variables.eligibility_score >= 80:
            set @variables.succession_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.succession_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the development plan stage for the succession.
              Current succession status: {! @variables.succession_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Development Plan result: {! @variables.development_plan_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.succession_tier }
              Review the development plan results and determine next steps.
              Eligibility score: {! @variables.eligibility_score }
              If the score is sufficient, proceed to the next stage.
              If the user has concerns, address them before proceeding.
        actions:
            run_development_plan: @actions.process_development_plan_data
                with record_ref=@variables.succession_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.succession_category
                set @variables.development_plan_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.development_plan_complete = @outputs.is_passed
            fetch_development_plan_info: @actions.fetch_development_plan_details
                with record_ref=@variables.succession_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.succession_tier = @outputs.tier_value
                available when @variables.succession_record_id is not None
            go_to_gap_analysis: @utils.transition to @topic.gap_analysis
                description: "Move to gap analysis stage."
                available when @variables.development_plan_complete == True and @variables.eligibility_score >= 50
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.eligibility_score >= 70:
            set @variables.succession_tier = "premium"
        if @variables.eligibility_score >= 40 and @variables.eligibility_score < 70:
            set @variables.succession_tier = "standard"
        if @variables.eligibility_score < 40:
            set @variables.succession_tier = "basic"
        if @variables.attempt_count >= 3 and @variables.development_plan_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True

topic gap_analysis:
    description: "Handles the gap analysis stage of the succession process"

    actions:
        process_gap_analysis_data:
            description: "Process gap analysis stage data for the succession"
            inputs:
                record_ref: string
                step_num: number
                category_val: string
            outputs:
                result_code: string
                result_message: string
                score_value: number
                is_passed: boolean
            target: "apex://Process_GapAnalysis"

        validate_gap_analysis_info:
            description: "Validate gap analysis information for the succession"
            inputs:
                record_ref: string
                contact_ref: string
            outputs:
                is_valid: boolean
                error_msg: string
                updated_status: string
            target: "flow://Validate_GapAnalysis_Info"

        fetch_gap_analysis_details:
            description: "Fetch gap analysis details for the succession"
            inputs:
                record_ref: string
                include_history: boolean
            outputs:
                detail_data: string
                item_count: number
                tier_value: string
                last_updated: string
            target: "flow://Fetch_GapAnalysis_Details"

    before_reasoning:
        if @variables.attempt_count > 5:
            set @variables.escalation_requested = True
        if @variables.development_plan_complete == False:
            transition to @topic.development_plan
        if @variables.eligibility_score >= 80:
            set @variables.succession_tier = "premium"
        if @variables.eligibility_score < 20:
            set @variables.succession_tier = "basic"

    reasoning:
        instructions: ->
            | Handle the gap analysis stage for the succession.
              Current succession status: {! @variables.succession_status }
              Step {! @variables.step_counter + 1 } of the process.
              Attempts so far: {! @variables.attempt_count }
              Contact: {! @variables.contact_name } ({! @variables.contact_email })
              Gap Analysis result: {! @variables.gap_analysis_result }
              Priority level: {! @variables.priority_level }
              Current tier: {! @variables.succession_tier }
              This is the final stage. Review all results and provide a summary.
              Total items processed: {! @variables.total_items_count }
              If all stages passed, confirm completion. Otherwise offer to retry or escalate.
        actions:
            run_gap_analysis: @actions.process_gap_analysis_data
                with record_ref=@variables.succession_record_id
                with step_num=@variables.step_counter
                with category_val=@variables.succession_category
                set @variables.gap_analysis_result = @outputs.result_code
                set @variables.eligibility_score = @outputs.score_value
                set @variables.gap_analysis_complete = @outputs.is_passed
            fetch_gap_analysis_info: @actions.fetch_gap_analysis_details
                with record_ref=@variables.succession_record_id
                with include_history=False
                set @variables.total_items_count = @outputs.item_count
                set @variables.succession_tier = @outputs.tier_value
                available when @variables.succession_record_id is not None
            escalate_now: @utils.transition to @topic.escalation_handling
                description: "Escalate if issues arise."
                available when @variables.escalation_requested == True
            back_to_start: @utils.transition to @topic.topic_selector
                description: "Return to topic selector."

    after_reasoning:
        set @variables.step_counter = @variables.step_counter + 1
        set @variables.attempt_count = @variables.attempt_count + 1
        if @variables.gap_analysis_complete == True:
            set @variables.succession_status = "gap_analysis_done"
        if @variables.attempt_count >= 3 and @variables.gap_analysis_complete == False:
            set @variables.priority_level = "high"
        if @variables.attempt_count >= 5:
            set @variables.escalation_requested = True


topic escalation_handling:
    description: "Handle escalation and case creation for succession issues"

    actions:
        check_hours:
            description: "Check whether it is currently business hours"
            inputs:
                query_text: string
            outputs:
                hours_active: boolean
                next_available: string
            target: "flow://Check_Business_Hours"

        create_support_case:
            description: "Create a support case for the succession issue"
            inputs:
                case_subject: string
                case_detail: string
                record_ref: string
                priority_val: string
            outputs:
                case_ref: string
                assigned_to: string
            target: "flow://Create_Support_Case"

        generate_summary:
            description: "Generate a summary of the succession interaction"
            inputs:
                record_ref: string
                notes_val: string
            outputs:
                summary_text: string
            target: "flow://Generate_Summary"

    before_reasoning:
        run @actions.check_hours
            with query_text="check_availability"
            set @variables.is_business_hours = @outputs.hours_active
            set @variables.next_available_slot = @outputs.next_available

    reasoning:
        instructions: ->
            | Handle escalation for the succession request.
              Business hours active: {! @variables.is_business_hours }
              Next available slot: {! @variables.next_available_slot }
              Case reference: {! @variables.case_ref_number }
              Succession status: {! @variables.succession_status }
              Eligibility score: {! @variables.eligibility_score }
              Priority: {! @variables.priority_level }
              If during business hours, offer to connect to a live agent.
              If outside business hours, create a support case and share the case reference.
              Use {!@actions.create_case} to create a case.
              Use {!@actions.get_summary} to generate a summary of the interaction.
        actions:
            create_case: @actions.create_support_case
                with case_subject=@variables.succession_status
                with case_detail=@variables.notes_text
                with record_ref=@variables.succession_record_id
                with priority_val=@variables.priority_level
                set @variables.case_ref_number = @outputs.case_ref
                set @variables.assigned_agent = @outputs.assigned_to
            get_summary: @actions.generate_summary
                with record_ref=@variables.succession_record_id
                with notes_val=@variables.notes_text
                set @variables.resolution_summary = @outputs.summary_text
            return_to_selector: @utils.transition to @topic.topic_selector
                description: "Return to topic selector after escalation."

    after_reasoning:
        if @variables.case_ref_number != "":
            set @variables.succession_status = "escalated"
        set @variables.escalation_requested = False

