config:
    agent_name: "ContextFullAgent"

context:
    memory:
        enabled: True
    user_profile:
        enabled: True
    past_conversations:
        enabled: False

language:
    default_locale: "en_US"

start_agent main_agent:
    description: "You respond to user queries"

    reasoning:
        instructions: ->
            | respond to whatever the user says! Make sure to speak in iambic pentameter
