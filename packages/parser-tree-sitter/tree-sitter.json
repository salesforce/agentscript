{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "agentscript",
      "camelcase": "AgentScript",
      "title": "AgentScript",
      "scope": "source.agentscript",
      "file-types": [
        "agent"
      ],
      "injection-regex": "^agentscript$",
      "class-name": "TreeSitterAgentScript",
      "highlights": "queries/highlights.scm"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "None",
    "description": "AgentScript grammar for tree-sitter",
    "authors": [
      {
        "name": "Allen Li",
        "email": "allen@allen.li"
      }
    ],
    "links": {
      "repository": "https://github.com/salesforce/agentscript"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}