# Actions test
topic action_demo:
    description: "My action"
#   ^ key
#                ^ string

topic action_demo2:
    reasoning_actions:
        @action.DoSomething to @variable.target
#       ^ decorator
#        ^ module
# NOTE: 'to' is inside an ERROR node here (not a valid statement), so it's parsed as id not keyword
#                              ^ decorator
#                               ^ module
#                                        ^ variable

topic action_demo3:
    reasoning_actions:
        transition to @topic.next
#       ^ keyword
#                     ^ decorator
#                      ^ module
#                            ^ variable

topic action_demo4:
    reasoning_actions:
        set @variable.result = @variable.a + @variable.b
#       ^ keyword
#           ^ decorator
#            ^ module
#                      ^ variable
#                            ^ operator
#                              ^ decorator
#                               ^ module
#                                        ^ variable
#                                          ^ operator
#                                            ^ decorator
#                                             ^ module
#                                                      ^ variable
