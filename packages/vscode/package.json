{
  "name": "@agentscript/vscode",
  "displayName": "Agent Script",
  "description": "VS Code extension for Agent Script language support",
  "version": "2.2.1",
  "private": true,
  "publisher": "Salesforce",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./dist/extension.js",
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@agentscript/lsp-server": "workspace:*",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.3",
    "@vscode/vsce": "^3.7.1"
  },
  "activationEvents": [],
  "scripts": {
    "prebuild": "tsx ../../scripts/sync-vscode-theme.ts",
    "build": "node esbuild.mjs",
    "dev": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "prepackage": "node scripts/check-changelog.mjs && pnpm run clean && pnpm run build && node esbuild.mjs --stage",
    "package": "cd staging && vsce package --no-dependencies -o ../publish/",
    "package:prerelease": "cd staging && vsce package --no-dependencies -o ../publish/ --pre-release",
    "clean": "node scripts/clean.mjs"
  },
  "contributes": {
    "languages": [
      {
        "id": "agentscript",
        "aliases": [
          "Agent Script",
          "AgentScript",
          "agentscript"
        ],
        "extensions": [
          ".agent"
        ],
        "firstLine": "^#\\s*@dialect:",
        "configuration": "./language-configuration.json"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "agentscript",
        "scopes": {
          "keyword": [
            "keyword.control.agentscript"
          ],
          "keyword.modification": [
            "storage.modifier.agentscript"
          ],
          "type": [
            "entity.name.type.agentscript"
          ],
          "function": [
            "entity.name.function.agentscript"
          ],
          "variable": [
            "variable.other.agentscript"
          ],
          "variable.readonly.defaultLibrary": [
            "constant.language.agentscript"
          ],
          "string": [
            "string.quoted.agentscript"
          ],
          "number": [
            "constant.numeric.agentscript"
          ],
          "comment": [
            "comment.line.agentscript"
          ],
          "namespace": [
            "entity.name.type.module.agentscript"
          ],
          "property": [
            "variable.other.property.agentscript"
          ],
          "operator": [
            "keyword.operator.agentscript"
          ],
          "decorator": [
            "string.regexp.decorator.agentscript"
          ],
          "keyword.block": [
            "keyword.other.block.agentscript"
          ],
          "keyword.blockName": [
            "entity.name.section.agentscript"
          ]
        }
      }
    ],
    "configurationDefaults": {
      "editor.semanticHighlighting.enabled": true,
      "[agentscript]": {
        "editor.semanticHighlighting.enabled": true,
        "editor.bracketPairColorization.enabled": false
      },
      "editor.semanticTokenColorCustomizations": {
        "rules": {
          "keyword:agentscript": {
            "foreground": "#C586C0",
            "bold": true
          },
          "keyword.modification:agentscript": {
            "foreground": "#D7BA7D",
            "bold": true,
            "italic": true
          },
          "keyword.block:agentscript": {
            "foreground": "#569CD6",
            "bold": true
          },
          "keyword.blockName:agentscript": {
            "foreground": "#D7BA7D",
            "bold": false
          },
          "type:agentscript": "#4EC9B0",
          "function:agentscript": {
            "foreground": "#DCDCAA",
            "bold": true
          },
          "variable:agentscript": "#9CDCFE",
          "variable.readonly.defaultLibrary:agentscript": "#569CD6",
          "string:agentscript": "#CE9178",
          "number:agentscript": "#B5CEA8",
          "operator:agentscript": "#D4D4D4",
          "comment:agentscript": {
            "foreground": "#6A9955",
            "italic": true
          },
          "namespace:agentscript": "#4EC9B0",
          "property:agentscript": "#D4D4D4",
          "decorator:agentscript": "#E06C75"
        },
        "[Default Light+]": {
          "rules": {
            "keyword:agentscript": {
              "foreground": "#A626A4",
              "bold": true
            },
            "keyword.modification:agentscript": {
              "foreground": "#A626A4",
              "bold": true,
              "italic": true
            },
            "keyword.block:agentscript": {
              "foreground": "#0550AE",
              "bold": true
            },
            "keyword.blockName:agentscript": {
              "foreground": "#A626A4",
              "bold": false
            },
            "type:agentscript": "#0A6577",
            "function:agentscript": {
              "foreground": "#B45309",
              "bold": true
            },
            "variable:agentscript": "#24292F",
            "variable.readonly.defaultLibrary:agentscript": {
              "foreground": "#A626A4",
              "bold": true
            },
            "string:agentscript": "#A31415",
            "number:agentscript": "#7A3E00",
            "operator:agentscript": "#586069",
            "comment:agentscript": {
              "foreground": "#6B7783",
              "italic": true
            },
            "namespace:agentscript": "#A31415",
            "property:agentscript": "#111DFF",
            "decorator:agentscript": "#A31415"
          }
        },
        "[Default Light Modern]": {
          "rules": {
            "keyword:agentscript": {
              "foreground": "#A626A4",
              "bold": true
            },
            "keyword.modification:agentscript": {
              "foreground": "#A626A4",
              "bold": true,
              "italic": true
            },
            "keyword.block:agentscript": {
              "foreground": "#0550AE",
              "bold": true
            },
            "keyword.blockName:agentscript": {
              "foreground": "#A626A4",
              "bold": false
            },
            "type:agentscript": "#0A6577",
            "function:agentscript": {
              "foreground": "#B45309",
              "bold": true
            },
            "variable:agentscript": "#24292F",
            "variable.readonly.defaultLibrary:agentscript": {
              "foreground": "#A626A4",
              "bold": true
            },
            "string:agentscript": "#A31415",
            "number:agentscript": "#7A3E00",
            "operator:agentscript": "#586069",
            "comment:agentscript": {
              "foreground": "#6B7783",
              "italic": true
            },
            "namespace:agentscript": "#A31415",
            "property:agentscript": "#111DFF",
            "decorator:agentscript": "#A31415"
          }
        },
        "[Default High Contrast Light]": {
          "rules": {
            "keyword:agentscript": {
              "foreground": "#A626A4",
              "bold": true
            },
            "keyword.modification:agentscript": {
              "foreground": "#A626A4",
              "bold": true,
              "italic": true
            },
            "keyword.block:agentscript": {
              "foreground": "#0550AE",
              "bold": true
            },
            "keyword.blockName:agentscript": {
              "foreground": "#A626A4",
              "bold": false
            },
            "type:agentscript": "#0A6577",
            "function:agentscript": {
              "foreground": "#B45309",
              "bold": true
            },
            "variable:agentscript": "#24292F",
            "variable.readonly.defaultLibrary:agentscript": {
              "foreground": "#A626A4",
              "bold": true
            },
            "string:agentscript": "#A31415",
            "number:agentscript": "#7A3E00",
            "operator:agentscript": "#586069",
            "comment:agentscript": {
              "foreground": "#6B7783",
              "italic": true
            },
            "namespace:agentscript": "#A31415",
            "property:agentscript": "#111DFF",
            "decorator:agentscript": "#A31415"
          }
        }
      }
    },
    "configuration": {
      "title": "AgentScript",
      "properties": {
        "agentscript.dialect": {
          "type": "string",
          "default": "agentforce",
          "enum": [
            "agentforce",
            "agentscript"
          ],
          "enumDescriptions": [
            "Agentforce dialect (with compilation support)",
            "AgentScript dialect"
          ],
          "description": "Default dialect for AgentScript files when no @dialect annotation is present"
        },
        "agentscript.trace.server": {
          "type": "string",
          "default": "off",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "description": "Traces the communication between VS Code and the AgentScript language server"
        }
      }
    }
  }
}
