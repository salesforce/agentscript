{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "AgentScript",
  "scopeName": "source.agentscript",
  "fileTypes": ["agent"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#template" },
    { "include": "#datetime" },
    { "include": "#number" },
    { "include": "#constants" },
    { "include": "#block-keyword" },
    { "include": "#storage" },
    { "include": "#keyword-logical" },
    { "include": "#keyword-control" },
    { "include": "#decorator" },
    { "include": "#operator" }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.number-sign.agentscript",
      "match": "#.*$"
    },
    "string": {
      "name": "string.quoted.double.agentscript",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.agentscript",
          "match": "\\\\[\"'\\\\nrt0]"
        }
      ]
    },
    "template": {
      "name": "meta.template.agentscript",
      "begin": "\\|",
      "beginCaptures": {
        "0": { "name": "keyword.operator.template.agentscript" }
      },
      "end": "$",
      "patterns": [
        {
          "name": "meta.embedded.agentscript",
          "begin": "\\{!",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.template.begin.agentscript" }
          },
          "end": "\\}",
          "endCaptures": {
            "0": { "name": "punctuation.definition.template.end.agentscript" }
          },
          "patterns": [
            { "include": "#decorator" },
            { "include": "#operator" },
            { "include": "#constants" },
            { "include": "#number" },
            { "include": "#string" }
          ]
        },
        {
          "name": "string.unquoted.template.agentscript",
          "match": "[^{\\n]+|(?!\\{!)\\{"
        }
      ]
    },
    "datetime": {
      "name": "constant.numeric.agentscript",
      "match": "\\b\\d{4}-\\d{2}-\\d{2}(?:T\\d{1,2}(?::\\d{2})?(?::\\d{2})?(?:\\.\\d+)?Z?)?(?![-\\d])"
    },
    "number": {
      "name": "constant.numeric.agentscript",
      "match": "\\b\\d+\\.?\\d*\\b|\\.\\d+\\b"
    },
    "constants": {
      "name": "constant.language.agentscript",
      "match": "\\b(?:True|False|None)\\b|\\.\\.\\.(?!\\.)"
    },
    "block-keyword": {
      "match": "^(system|config|language|variables|knowledge|context|security|topic|start_agent|subagent|connected_subagent|connection)(?:\\s+([a-zA-Z_][a-zA-Z0-9_]*))?(?=\\s*:)",
      "captures": {
        "1": { "name": "keyword.other.block.agentscript" },
        "2": { "name": "entity.name.section.agentscript" }
      }
    },
    "storage": {
      "match": "\\b(mutable|linked)(?:\\s+([a-zA-Z_][a-zA-Z0-9_]*))?",
      "captures": {
        "1": { "name": "storage.modifier.agentscript" },
        "2": { "name": "storage.type.agentscript" }
      }
    },
    "keyword-logical": {
      "name": "keyword.operator.logical.agentscript",
      "match": "\\bis not\\b|\\b(?:and|or|not|is)\\b"
    },
    "keyword-control": {
      "name": "keyword.control.agentscript",
      "match": "\\bavailable when\\b|\\b(?:if|elif|else|run|with|set|to|transition|empty)\\b"
    },
    "decorator": {
      "match": "(@)([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "punctuation.definition.decorator.agentscript" },
        "2": { "name": "entity.name.namespace.agentscript" }
      }
    },
    "operator": {
      "name": "keyword.operator.agentscript",
      "match": "==|!=|<=|>=|->|<|>|[+*\\/]|-(?!>)|=(?![>=])"
    }
  }
}
